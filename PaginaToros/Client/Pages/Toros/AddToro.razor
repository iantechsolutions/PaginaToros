@inject ITorosServicio _torosServicio
@inject ISocioServicio _sociosServicio
@inject IEstableServicio _estableServicio

@if (isReady)
{
    <div class="card">
        <div class="card-body">
            <EditForm Model="@oTorosuni" OnValidSubmit="Guardar">
                <DataAnnotationsValidator />

                <div class="row">
                    @if (!EsSocio)
                    {
                        <div class="col-sm">
                            <label>Propietario</label>
                            <SocioLookup Value="socioSeleccionado"
                                         ValueChanged="HandleSocioSeleccion"
                                         ValueExpression="@(() => socioSeleccionado)"
                                         Placeholder="Buscar por número o nombre" />
                        </div>
                    }
                    <div class="col-sm">
                        <label>Estado</label>
                        <RadzenDropDown @bind-Value="estadoTemp" Data="@estados" Style="width: 100%;" />
                    </div>
                    <div class="col-sm">
                        <label>Variedad</label>
                        <RadzenDropDown @bind-Value="oTorosuni.Variedad" Data="@variedades" Style="width: 100%;" />
                    </div>
                </div>

                <br />

                <div class="row">
                    <div class="col-sm">
                        <label>Fecha S/</label>
                        <RadzenDatePicker TValue="DateTime?" @bind-Value="dateTemp" ShowTime="false" DateFormat="dd/MM/yyyy" Style="width: 100%;" />
                    </div>
                    <div class="col-sm">
                        <label>Circunferencia escrotal</label>
                        <InputText @bind-Value="oTorosuni.CircEscrotal" class="form-control" />
                    </div>
                    <div class="col-sm">
                        <label>Tipo de toro</label>
                        <RadzenDropDown @bind-Value="tipoTemp" Data="@tiposToro" Style="width: 100%;" />
                    </div>
                </div>

                <br />

                <div class="row">
                    <div class="col-sm">
                        <label>HBA</label>
                        <InputText @bind-Value="oTorosuni.Hba" class="form-control" />
                    </div>
                    <div class="col-sm">
                        <label>Tatuaje</label>
                        <InputText @bind-Value="oTorosuni.Tatpart" class="form-control" />
                    </div>
                    <div class="col-sm">
                        <label>Nombre del toro</label>
                        <InputText @bind-Value="oTorosuni.NomDad" class="form-control" />
                    </div>
                </div>

                <br />

                <div class="row">
                    <div class="col-sm">
                        <label>Tip / ADN</label>
                        <InputText @bind-Value="oTorosuni.NrTsan" class="form-control" />
                    </div>
                    <div class="col-sm">
                        <label>Fecha de nacimiento</label>
                        <RadzenDatePicker TValue="DateTime?" @bind-Value="oTorosuni.Nacido" ShowTime="false" DateFormat="dd/MM/yyyy" Style="width: 100%;" />
                    </div>
                    <div class="col-sm">
                        <label>Número de orden</label>
                        <InputNumber @bind-Value="oTorosuni.Sbcod" class="form-control" />
                    </div>
                </div>

                <br />

                <div class="row">
                    <div class="col-sm">
                        <label>Establecimiento</label>
                        <RadzenDropDown TValue="int?"
                                        Data="@establecimientosDisponibles"
                                        TextProperty="Label"
                                        ValueProperty="IntValue"
                                        @bind-Value="establecimientoSelection"
                                        Placeholder="@establecimientoPlaceholder"
                                        AllowClear="true"
                                        Disabled="@establecimientoDisabled"
                                        Style="width: 100%;" />
                        @if (establecimientoDisabled)
                        {
                            <small class="text-muted">@establecimientoAyuda</small>
                        }
                    </div>
                </div>

                <br />

                <button type="submit" class="btn btn-primary mr-2">Aceptar</button>
                <button type="button" @onclick="Cancel" class="btn btn-light">Cancelar</button>
            </EditForm>
        </div>
    </div>
}
else
{
    <center>
        <div class="mb-2">
            <br />
            <RadzenProgressBar style="position:relative;width:93.5%" Value="100" ShowValue="false" ProgressBarStyle="ProgressBarStyle.Primary" Mode="ProgressBarMode.Indeterminate" />
        </div>
    </center>
}

@code {
    [CascadingParameter] BlazoredModalInstance ModalInstance { get; set; } = default!;
    [Parameter] public int Id { get; set; }
    [Parameter] public bool EsSocio { get; set; }

    private readonly List<string> estados = new() { "Activo", "Inactivo", "Inexistente", "Muerto", "Vendido" };
    private readonly List<string> variedades = new() { "H", "PH" };
    private readonly List<string> tiposToro = new() { "S/", "Puro Pedigree (SRA)", "Patagonico", "Ganador de prueba" };

    private readonly Dictionary<string, string> traductor = new()
    {
        {"Activo","1"},
        {"Inactivo", "2"},
        {"Inexistente","3"},
        {"Muerto","4"},
        {"Vendido","5"},
        {"Ganador de prueba","GP"},
        {"S/","S"},
        {"Puro Pedigree (SRA)","P"},
        {"Patagonico","A"}
    };

    private readonly Dictionary<string, string> traductorCarga = new()
    {
        {"1","Activo"},
        {"2", "Inactivo"},
        {"3","Inexistente"},
        {"4","Muerto"},
        {"5","Vendido"},
        {"GP","Ganador de prueba"},
        {"S","S/"},
        {"P","Puro Pedigree (SRA)"},
        {"A","Patagonico"}
    };

    private TorosuniDTO oTorosuni = new();
    private UserContextDTO? userContext;
    private SocioLookupItemDTO? socioSeleccionado;
    private List<TorosFilterOptionDTO> establecimientosDisponibles = new();
    private string estadoTemp = string.Empty;
    private string tipoTemp = string.Empty;
    private DateTime? dateTemp;
    private int? establecimientoSelection;
    private bool isReady;

    private bool establecimientoDisabled => !EsSocio && socioSeleccionado == null;
    private string establecimientoPlaceholder => establecimientoDisabled ? "Seleccioná un socio primero" : "Seleccionar establecimiento";
    private string establecimientoAyuda => "Los establecimientos disponibles se cargan según el socio seleccionado.";

    protected override async Task OnInitializedAsync()
    {
        userContext = await Http.GetFromJsonAsync<UserContextDTO>("api/Account/context");

        if (Id != 0)
        {
            var rt = await _torosServicio.GetById(Id);
            oTorosuni = rt.List ?? new TorosuniDTO();
            establecimientoSelection = oTorosuni.EstablecimientoId;

            if (traductorCarga.TryGetValue(oTorosuni.CodEstado ?? string.Empty, out var estado))
            {
                estadoTemp = estado;
            }

            if (traductorCarga.TryGetValue(oTorosuni.TipToro ?? string.Empty, out var tipo))
            {
                tipoTemp = tipo;
            }

            if (DateTime.TryParseExact(oTorosuni.Fechasba, "dd/MM/yyyy", System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var parsedDate))
            {
                dateTemp = parsedDate;
            }

            if (oTorosuni.Socio != null)
            {
                socioSeleccionado = new SocioLookupItemDTO
                {
                    Id = oTorosuni.Socio.Id,
                    Scod = oTorosuni.Socio.Scod ?? string.Empty,
                    NumeroSocio = oTorosuni.Socio.Codpos2 ?? string.Empty,
                    Nombre = oTorosuni.Socio.Nombre ?? string.Empty,
                    DisplayName = string.IsNullOrWhiteSpace(oTorosuni.Socio.Codpos2)
                        ? (oTorosuni.Socio.Nombre ?? string.Empty)
                        : $"{oTorosuni.Socio.Codpos2} - {oTorosuni.Socio.Nombre}"
                };
            }
        }

        await LoadEstablecimientosAsync();
        isReady = true;
    }

    private async Task Guardar()
    {
        if (!EsSocio)
        {
            if (socioSeleccionado == null)
            {
                await Swal.FireAsync(new SweetAlertOptions
                {
                    Title = "Falta el propietario",
                    Text = "Debés seleccionar un socio antes de guardar el toro.",
                    Icon = SweetAlertIcon.Warning,
                    ConfirmButtonText = "Entendido"
                });
                return;
            }

            oTorosuni.Criador = socioSeleccionado?.Scod;
        }

        if (traductor.TryGetValue(estadoTemp, out var estado))
        {
            oTorosuni.CodEstado = estado;
        }

        if (traductor.TryGetValue(tipoTemp, out var tipoToro))
        {
            oTorosuni.TipToro = tipoToro;
        }

        oTorosuni.Fechasba = dateTemp?.ToString("dd/MM/yyyy");
        oTorosuni.EstablecimientoId = establecimientoSelection.HasValue && establecimientoSelection.Value > 0
            ? establecimientoSelection
            : null;
        oTorosuni.Fecing ??= string.Empty;

        if (Id == 0)
        {
            await _torosServicio.Crear(oTorosuni);
        }
        else
        {
            await _torosServicio.Editar(oTorosuni);
        }

        await ModalInstance.CloseAsync(ModalResult.Ok(true));
    }

    private async Task HandleSocioSeleccion(SocioLookupItemDTO? socio)
    {
        socioSeleccionado = socio;
        if (socioSeleccionado == null)
        {
            establecimientoSelection = null;
        }

        await LoadEstablecimientosAsync();
        StateHasChanged();
    }

    private async Task LoadEstablecimientosAsync()
    {
        IEnumerable<int>? socioIds = null;
        int? socioId = socioSeleccionado?.Id;

        if (EsSocio)
        {
            socioIds = userContext?.AllowedSocios?.Select(x => x.Id).ToList() ?? new List<int>();
            if (socioSeleccionado?.Id > 0)
            {
                socioId = socioSeleccionado.Id;
            }
            else if (oTorosuni.Socio?.Id > 0)
            {
                socioId = oTorosuni.Socio.Id;
            }
        }

        var response = await _estableServicio.Search(socioId: socioId, socioIds: socioIds, take: 100);
        establecimientosDisponibles = response.List ?? new List<TorosFilterOptionDTO>();
        establecimientosDisponibles.Insert(0, new TorosFilterOptionDTO
        {
            IntValue = null,
            Value = string.Empty,
            Label = "Sin establecimiento"
        });

        if (establecimientoSelection.HasValue && establecimientosDisponibles.All(x => x.IntValue != establecimientoSelection))
        {
            establecimientoSelection = null;
        }
    }

    private async Task Cancel()
    {
        await ModalInstance.CancelAsync();
    }
}
