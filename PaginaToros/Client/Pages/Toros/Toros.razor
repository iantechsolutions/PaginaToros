@page "/toros"
@inject ITorosServicio _torosServicio

<style>
    @@media-print {
        .tablacontent {
            break-inside: avoid !important;
        }

        .no-print {
            display: none;
        }
    }

    .toros-page {
        width: 100%;
        margin: 0 auto 2rem;
        color: #172033;
    }

    .toros-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin: 1rem 0;
    }

    .toros-title {
        margin: 0;
        font-size: 1.55rem;
        font-weight: 700;
    }

    .toros-description {
        margin: .25rem 0 0;
        color: #64748b;
    }

    .toros-card {
        border: 1px solid #dbe3cf;
        border-radius: 8px;
        background: #fffdf8;
        box-shadow: 0 8px 18px rgba(76, 59, 32, .06);
    }

    .toros-filter-card {
        padding: .75rem;
        margin-bottom: .85rem;
    }

    .toros-toolbar {
        display: grid;
        grid-template-columns: minmax(260px, 1fr) minmax(190px, 250px) minmax(190px, 250px) max-content;
        align-items: center;
        gap: .5rem;
    }

    .toros-toolbar-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: .4rem;
        flex-wrap: wrap;
    }

    .toros-inline-select {
        min-width: 0;
    }

    .toros-status-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-top: .55rem;
    }

    .toros-loading-message {
        color: #2563eb;
        font-size: .92rem;
        font-weight: 600;
    }

    .filter-search {
        display: flex;
        gap: .4rem;
        align-items: center;
        width: 100%;
    }

    .filter-search-clear,
    .filter-search-status {
        white-space: nowrap;
    }

    .filter-search-status {
        color: #2563eb;
        font-size: .8rem;
        font-weight: 600;
    }

    .toros-filter-card .form-control,
    .toros-filter-card .rz-dropdown,
    .toros-filter-card .blazored-typeahead {
        min-height: 32px !important;
        height: 32px !important;
        border-color: #cfd8c2 !important;
        border-radius: 5px !important;
        background: #fff !important;
        color: #334155 !important;
        font-size: .84rem !important;
        box-shadow: none !important;
    }

    .toros-filter-card .form-control {
        padding: .28rem .55rem !important;
    }

    .toros-filter-card .form-control:focus,
    .toros-filter-card .rz-dropdown:not(.rz-state-disabled):focus,
    .toros-filter-card .rz-dropdown:not(.rz-state-disabled):focus-within,
    .toros-filter-card .blazored-typeahead:focus-within {
        border-color: #78985a !important;
        box-shadow: 0 0 0 .12rem rgba(120, 152, 90, .18) !important;
    }

    .toros-filter-card .rz-dropdown-label {
        min-height: 30px !important;
        height: 30px !important;
        line-height: 1.2 !important;
        padding: 0 1.8rem 0 .55rem !important;
        font-size: .84rem !important;
        display: flex !important;
        align-items: center !important;
    }

    .toros-filter-card .rz-dropdown-trigger {
        width: 1.75rem !important;
        min-width: 1.75rem !important;
        height: 30px !important;
        border-left: 0 !important;
        background: transparent !important;
        color: #78985a !important;
        box-shadow: none !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
    }

    .toros-filter-card .rz-dropdown-trigger-icon,
    .toros-filter-card .rz-dropdown-trigger .rzi,
    .toros-filter-card .rz-dropdown-trigger .rz-icon {
        color: #78985a !important;
        font-size: 1rem !important;
    }

    .toros-filter-card .blazored-typeahead__controls,
    .toros-filter-card .blazored-typeahead__input-mask-wrapper {
        min-height: 30px !important;
        height: 30px !important;
        overflow: hidden !important;
        min-width: 0 !important;
    }

    .toros-filter-card .blazored-typeahead__input,
    .toros-filter-card .blazored-typeahead__input-mask {
        height: 30px !important;
        padding: .25rem .45rem !important;
        font-size: .84rem !important;
        line-height: 1.25 !important;
        min-width: 0 !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        white-space: nowrap !important;
    }

    .toros-filter-card .blazored-typeahead__input-icon {
        width: 1.75rem !important;
        min-width: 1.75rem !important;
        height: 30px !important;
        background: transparent !important;
        border-left: 0 !important;
        padding: 0 !important;
        align-items: center !important;
        justify-content: center !important;
        flex: 0 0 1.75rem !important;
    }

    .toros-filter-card .blazored-typeahead__clear {
        width: 1.45rem !important;
        min-width: 1.45rem !important;
        height: 30px !important;
        padding: 0 !important;
        align-items: center !important;
        justify-content: center !important;
        flex: 0 0 1.45rem !important;
        color: #b8c0ae !important;
    }

    .toros-filter-card .blazored-typeahead__clear:hover {
        color: #52683d !important;
        background: transparent !important;
    }

    .toros-filter-card .blazored-typeahead__input-mask > *,
    .toros-filter-card .blazored-typeahead__selected-item {
        min-width: 0 !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        white-space: nowrap !important;
        line-height: 1.25 !important;
    }

    .toros-filter-card .blazored-typeahead__down-arrow path {
        fill: #78985a !important;
    }

    .toros-filter-card .btn {
        min-height: 32px;
        height: 32px;
        padding: .25rem .65rem;
        border-radius: 5px;
        font-size: .84rem;
        line-height: 1.1;
        white-space: nowrap;
    }

    .toros-filter-card .btn-outline-secondary {
        border-color: #78985a;
        color: #52683d;
        background: #fff;
    }

    .toros-filter-card .btn-outline-secondary:hover {
        background: #edf4e5;
        color: #3f562c;
    }

    .toros-filter-card .btn-light {
        background: #f2f5ee;
        border-color: #e1e7d9;
        color: #24321b;
    }

    .filter-chip-list {
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
        margin: 0;
    }

    .filter-chip {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .25rem .55rem;
        border: 1px solid #c8d9b6;
        border-radius: 999px;
        background: #edf4e5;
        color: #445f2f;
        font-size: .8rem;
    }

    .filter-chip-close {
        font-weight: bold;
    }

    .filter-panel-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, .25);
        z-index: 1000;
    }

    .filter-panel {
        position: fixed;
        top: 0;
        right: -440px;
        width: min(440px, 95vw);
        height: 100vh;
        background: white;
        box-shadow: -8px 0 24px rgba(15, 23, 42, .14);
        z-index: 1001;
        transition: right .2s ease;
        display: flex;
        flex-direction: column;
    }

    .filter-panel.open {
        right: 0;
    }

    .filter-panel-header,
    .filter-panel-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        padding: 1rem 1.1rem;
        border-bottom: 1px solid #e5e7eb;
    }

    .filter-panel-footer {
        border-top: 1px solid #e5e7eb;
        border-bottom: none;
        margin-top: auto;
    }

    .filter-panel-body {
        padding: 1rem 1.1rem;
        overflow: auto;
    }

    .toros-filters-grid {
        display: grid;
        gap: .85rem;
    }

    .toros-filters-grid label {
        display: block;
        font-weight: 600;
        margin-bottom: .3rem;
    }

    .toros-help-text {
        margin-top: .35rem;
        color: #64748b;
        font-size: .84rem;
    }

    .tablacontent {
        position: relative;
        overflow: hidden;
        border-radius: 8px;
    }

    .tablacontent .rz-datatable-tablewrapper,
    .tablacontent.rz-data-grid .rz-datatable-tablewrapper {
        border-radius: 8px 8px 0 0 !important;
    }

    .tablacontent .rz-cell-data,
    .tablacontent .rz-column-title-content {
        font-size: 11.2px !important;
    }

    .tablacontent .rz-cell-data {
        overflow: hidden !important;
        text-overflow: ellipsis;
        white-space: nowrap !important;
    }

    .tablacontent th.rz-unselectable-text.rz-text-align-left {
        background-color: #f1f5f9;
        color: #334155;
        position: sticky;
        top: 0;
        z-index: 2;
    }

    .tablacontent .rz-grid-table td,
    .tablacontent .rz-grid-table th {
        padding-left: .42rem !important;
        padding-right: .42rem !important;
    }

    .tablacontent .rz-grid-table thead th,
    .tablacontent th.rz-unselectable-text.rz-text-align-left {
        padding-top: .75rem !important;
        padding-bottom: .75rem !important;
    }

    .rz-paginator {
        border-top: solid #e2e8f0 1px;
    }

    .estado-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: .18rem .5rem;
        font-size: .72rem;
        font-weight: 700;
        background: #e2e8f0;
        color: #334155;
    }

    .estado-badge.activo {
        background: #dcfce7;
        color: #166534;
    }

    .table-action {
        width: 2rem;
        height: 1.75rem;
        width: 1.75rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        background: #fff;
    }

    .empty-state {
        padding: 3rem 1rem;
        text-align: center;
        color: #475569;
        border: 1px dashed #cbd5e1;
        border-radius: 8px;
        background: #f8fafc;
    }

    .table-overlay {
        position: absolute;
        inset: 0;
        z-index: 5;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, .68);
        color: #1d4ed8;
        font-weight: 700;
    }

    @@media (min-width: 1200px) {
        .toros-page {
            width: calc(100vw - 20.75rem);
            max-width: none;
            margin-left: calc((100% - (100vw - 20.75rem)) / 2);
            margin-right: 0;
        }
    }

    @@media (max-width: 1320px) {
        .toros-toolbar {
            grid-template-columns: minmax(240px, 1fr) minmax(180px, 230px) minmax(180px, 230px);
        }

        .toros-toolbar-actions {
            grid-column: 1 / -1;
            justify-content: flex-start;
        }
    }

    @@media (max-width: 980px) {
        .toros-header,
        .toros-status-row {
            flex-direction: column;
            align-items: stretch;
        }

        .toros-toolbar {
            grid-template-columns: 1fr;
        }

        .toros-toolbar-actions {
            justify-content: flex-start;
        }

        .toros-filter-card .btn {
            flex: 1 1 auto;
        }
    }
</style>

<div class="toros-page">
    <div class="toros-header no-print">
        <div>
            <h3 class="toros-title">Toros</h3>
            <p class="toros-description">Consulta, filtrá y ordená el padrón de toros sin perder contexto mientras se actualizan los resultados.</p>
        </div>
        @if (!esSocio)
        {
            <button class="btn btn-primary" @onclick="() => OpenToroModal(0)" disabled="@tableLoading">
                Agregar toro
            </button>
        }
    </div>

    <div class="toros-card toros-filter-card no-print">
        <div class="toros-toolbar">
            <SearchInput Value="@draftFilters.SearchText"
                         ValueChanged="OnSearchChanged"
                         IsLoading="@searchLoading"
                         Disabled="@metadataLoading"
                         Placeholder="Buscar por toro, socio, HBA, tatuaje, ADN o número de orden" />

            @if (!esSocio)
            {
                <div class="toros-inline-select">
                    <SocioLookup Value="adminSocioSeleccionado"
                                 ValueChanged="OnToolbarAdminSocioChanged"
                                 ValueExpression="@(() => adminSocioSeleccionado)"
                                 Placeholder="Filtrar por socio" />
                </div>
                <div class="toros-inline-select">
                    <RadzenDropDown TValue="int?"
                                    Data="@GetToolbarEstablecimientos()"
                                    TextProperty="Label"
                                    ValueProperty="IntValue"
                                    Value="@GetEstablecimientoSelection(appliedFilters)"
                                    Change="OnToolbarEstablecimientoChanged"
                                    AllowClear="true"
                                    Disabled="@(!CanChooseEstablecimiento(appliedFilters) || metadataLoading)"
                                    Placeholder="@GetEstablecimientoPlaceholder()"
                                    Style="width: 100%;" />
                </div>
            }
            else if (showSocioSelectorSocio)
            {
                <div class="toros-inline-select">
                    <RadzenDropDown TValue="int?"
                                    Data="@sociosSocioDropdown"
                                    TextProperty="DisplayName"
                                    ValueProperty="Id"
                                    Value="@draftFilters.SocioId"
                                    Change="OnSocioDropdownChanged"
                                    Placeholder="Todas mis razones sociales"
                                    AllowClear="true"
                                    Disabled="@metadataLoading"
                                    Style="width: 100%;" />
                </div>
                <div class="toros-inline-select">
                    <RadzenDropDown TValue="int?"
                                    Data="@GetToolbarEstablecimientos()"
                                    TextProperty="Label"
                                    ValueProperty="IntValue"
                                    Value="@GetEstablecimientoSelection(appliedFilters)"
                                    Change="OnToolbarEstablecimientoChanged"
                                    AllowClear="true"
                                    Disabled="@(!CanChooseEstablecimiento(appliedFilters) || metadataLoading)"
                                    Placeholder="@GetEstablecimientoPlaceholder()"
                                    Style="width: 100%;" />
                </div>
            }
            else
            {
                <div></div>
                <div class="toros-inline-select">
                    <RadzenDropDown TValue="int?"
                                    Data="@GetToolbarEstablecimientos()"
                                    TextProperty="Label"
                                    ValueProperty="IntValue"
                                    Value="@GetEstablecimientoSelection(appliedFilters)"
                                    Change="OnToolbarEstablecimientoChanged"
                                    AllowClear="true"
                                    Disabled="@(!CanChooseEstablecimiento(appliedFilters) || metadataLoading)"
                                    Placeholder="@GetEstablecimientoPlaceholder()"
                                    Style="width: 100%;" />
                </div>
            }

            <div class="toros-toolbar-actions">
                <button class="btn btn-outline-secondary" @onclick="ClearFilters" disabled="@(filtersApplying || metadataLoading)">
                    Limpiar filtros
                </button>
                @if (!esSocio)
                {
                    <button class="btn btn-light" @onclick="PaginaReporte">
                        Reporte x socio
                    </button>
                }
                <button class="btn btn-light" title="Filtros avanzados" @onclick="OpenFilterPanel">
                    <FeatherFilter Color="Black" />
                </button>
            </div>
        </div>

        @if (activeChips.Any() || metadataLoading || filtersApplying || tableLoading)
        {
            <div class="toros-status-row">
                <FilterChipList Items="@activeChips" OnRemove="RemoveFilterChip" />
                @if (metadataLoading)
                {
                    <span class="toros-loading-message">Cargando filtros...</span>
                }
                else if (filtersApplying || tableLoading)
                {
                    <span class="toros-loading-message">Aplicando filtros...</span>
                }
            </div>
        }
    </div>

    <FilterPanel Visible="@showFilterPanel"
                 VisibleChanged="OnPanelVisibilityChanged"
                 ApplyClicked="ApplyFiltersFromPanel"
                 ClearClicked="ClearFilters"
                 Title="Filtros avanzados">
        <div class="toros-filters-grid">
            <div>
                <label>Estado</label>
                <RadzenDropDown TValue="string"
                                Data="@metadata.Estados"
                                TextProperty="Label"
                                ValueProperty="Value"
                                @bind-Value="draftFilters.Estado"
                                AllowClear="true"
                                Disabled="@metadataLoading"
                                Style="width: 100%;" />
            </div>
            <div>
                <label>Tipo de toro</label>
                <RadzenDropDown TValue="string"
                                Data="@metadata.TiposToro"
                                TextProperty="Label"
                                ValueProperty="Value"
                                @bind-Value="draftFilters.TipoToro"
                                AllowClear="true"
                                Disabled="@metadataLoading"
                                Style="width: 100%;" />
            </div>
            @if (!esSocio)
            {
                <div>
                    <label>Socio / propietario</label>
                    <SocioLookup Value="adminSocioSeleccionado"
                                 ValueChanged="OnDraftAdminSocioChanged"
                                 ValueExpression="@(() => adminSocioSeleccionado)"
                                 Placeholder="Buscar por número o nombre" />
                </div>
            }
            <div>
                <label>Establecimiento</label>
                <RadzenDropDown TValue="int?"
                                Data="@metadata.Establecimientos"
                                TextProperty="Label"
                                ValueProperty="IntValue"
                                Value="@GetEstablecimientoSelection(draftFilters)"
                                Change="OnDraftEstablecimientoChanged"
                                AllowClear="true"
                                Disabled="@(!CanChooseEstablecimiento(draftFilters) || metadataLoading)"
                                Placeholder="@GetEstablecimientoPlaceholder()"
                                Style="width: 100%;" />
                @if (metadataLoading)
                {
                    <div class="toros-help-text">Cargando establecimientos...</div>
                }
                else if (draftFilters.SocioId.HasValue && !CanChooseEstablecimiento(draftFilters))
                {
                    <div class="toros-help-text">Sin establecimientos disponibles</div>
                }
                @if (metadata.HasSinEstablecimientoOption)
                {
                    <div class="mt-2">
                        <label class="mb-0">
                            <input type="checkbox" @bind="draftFilters.IncluirSinEstablecimiento" />
                            <span class="ml-1">Sin establecimiento</span>
                        </label>
                    </div>
                }
            </div>
            <div>
                <label>Variedad</label>
                <RadzenDropDown TValue="string"
                                Data="@metadata.Variedades"
                                TextProperty="Label"
                                ValueProperty="Value"
                                @bind-Value="draftFilters.Variedad"
                                AllowClear="true"
                                Disabled="@metadataLoading"
                                Style="width: 100%;" />
            </div>
            <div>
                <label>Nombre del toro</label>
                <input class="form-control" value="@draftFilters.NombreToro" @oninput="OnNombreToroInput" />
            </div>
            <div>
                <label>Número de orden</label>
                <input type="number" class="form-control" value="@FormatNullableInt(draftFilters.NroOrden)" @oninput="OnNroOrdenInput" />
            </div>
            <div>
                <label>HBA</label>
                <input class="form-control" value="@draftFilters.Hba" @oninput="OnHbaInput" />
            </div>
            <div>
                <label>Tatuaje</label>
                <input class="form-control" value="@draftFilters.Tatuaje" @oninput="OnTatuajeInput" />
            </div>
            <div>
                <label>Tipificación / ADN</label>
                <input class="form-control" value="@draftFilters.TipAdn" @oninput="OnTipAdnInput" />
            </div>
            <div>
                <label>Fecha S/ desde</label>
                <RadzenDatePicker TValue="DateTime?" @bind-Value="draftFilters.FechaSDesde" DateFormat="dd/MM/yyyy" Style="width: 100%;" />
            </div>
            <div>
                <label>Fecha S/ hasta</label>
                <RadzenDatePicker TValue="DateTime?" @bind-Value="draftFilters.FechaSHasta" DateFormat="dd/MM/yyyy" Style="width: 100%;" />
            </div>
            <div>
                <label>Fecha nacimiento desde</label>
                <RadzenDatePicker TValue="DateTime?" @bind-Value="draftFilters.FechaNacimientoDesde" DateFormat="dd/MM/yyyy" Style="width: 100%;" />
            </div>
            <div>
                <label>Fecha nacimiento hasta</label>
                <RadzenDatePicker TValue="DateTime?" @bind-Value="draftFilters.FechaNacimientoHasta" DateFormat="dd/MM/yyyy" Style="width: 100%;" />
            </div>
        </div>
    </FilterPanel>

    <div class="toros-card tablacontent">
        @if (tableLoading && items.Count > 0)
        {
            <div class="table-overlay">Actualizando resultados...</div>
        }
        <RadzenDataGrid Data="@items"
                        TItem="TorosuniDTO"
                        IsLoading="@tableLoading"
                        AllowColumnResize="true"
                        AllowSorting="true"
                        AllowPaging="true"
                        ShowPagingSummary="true"
                        Density="Density.Compact"
                        PageSize="15"
                        Count="@cantidad"
                        LoadData="LoadData"
                        @ref="grid"
                        PagerHorizontalAlign="HorizontalAlign.Center">
            <EmptyTemplate>
                <div class="empty-state">
                    No hay toros para los filtros seleccionados.
                </div>
            </EmptyTemplate>
            <Columns>
                <RadzenDataGridColumn TItem="TorosuniDTO" Property="CodEstado" Title="Estado" Width="74px">
                    <Template Context="data">
                        <span class="estado-badge @(data.CodEstado == "1" ? "activo" : string.Empty)" title="@TranslateEstado(data.CodEstado)">
                            @TranslateEstado(data.CodEstado)
                        </span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="TorosuniDTO" Property="TipToro" Title="Tipo" Width="92px">
                    <Template Context="data"><span title="@TranslateTipo(data.TipToro)">@TranslateTipo(data.TipToro)</span></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="TorosuniDTO" Property="Socio.Nombre" Title="Propietario" Width="132px">
                    <Template Context="data"><span title="@data.Socio?.Nombre">@data.Socio?.Nombre</span></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="TorosuniDTO" Property="Establecimiento.Nombre" Title="Establecimiento" Width="138px">
                    <Template Context="data"><span title="@GetEstablecimientoNombre(data)">@GetEstablecimientoNombre(data)</span></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="TorosuniDTO" Property="Variedad" Title="Var." Width="52px" />
                <RadzenDataGridColumn TItem="TorosuniDTO" Property="NomDad" Title="Nombre del toro" Width="156px">
                    <Template Context="data"><span title="@data.NomDad">@data.NomDad</span></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="TorosuniDTO" Property="Sbcod" Title="Orden" Width="68px" />
                <RadzenDataGridColumn TItem="TorosuniDTO" Property="Fechasba" Title="Fecha S/" Width="84px" />
                <RadzenDataGridColumn TItem="TorosuniDTO" Property="Hba" Title="HBA" Width="72px">
                    <Template Context="data"><span title="@data.Hba">@data.Hba</span></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="TorosuniDTO" Property="Tatpart" Title="Tatuaje" Width="72px">
                    <Template Context="data"><span title="@data.Tatpart">@data.Tatpart</span></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="TorosuniDTO" Property="NrTsan" Title="Tip./ADN" Width="78px">
                    <Template Context="data"><span title="@data.NrTsan">@data.NrTsan</span></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="TorosuniDTO" Property="Nacido" Title="Nacimiento" Width="88px">
                    <Template Context="data">
                        @if (data.Nacido.HasValue)
                        {
                            @data.Nacido.Value.ToString("dd/MM/yyyy")
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="TorosuniDTO" Property="CreatedAt" Title="Alta" Width="82px">
                    <Template Context="data">
                        @if (data.CreatedAt != default)
                        {
                            @data.CreatedAt.ToString("dd/MM/yyyy")
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="TorosuniDTO" Filterable="false" Sortable="false" Width="38px">
                    <Template Context="data">
                        <button class="table-action" title="Editar" @onclick="() => OpenToroModal(data.Id)">
                            <FeatherEdit Size="16" Color="green" />
                        </button>
                    </Template>
                </RadzenDataGridColumn>
                @if (!esSocio)
                {
                    <RadzenDataGridColumn TItem="TorosuniDTO" Filterable="false" Sortable="false" Width="38px">
                        <Template Context="data">
                            <button class="table-action" title="Eliminar" @onclick="() => ConfirmDelete(data.Id)">
                                <FeatherTrash2 Size="16" Color="red" />
                            </button>
                        </Template>
                    </RadzenDataGridColumn>
                }
            </Columns>
        </RadzenDataGrid>
    </div>
</div>

@code {
    [CascadingParameter] public IModalService Modal { get; set; } = default!;

    private readonly Dictionary<string, string> estadoLabels = new()
    {
        {"1","Activo"},
        {"2","Inactivo"},
        {"3","Inexistente"},
        {"4","Muerto"},
        {"5","Vendido"}
    };

    private readonly Dictionary<string, string> tipoToroLabels = new()
    {
        {"P","Puro Pedigree (SRA)"},
        {"S","S/"},
        {"GP","Ganador de prueba"},
        {"A","Patagonico"}
    };

    private RadzenDataGrid<TorosuniDTO>? grid;
    private TorosFilterState draftFilters = new();
    private TorosFilterState appliedFilters = new();
    private TorosFilterMetadataResponse metadata = new();
    private List<TorosuniDTO> items = new();
    private List<FilterChipItem> activeChips = new();
    private List<UserSocioOptionDTO> sociosSocioDropdown = new();
    private SocioLookupItemDTO? adminSocioSeleccionado;
    private UserContextDTO? userContext;
    private bool esSocio;
    private bool tableLoading;
    private bool metadataLoading;
    private bool filtersApplying;
    private bool searchLoading;
    private bool showFilterPanel;
    private bool showSocioSelectorSocio;
    private bool initialGridLoadTriggered;
    private int cantidad;
    private int metadataRequestVersion;
    private int tableRequestVersion;

    protected override async Task OnInitializedAsync()
    {
        esSocio = await UserHasRole("Socio");
        FilterQueryStateHelper.ApplyTorosQuery(draftFilters, nav.Uri);
        appliedFilters.CopyFrom(draftFilters);

        if (esSocio)
        {
            userContext = await Http.GetFromJsonAsync<UserContextDTO>("api/Account/context");
            sociosSocioDropdown = userContext?.AllowedSocios ?? new List<UserSocioOptionDTO>();
            showSocioSelectorSocio = sociosSocioDropdown.Count > 1;
        }

        await RefreshMetadataAsync(appliedFilters);
        SyncStateLabelsFromMetadata(appliedFilters);
        draftFilters.CopyFrom(appliedFilters);
        BuildActiveChips();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || initialGridLoadTriggered || grid == null)
        {
            return;
        }

        initialGridLoadTriggered = true;
        await grid.Reload();
    }

    private async Task LoadData(LoadDataArgs args)
    {
        var requestId = ++tableRequestVersion;
        tableLoading = true;
        StateHasChanged();

        try
        {
            ApplySortFromArgs(args);
            var response = await _torosServicio.Search(appliedFilters.ToRequest(args.Skip ?? 0, args.Top ?? 15, GetScopedSocioIds()));
            if (requestId != tableRequestVersion)
            {
                return;
            }

            items = response.List?.Items ?? new List<TorosuniDTO>();
            cantidad = response.List?.TotalCount ?? 0;
            BuildActiveChips();
        }
        finally
        {
            if (requestId == tableRequestVersion)
            {
                tableLoading = false;
                filtersApplying = false;
                searchLoading = false;
                StateHasChanged();
            }
        }
    }

    private async Task<bool> UserHasRole(string role)
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        return authenticationState.User.IsInRole(role);
    }

    private async Task OnSearchChanged(string value)
    {
        searchLoading = true;
        draftFilters.SearchText = value;
        appliedFilters.SearchText = value;
        await ApplyAppliedFiltersAsync(persistQuery: false, refreshMetadata: false);
    }

    private async Task OnToolbarAdminSocioChanged(SocioLookupItemDTO? socio)
    {
        SetSocio(draftFilters, socio);
        appliedFilters.CopyFrom(draftFilters);
        await ApplyAppliedFiltersAsync();
    }

    private async Task OnDraftAdminSocioChanged(SocioLookupItemDTO? socio)
    {
        SetSocio(draftFilters, socio);
        await RefreshMetadataAsync(draftFilters);
        SyncStateLabelsFromMetadata(draftFilters);
    }

    private async Task OnSocioDropdownChanged(object value)
    {
        var selectedId = ParseNullableInt(value);
        draftFilters.SocioId = selectedId;
        draftFilters.SocioLabel = sociosSocioDropdown.FirstOrDefault(x => x.Id == selectedId)?.DisplayName ?? string.Empty;
        ClearEstablecimiento(draftFilters);
        appliedFilters.CopyFrom(draftFilters);
        await ApplyAppliedFiltersAsync();
    }

    private async Task OnDraftEstablecimientoChanged(object value)
    {
        SetEstablecimiento(draftFilters, value);
        await Task.CompletedTask;
    }

    private async Task OnToolbarEstablecimientoChanged(object value)
    {
        SetEstablecimiento(draftFilters, value);
        appliedFilters.CopyFrom(draftFilters);
        await ApplyAppliedFiltersAsync(refreshMetadata: false);
    }

    private Task ApplyFiltersFromPanel()
    {
        appliedFilters.CopyFrom(draftFilters);
        return ApplyAppliedFiltersAsync();
    }

    private async Task ApplyAppliedFiltersAsync(bool persistQuery = true, bool refreshMetadata = true)
    {
        filtersApplying = true;
        if (refreshMetadata)
        {
            await RefreshMetadataAsync(appliedFilters);
            SyncStateLabelsFromMetadata(appliedFilters);
            draftFilters.CopyFrom(appliedFilters);
        }

        BuildActiveChips();
        if (persistQuery)
        {
            PersistQueryState();
        }

        await ReloadGridFromStartAsync();
    }

    private async Task ClearFilters()
    {
        filtersApplying = true;
        draftFilters.Clear();
        appliedFilters.Clear();
        adminSocioSeleccionado = null;
        ResetDependentMetadata();
        BuildActiveChips();
        PersistQueryState();

        var reloadTask = ReloadGridFromStartAsync();
        var metadataTask = RefreshMetadataAsync(appliedFilters);

        await reloadTask;
        await metadataTask;
    }

    private async Task ReloadGridFromStartAsync()
    {
        if (grid != null)
        {
            if (grid.CurrentPage > 0)
            {
                await grid.FirstPage(true);
            }
            else
            {
                await grid.Reload();
            }
        }
    }

    private async Task RefreshMetadataAsync(TorosFilterState state)
    {
        var requestId = ++metadataRequestVersion;
        metadataLoading = true;
        StateHasChanged();

        try
        {
            var request = new TorosFilterRequest
            {
                Skip = 0,
                Take = 1,
                SocioId = state.SocioId,
                SocioIds = GetScopedSocioIds().ToList()
            };

            var response = await _torosServicio.GetFilterMetadata(request);
            if (requestId != metadataRequestVersion)
            {
                return;
            }

            metadata = response.List ?? new TorosFilterMetadataResponse();
            EnsureValidEstablecimiento(state);
        }
        finally
        {
            if (requestId == metadataRequestVersion)
            {
                metadataLoading = false;
                StateHasChanged();
            }
        }
    }

    private void ResetDependentMetadata()
    {
        metadata.Socios = new List<SocioLookupItemDTO>();
        metadata.Establecimientos = new List<TorosFilterOptionDTO>();
        metadata.Variedades = new List<TorosFilterOptionDTO>();
        metadata.ShowSocioSelector = false;
        metadata.ShowEstablecimientoSelector = false;
        metadata.HasSinEstablecimientoOption = false;
    }

    private void SyncStateLabelsFromMetadata(TorosFilterState state)
    {
        if (state.SocioId.HasValue)
        {
            state.SocioLabel = adminSocioSeleccionado?.DisplayName
                ?? sociosSocioDropdown.FirstOrDefault(x => x.Id == state.SocioId)?.DisplayName
                ?? metadata.Socios.FirstOrDefault(x => x.Id == state.SocioId)?.DisplayName
                ?? state.SocioLabel;
        }

        if (state.EstablecimientoId.HasValue)
        {
            state.EstablecimientoLabel = metadata.Establecimientos
                .FirstOrDefault(x => x.IntValue == state.EstablecimientoId)?.Label ?? state.EstablecimientoLabel;
        }
    }

    private IEnumerable<int> GetScopedSocioIds()
    {
        if (!esSocio)
        {
            return Enumerable.Empty<int>();
        }

        return userContext?.AllowedSocios.Select(x => x.Id) ?? Enumerable.Empty<int>();
    }

    private bool CanChooseEstablecimiento(TorosFilterState state)
    {
        if (metadataLoading)
        {
            return false;
        }

        if (esSocio)
        {
            return metadata.ShowEstablecimientoSelector;
        }

        return state.SocioId.HasValue
            && (metadata.Establecimientos.Count > 0 || metadata.HasSinEstablecimientoOption);
    }

    private string GetEstablecimientoPlaceholder()
    {
        if (metadataLoading)
        {
            return "Cargando establecimientos...";
        }

        if (!metadata.ShowEstablecimientoSelector)
        {
            return "Sin establecimientos disponibles";
        }

        return "Filtrar por establecimiento";
    }

    private IEnumerable<TorosFilterOptionDTO> GetToolbarEstablecimientos()
    {
        if (!metadata.HasSinEstablecimientoOption)
        {
            return metadata.Establecimientos;
        }

        return metadata.Establecimientos
            .Concat(new[]
            {
                new TorosFilterOptionDTO
                {
                    IntValue = -1,
                    Value = "-1",
                    Label = "Sin establecimiento"
                }
            });
    }

    private int? GetEstablecimientoSelection(TorosFilterState state)
        => state.IncluirSinEstablecimiento ? -1 : state.EstablecimientoId;

    private string TranslateEstado(string? value)
        => !string.IsNullOrWhiteSpace(value) && estadoLabels.TryGetValue(value, out var label) ? label : (value ?? string.Empty);

    private string TranslateTipo(string? value)
        => !string.IsNullOrWhiteSpace(value) && tipoToroLabels.TryGetValue(value, out var label) ? label : (value ?? string.Empty);

    private string GetEstablecimientoNombre(TorosuniDTO data)
        => data.Establecimiento?.Nombre ?? "Sin establecimiento";

    private async Task OpenToroModal(int id)
    {
        if (id == 0 && esSocio)
        {
            await Swal.FireAsync(new SweetAlertOptions
            {
                Title = "Acción no permitida",
                Text = "Como socio solo podés editar tus toros. No podés agregar nuevos.",
                Icon = SweetAlertIcon.Info,
                ConfirmButtonText = "Entendido"
            });
            return;
        }

        var parameters = new ModalParameters();
        parameters.Add(nameof(AddToro.Id), id);
        parameters.Add(nameof(AddToro.EsSocio), esSocio);
        var modal = Modal.Show<AddToro>(id == 0 ? "Agregar Toro" : "Editar Toro", parameters, new ModalOptions
        {
            Size = ModalSize.ExtraLarge
        });

        var result = await modal.Result;
        if (!result.Cancelled && grid != null)
        {
            await grid.Reload();
        }
    }

    private async Task ConfirmDelete(int id)
    {
        SweetAlertResult result = await Swal.FireAsync(new SweetAlertOptions
        {
            Title = "¿Está seguro?",
            Text = "Se eliminará este toro",
            Icon = SweetAlertIcon.Warning,
            ShowCancelButton = true,
            ConfirmButtonText = "Eliminar",
            CancelButtonText = "Cancelar"
        });

        if (!string.IsNullOrEmpty(result.Value))
        {
            await Delete(id);
        }
    }

    private async Task Delete(int id)
    {
        var currentPage = grid?.CurrentPage ?? 0;
        var response = await _torosServicio.Eliminar(id);
        if (!response || grid == null)
        {
            return;
        }

        if (items.Count == 1 && currentPage > 0)
        {
            await grid.GoToPage(currentPage - 1);
            return;
        }

        await grid.Reload();
    }

    private async Task PaginaReporte()
    {
        nav.NavigateTo("/reporteprint/1");
        await Task.CompletedTask;
    }

    private void BuildActiveChips()
    {
        var chips = new List<FilterChipItem>();
        AddChip(chips, "search", "Buscar", appliedFilters.SearchText);
        AddChip(chips, "socio", "Socio", appliedFilters.SocioLabel);
        AddChip(chips, "establecimiento", "Establecimiento", appliedFilters.IncluirSinEstablecimiento ? "Sin establecimiento" : appliedFilters.EstablecimientoLabel);
        AddChip(chips, "estado", "Estado", TranslateEstado(appliedFilters.Estado));
        AddChip(chips, "tipoToro", "Tipo", TranslateTipo(appliedFilters.TipoToro));
        AddChip(chips, "variedad", "Variedad", appliedFilters.Variedad);
        AddChip(chips, "nombreToro", "Nombre", appliedFilters.NombreToro);
        AddChip(chips, "nroOrden", "Orden", appliedFilters.NroOrden?.ToString());
        AddChip(chips, "hba", "HBA", appliedFilters.Hba);
        AddChip(chips, "tatuaje", "Tatuaje", appliedFilters.Tatuaje);
        AddChip(chips, "tipAdn", "ADN", appliedFilters.TipAdn);
        AddChip(chips, "fechaS", "Fecha S/", FormatRange(appliedFilters.FechaSDesde, appliedFilters.FechaSHasta));
        AddChip(chips, "fechaNacimiento", "Nacimiento", FormatRange(appliedFilters.FechaNacimientoDesde, appliedFilters.FechaNacimientoHasta));
        activeChips = chips;
    }

    private static void AddChip(ICollection<FilterChipItem> chips, string key, string label, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            chips.Add(new FilterChipItem { Key = key, Label = label, Value = value });
        }
    }

    private static string FormatRange(DateTime? desde, DateTime? hasta)
    {
        if (!desde.HasValue && !hasta.HasValue)
        {
            return string.Empty;
        }

        return $"{desde?.ToString("dd/MM/yyyy") ?? "..."} - {hasta?.ToString("dd/MM/yyyy") ?? "..."}";
    }

    private async Task RemoveFilterChip(string key)
    {
        ClearFilterKey(draftFilters, key);
        appliedFilters.CopyFrom(draftFilters);
        await ApplyAppliedFiltersAsync();
    }

    private Task OnPanelVisibilityChanged(bool visible)
    {
        showFilterPanel = visible;
        if (!visible)
        {
            draftFilters.CopyFrom(appliedFilters);
        }

        return Task.CompletedTask;
    }

    private void OpenFilterPanel()
    {
        draftFilters.CopyFrom(appliedFilters);
        showFilterPanel = true;
    }

    private void PersistQueryState()
    {
        var url = FilterQueryStateHelper.BuildTorosUrl("/toros", appliedFilters);
        var current = nav.ToBaseRelativePath(nav.Uri);
        var next = nav.ToBaseRelativePath(nav.ToAbsoluteUri(url).ToString());

        if (!string.Equals(current, next, StringComparison.Ordinal))
        {
            nav.NavigateTo(url, replace: true);
        }
    }

    private void ApplySortFromArgs(LoadDataArgs args)
    {
        var orderBy = args.OrderBy ?? string.Empty;
        if (string.IsNullOrWhiteSpace(orderBy))
        {
            return;
        }

        var parts = orderBy.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var property = parts.FirstOrDefault() ?? string.Empty;
        var direction = parts.Length > 1 ? parts[1] : "asc";
        var sortBy = MapSortProperty(property);

        appliedFilters.SortBy = sortBy;
        appliedFilters.SortDirection = direction.Equals("desc", StringComparison.OrdinalIgnoreCase) ? "desc" : "asc";
        draftFilters.SortBy = appliedFilters.SortBy;
        draftFilters.SortDirection = appliedFilters.SortDirection;
    }

    private static string MapSortProperty(string property)
    {
        return property.ToLowerInvariant() switch
        {
            "codestado" => "estado",
            "socio.nombre" => "propietario",
            "establecimiento.nombre" => "establecimiento",
            "nomdad" => "nombreToro",
            "fechasba" => "fechaS",
            "hba" => "hba",
            "tatpart" => "tatuaje",
            "nacido" => "fechaNacimiento",
            "createdat" => "createdAt",
            _ => string.Empty
        };
    }

    private void SetSocio(TorosFilterState state, SocioLookupItemDTO? socio)
    {
        adminSocioSeleccionado = socio;
        state.SocioId = socio?.Id;
        state.SocioLabel = socio?.DisplayName ?? string.Empty;
        ClearEstablecimiento(state);
    }

    private void SetEstablecimiento(TorosFilterState state, object value)
    {
        var selectedValue = ParseNullableInt(value);

        if (selectedValue.HasValue && selectedValue.Value == -1)
        {
            state.EstablecimientoId = null;
            state.IncluirSinEstablecimiento = true;
            state.EstablecimientoLabel = "Sin establecimiento";
            return;
        }

        state.EstablecimientoId = selectedValue;
        state.IncluirSinEstablecimiento = false;
        state.EstablecimientoLabel = metadata.Establecimientos
            .FirstOrDefault(x => x.IntValue == state.EstablecimientoId)?.Label ?? string.Empty;
    }

    private void EnsureValidEstablecimiento(TorosFilterState state)
    {
        if (state.EstablecimientoId.HasValue && metadata.Establecimientos.All(x => x.IntValue != state.EstablecimientoId))
        {
            ClearEstablecimiento(state);
        }

        if (state.IncluirSinEstablecimiento && !metadata.HasSinEstablecimientoOption)
        {
            ClearEstablecimiento(state);
        }
    }

    private static void ClearEstablecimiento(TorosFilterState state)
    {
        state.EstablecimientoId = null;
        state.EstablecimientoLabel = string.Empty;
        state.IncluirSinEstablecimiento = false;
    }

    private static void ClearFilterKey(TorosFilterState state, string key)
    {
        switch (key)
        {
            case "search":
                state.SearchText = string.Empty;
                break;
            case "socio":
                state.SocioId = null;
                state.SocioLabel = string.Empty;
                ClearEstablecimiento(state);
                break;
            case "establecimiento":
                ClearEstablecimiento(state);
                break;
            case "estado":
                state.Estado = string.Empty;
                break;
            case "tipoToro":
                state.TipoToro = string.Empty;
                break;
            case "variedad":
                state.Variedad = string.Empty;
                break;
            case "nombreToro":
                state.NombreToro = string.Empty;
                break;
            case "nroOrden":
                state.NroOrden = null;
                break;
            case "hba":
                state.Hba = string.Empty;
                break;
            case "tatuaje":
                state.Tatuaje = string.Empty;
                break;
            case "tipAdn":
                state.TipAdn = string.Empty;
                break;
            case "fechaS":
                state.FechaSDesde = null;
                state.FechaSHasta = null;
                break;
            case "fechaNacimiento":
                state.FechaNacimientoDesde = null;
                state.FechaNacimientoHasta = null;
                break;
        }
    }

    private static int? ParseNullableInt(object? value)
    {
        if (value is null)
        {
            return null;
        }

        if (value is int intValue)
        {
            return intValue;
        }

        if (int.TryParse(value.ToString(), out var parsed))
        {
            return parsed;
        }

        return null;
    }

    private static string FormatNullableInt(int? value)
        => value?.ToString() ?? string.Empty;

    private Task OnNombreToroInput(ChangeEventArgs args)
    {
        draftFilters.NombreToro = args.Value?.ToString() ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnNroOrdenInput(ChangeEventArgs args)
    {
        var rawValue = args.Value?.ToString();
        draftFilters.NroOrden = int.TryParse(rawValue, out var parsed) ? parsed : null;
        return Task.CompletedTask;
    }

    private Task OnHbaInput(ChangeEventArgs args)
    {
        draftFilters.Hba = args.Value?.ToString() ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnTatuajeInput(ChangeEventArgs args)
    {
        draftFilters.Tatuaje = args.Value?.ToString() ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnTipAdnInput(ChangeEventArgs args)
    {
        draftFilters.TipAdn = args.Value?.ToString() ?? string.Empty;
        return Task.CompletedTask;
    }
}
