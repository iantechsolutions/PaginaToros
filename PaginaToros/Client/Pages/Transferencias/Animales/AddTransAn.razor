    private bool PuedeVerPlantel(PlantelDTO? plantel)
        => plantel != null && !string.IsNullOrWhiteSpace(plantel.Placod);

    private void TogglePlantelPanel(PlantelDTO? plantel)
    {
        if (!PuedeVerPlantel(plantel))
        {
            return;
        }

        if (plantelPanelAbierto && plantelPanelSeleccionado?.Id == plantel!.Id)
        {
            CerrarPlantelPanel();
            return;
        }

        plantelPanelSeleccionado = plantel;
        plantelPanelAbierto = true;
    }

    private void CerrarPlantelPanel()
    {
        plantelPanelSeleccionado = null;
        plantelPanelAbierto = false;
    }

    private string GetPlantelPanelTitle(PlantelDTO? plantel)
    {
        if (plantel is null)
        {
            return string.Empty;
        }

        var socioNombre = GetNombreSocio(plantel.Nrocri);
        return string.IsNullOrWhiteSpace(socioNombre)
            ? FormatoPlantel(plantel)
            : $"{FormatoPlantel(plantel)} · {socioNombre}";
    }

    private void OnTipoHembraChanged(object? value)
    {
        oTransan.Tipohem = value?.ToString();
        RecalcularEstadosHembras();
    }

    private void OnTipoHaciendaChanged(object? value)
    {
        RecalcularEstadosHembras();
    }

    private bool TieneImpactoPosible()
    {
        return PuedeVerPlantel(plantelOrigen) && PuedeVerPlantel(plantelDestino);
    }

    private void RecalcularEstadosHembras(object? _ = null)
    {
        estadoHembrasDisponibles = oTransan.Tipohem?.Trim().ToUpperInvariant() switch
        {
            "VA" => new List<string> { "Con Cria (CC)", "Con Cria y Preñada (CCP)" },
            "VQ" => new List<string> { "Preñada (PR)", "Sin Servicio (SS)" },
            _ => new List<string> { "Con Cria (CC)", "Con Cria y Preñada (CCP)", "Sin Servicio (SS)", "Preñada (PR)" }
        };

        if (!string.IsNullOrWhiteSpace(temp3) &&
            !estadoHembrasDisponibles.Any(x => string.Equals(x, temp3, StringComparison.OrdinalIgnoreCase)))
        {
            temp3 = string.Empty;
            oTransan.Hemsta = null;
        }
    }

    private TransferenciaPreviewInfo GetPreviewImpacto()
    {
        // El preview usa la misma regla compartida del backend para mostrar el cambio real antes de guardar.
        var transanPreview = BuildTransanParaImpacto();
        if (!TransferenciaAnimalImpactoHelper.TryBuildImpacto(transanPreview, plantelOrigen, plantelDestino, out var impacto, out var error))
        {
            return new TransferenciaPreviewInfo
            {
                Error = error
            };
        }

        return new TransferenciaPreviewInfo
        {
            Impacto = impacto
        };
    }

    private TransanDTO BuildTransanParaImpacto()
    {
        var transan = new TransanDTO
        {
            Tiphac = traductor.TryGetValue(temp1, out var tiphac) ? tiphac : null,
            Tipani = traductor.TryGetValue(temp2, out var tipani) ? tipani : null,
            Hemsta = string.IsNullOrWhiteSpace(temp3) ? null : traductor.TryGetValue(temp3, out var hemsta) ? hemsta : null,
            Tipohem = string.IsNullOrWhiteSpace(oTransan.Tipohem) ? null : oTransan.Tipohem,
            CantHem = oTransan.CantHem,
            CantMach = oTransan.CantMach,
            CantChem = oTransan.CantChem,
            CantCmach = oTransan.CantCmach
        };

        return transan;
    }

    private static string FormatearCantidad(double? value)
        => (value ?? 0).ToString("0");

    private string GetNombreSocio(string? nrocri)
    {
        if (string.IsNullOrWhiteSpace(nrocri))
        {
            return string.Empty;
        }

        var socio = socios.FirstOrDefault(x => string.Equals(x.Scod, nrocri, StringComparison.OrdinalIgnoreCase));
        return socio?.Nombre ?? nrocri;
    }

    private sealed class TransferenciaPreviewInfo
    {
        public TransferenciaAnimalImpacto? Impacto { get; set; }
        public string? Error { get; set; }
    }

    private async Task MostrarErrorGuardado(string? mensaje)
    {
        await Swal.FireAsync(new SweetAlertOptions
            {
                Title = "La transferencia no pudo completarse",
                Html = string.IsNullOrWhiteSpace(mensaje)
                    ? "Ocurrió un error al guardar la transferencia. No se aplicó ningún cambio."
                    : mensaje,
                Icon = SweetAlertIcon.Error
            });
    }

    protected async Task updateComprador(SocioDTO? socio)
    {
        socioComprador = socio;
        direccionCompra = socio?.Mail ?? string.Empty;
        plantelDestino = null;
        plantelesComprador = new List<PlantelDTO>();
        plantelesCompradorSocioCode = null;
        await EnsurePlantelesCompradorLoadedAsync();

        StateHasChanged();
    }

    private async Task OnVendedorChanged(SocioDTO? socio)
    {
        socioVendedor = socio;
        plantelOrigen = null;
        plantelesVendedor = new List<PlantelDTO>();
        plantelesVendedorSocioCode = null;
        await EnsurePlantelesVendedorLoadedAsync();
        StateHasChanged();
    }

    private Task OnPlantelOrigenChanged(PlantelDTO? plantel)
    {
        plantelOrigen = plantel;
        return Task.CompletedTask;
    }

    private Task OnPlantelDestinoChanged(PlantelDTO? plantel)
    {
        plantelDestino = plantel;
        return Task.CompletedTask;
    }

    private async Task<IEnumerable<SocioDTO>> BusquedaSocios(string searchText)
    {

        var result = socios.Where(x =>
            // x.Criador=="S" &&
            !string.IsNullOrWhiteSpace(x.Nombre) &&
            x.Nombre.Contains(searchText, StringComparison.OrdinalIgnoreCase)).ToList();
        return await Task.FromResult(result);

    }

    private async Task<IEnumerable<PlantelDTO>> BusquedaPlantelesComprador(string searchText)
    {
        try
        {
            await EnsurePlantelesCompradorLoadedAsync();

            if (socioComprador != null && !string.IsNullOrWhiteSpace(socioComprador.Scod))
            {
                return await Task.FromResult(
                    OrderPlantelesByYear(plantelesComprador)
                        .Where(x => x.Placod.Contains(searchText ?? string.Empty, StringComparison.OrdinalIgnoreCase)).ToList()
                );
            }
        }
        catch
        {
            // Si falla la consulta de lookup, devolvemos vacío para no dejar el control en estado de carga.
        }

        return await Task.FromResult<IEnumerable<PlantelDTO>>(Array.Empty<PlantelDTO>());
    }

    private async Task<IEnumerable<PlantelDTO>> BusquedaPlantelesVendedor(string searchText)
    {
        try
        {
            await EnsurePlantelesVendedorLoadedAsync();

            return await Task.FromResult(
                OrderPlantelesByYear(plantelesVendedor)
                    .Where(x => x.Placod.Contains(searchText ?? string.Empty, StringComparison.OrdinalIgnoreCase)).ToList());
        }
        catch
        {
            // Si falla la consulta de lookup, devolvemos vacío para no dejar el control en estado de carga.
        }

        return await Task.FromResult<IEnumerable<PlantelDTO>>(Array.Empty<PlantelDTO>());
    }

    private static List<PlantelDTO> OrderPlantelesByYear(IEnumerable<PlantelDTO>? items)
        => (items ?? Enumerable.Empty<PlantelDTO>())
            .OrderByDescending(x => TryGetPlantelYear(x).HasValue)
            .ThenByDescending(x => TryGetPlantelYear(x))
            .ThenByDescending(x => x.Id)
            .ToList();

    private static int? TryGetPlantelYear(PlantelDTO? plantel)
    {
        if (plantel == null || string.IsNullOrWhiteSpace(plantel.Anioex))
        {
            return null;
        }

        return int.TryParse(plantel.Anioex, out var year) ? year : null;
    }

    private static string FormatoPlantel(PlantelDTO? plantel)
    {
        if (plantel is null)
        {
            return string.Empty;
        }

        var placod = plantel.Placod?.Trim() ?? string.Empty;
        var anio = plantel.Anioex?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(anio))
        {
            return placod;
        }

        if (string.IsNullOrWhiteSpace(placod))
        {
            return anio;
        }

        return $"{placod} - {anio}";
    }

    private async Task EnsurePlantelesVendedorLoadedAsync()
    {
        if (string.IsNullOrWhiteSpace(socioVendedor?.Scod))
        {
            plantelesVendedor = new List<PlantelDTO>();
            plantelesVendedorSocioCode = null;
            return;
        }

        if (string.Equals(plantelesVendedorSocioCode, socioVendedor.Scod, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        plantelesVendedor = await GetPlantelesBySocioCodeAsync(socioVendedor.Scod);
        plantelesVendedorSocioCode = socioVendedor.Scod;
    }

    private async Task EnsurePlantelesCompradorLoadedAsync()
    {
        if (string.IsNullOrWhiteSpace(socioComprador?.Scod))
        {
            plantelesComprador = new List<PlantelDTO>();
            plantelesCompradorSocioCode = null;
            return;
        }

        if (string.Equals(plantelesCompradorSocioCode, socioComprador.Scod, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        plantelesComprador = await GetPlantelesBySocioCodeAsync(socioComprador.Scod);
        plantelesCompradorSocioCode = socioComprador.Scod;
    }

    private async Task<List<PlantelDTO>> GetPlantelesBySocioCodeAsync(string? socioCode)
    {
        if (string.IsNullOrWhiteSpace(socioCode))
        {
            return new List<PlantelDTO>();
        }

        try
        {
            var response = await http.GetFromJsonAsync<Respuesta<List<PlantelDTO>>>(
                $"api/TransferenciasLookup/PlantelesBySocioCode?socioCode={Uri.EscapeDataString(socioCode)}");

            return response?.List ?? new List<PlantelDTO>();
        }
        catch
        {
            // Si el lookup falla, devolvemos una lista vacía para que el componente pueda recuperarse.
            return new List<PlantelDTO>();
        }
    }

    private async Task<List<SocioDTO>> GetSociosLookupAsync()
    {
        var response = await http.GetFromJsonAsync<Respuesta<List<SocioDTO>>>("api/TransferenciasLookup/Socios");
        return response?.List ?? new List<SocioDTO>();
    }

