@using Blazored.Typeahead
@using PaginaToros.Client.Servicios.Contrato;
@inject ISocioServicio _sociosServicio
@inject ITransanServicio _transanServicio
@inject HttpClient http

@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@using System.Security.Claims



<style>
    .bm-title {
        font-size: 25px;
        font-weight: bold;
    }

    .plantel-typeahead {
        width: 100%;
        max-width: 26.7rem;
    }

    .plantel-typeahead .blazored-typeahead__controls,
    .plantel-typeahead .blazored-typeahead__input-mask-wrapper {
        display: flex;
        align-items: stretch;
        width: 100%;
        min-width: 0;
    }

    .plantel-typeahead .blazored-typeahead__input-mask,
    .plantel-typeahead .blazored-typeahead__input {
        flex: 1 1 auto;
        min-width: 0;
        width: 100%;
    }

    .plantel-typeahead .blazored-typeahead__input-icon {
        flex: 0 0 40px;
        width: 40px;
        margin-left: auto;
        justify-content: center;
    }

    .plantel-info-btn {
        min-width: 1.6rem;
        height: 1.6rem;
        border-radius: 999px;
        padding: 0;
        font-weight: 600;
        line-height: 1;
        border: 1px solid #6f7680;
        background-color: #747c85;
        color: #fff;
        box-shadow: none;
        font-size: 0.72rem;
    }

    .plantel-info-btn:hover,
    .plantel-info-btn:focus {
        background-color: #666d76;
        border-color: #606771;
        color: #fff;
        box-shadow: none;
    }

    .plantel-info-btn:disabled {
        background-color: #8e959c;
        border-color: #818991;
        color: #fff;
        opacity: 1;
        cursor: not-allowed;
    }

    .plantel-panel {
        padding: 0.7rem 0.85rem;
    }

    .plantel-panel-title {
        font-size: 0.95rem;
        font-weight: 500;
    }

    .plantel-panel-section-title {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 0.35rem;
    }

    .plantel-panel-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem 1rem;
    }

    .plantel-panel-item {
        min-width: 7.5rem;
    }

    .plantel-panel-label {
        font-size: 0.72rem;
        line-height: 1.1;
        color: #6c757d;
        margin-bottom: 0.05rem;
    }

    .plantel-panel-value {
        font-size: 0.95rem;
        line-height: 1.1;
        font-weight: 600;
    }
</style>
@if (socios.Count > 0) {
<div class="card">
    <div class="card-body">
        <EditForm Model="@oTransan" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />
                <div class="row" style="width=100%;">
                    <div class="col-sm">
                        <label class="col-sm">Nro Certificado</label>
                        <InputText @bind-Value="@oTransan.NroCert" class="form-control" placeholder="" />
                    </div>
                    <div class="col-sm">
                        <label>Fecha de venta</label><br />
                        <RadzenDatePicker TValue="DateTime?" @bind-Value="@oTransan.Fecvta"
                                          ShowTime="false" ShowSeconds="false"
                                          DateFormat="dd/MM/yyyy" Class="w-75" />
                    </div>
                </div>
            <br />
            <div class="row" style="width=100%;">
                <div class="col-sm">
                    <label>Socio Vendedor</label><br />
                    <BlazoredTypeahead SearchMethod="BusquedaSocios" placeholder="Buscar por nombre" Disabled="IdSocio!=null" EnableDropDown="true" TItem="SocioDTO" TValue="SocioDTO" Value="socioVendedor" ValueChanged="OnVendedorChanged" ValueExpression="@(() => socioVendedor)">
                        <SelectedTemplate Context="eleccion">
                            @eleccion.Nombre
                        </SelectedTemplate>
                        <ResultTemplate Context="eleccion">
                            @eleccion.Nombre
                        </ResultTemplate>
                    </BlazoredTypeahead>
                </div>
                <div class="col-sm">
                    <label>Socio Comprador (Opcional)</label>
                    <BlazoredTypeahead SearchMethod="BusquedaSocios" placeholder="Busque socio por nombre" EnableDropDown="true" TItem="SocioDTO" TValue="SocioDTO" Value="socioComprador" ValueChanged="updateComprador" ValueExpression="@(() => socioComprador)">
                        <SelectedTemplate Context="eleccion">
                            @eleccion.Nombre
                        </SelectedTemplate>
                        <ResultTemplate Context="eleccion">
                            @eleccion.Nombre
                        </ResultTemplate>
                    </BlazoredTypeahead>
                </div>
            </div>
            <div class="row" style="width=100%;">
                <div class="col-sm">
                    <label class="col-sm">Hembras</label>
                    <InputNumber @bind-Value="@oTransan.CantHem" class="form-control" placeholder=""></InputNumber>
                    <ValidationMessage For="(()=> oTransan.CantHem)" style="color:red;" />
                </div>
                <div class="col-sm">
                    <label class="col-sm">Machos</label>
                    <InputNumber @bind-Value="@oTransan.CantMach" class="form-control" placeholder=""></InputNumber>
                    <ValidationMessage For="(()=> oTransan.CantMach)" style="color:red;" />
                </div>
                <div class="col-sm">
                    <label class="col-sm">Crias Hembras</label>
                    <InputNumber @bind-Value="@oTransan.CantChem" class="form-control" placeholder=""></InputNumber>
                    <ValidationMessage For="(()=> oTransan.CantChem)" style="color:red;" />
                </div>
                <div class="col-sm">
                    <label class="col-sm">Crias Machos</label>
                    <InputNumber @bind-Value="@oTransan.CantCmach" class="form-control" placeholder=""></InputNumber>
                    <ValidationMessage For="(()=> oTransan.CantCmach)" style="color:red;" />
                </div>
            </div>
            <div class="row" style="width=100%;">
                <div class="col-sm">
                    <label>Plantel Origen</label>
                    <div class="d-flex align-items-end">
                        <BlazoredTypeahead class="plantel-typeahead flex-grow-1" SearchMethod="BusquedaPlantelesVendedor" placeholder="Busque plantel por numero" EnableDropDown="true" TItem="PlantelDTO" TValue="PlantelDTO" Value="plantelOrigen" ValueChanged="OnPlantelOrigenChanged" ValueExpression="@(() => plantelOrigen)">
                            <SelectedTemplate Context="eleccion">
                                @FormatoPlantel(eleccion)
                            </SelectedTemplate>
                            <ResultTemplate Context="eleccion">
                                @FormatoPlantel(eleccion)
                            </ResultTemplate>
                        </BlazoredTypeahead>
                        <button type="button"
                                class="plantel-info-btn ml-2"
                                title="@(PuedeVerPlantel(plantelOrigen) ? "Ver stock actual" : "Seleccione un plantel")"
                                disabled="@(!PuedeVerPlantel(plantelOrigen))"
                                @onclick="() => TogglePlantelPanel(plantelOrigen)">
                            @(PuedeVerPlantel(plantelOrigen) ? "i" : "!")
                        </button>
                    </div>
                </div>
                <div class="col-sm">
                    <label>Plantel Destino</label>
                    <div class="d-flex align-items-end">
                        <BlazoredTypeahead class="plantel-typeahead flex-grow-1" SearchMethod="BusquedaPlantelesComprador" placeholder="Busque plantel por numero" EnableDropDown="true" TItem="PlantelDTO" TValue="PlantelDTO" Value="plantelDestino" ValueChanged="OnPlantelDestinoChanged" ValueExpression="@(() => plantelDestino)">
                            <SelectedTemplate Context="eleccion">
                                @FormatoPlantel(eleccion)
                            </SelectedTemplate>
                            <ResultTemplate Context="eleccion">
                                @FormatoPlantel(eleccion)
                            </ResultTemplate>
                        </BlazoredTypeahead>
                        <button type="button"
                                class="plantel-info-btn ml-2"
                                title="@(PuedeVerPlantel(plantelDestino) ? "Ver stock actual" : "Seleccione un plantel")"
                                disabled="@(!PuedeVerPlantel(plantelDestino))"
                                @onclick="() => TogglePlantelPanel(plantelDestino)">
                            @(PuedeVerPlantel(plantelDestino) ? "i" : "!")
                        </button>
                    </div>
                </div>
            </div>

            @if (plantelPanelAbierto && PuedeVerPlantel(plantelPanelSeleccionado))
            {
                <div class="border rounded plantel-panel mt-3 bg-light">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="plantel-panel-title">@GetPlantelPanelTitle(plantelPanelSeleccionado)</div>
                        <button type="button" class="btn btn-link btn-sm p-0" @onclick="CerrarPlantelPanel">Cerrar</button>
                    </div>
                    <div class="mt-3">
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <div class="plantel-panel-section-title">Puro Registrado</div>
                                <div class="plantel-panel-row">
                                    <div class="plantel-panel-item">
                                        <div class="plantel-panel-label">Vacas</div>
                                        <div class="plantel-panel-value">@FormatearCantidad(plantelPanelSeleccionado.Varede)</div>
                                    </div>
                                    <div class="plantel-panel-item">
                                        <div class="plantel-panel-label" title="Vaquillonas con servicio PR">Vaq. PR C/S</div>
                                        <div class="plantel-panel-value">@FormatearCantidad(plantelPanelSeleccionado.Vqcsrd)</div>
                                    </div>
                                    <div class="plantel-panel-item">
                                        <div class="plantel-panel-label" title="Vaquillonas sin servicio PR">Vaq. PR S/S</div>
                                        <div class="plantel-panel-value">@FormatearCantidad(plantelPanelSeleccionado.Vqssrd)</div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6 mb-2">
                                <div class="plantel-panel-section-title">VIP</div>
                                <div class="plantel-panel-row">
                                    <div class="plantel-panel-item">
                                        <div class="plantel-panel-label">Vacas</div>
                                        <div class="plantel-panel-value">@FormatearCantidad(plantelPanelSeleccionado.Varepr)</div>
                                    </div>
                                    <div class="plantel-panel-item">
                                        <div class="plantel-panel-label" title="Vaquillonas con servicio o preñadas VIP">Vaq. VIP C/S o preñadas</div>
                                        <div class="plantel-panel-value">@FormatearCantidad(plantelPanelSeleccionado.Vqcsrp)</div>
                                    </div>
                                    <div class="plantel-panel-item">
                                        <div class="plantel-panel-label" title="Vaquillonas sin servicio VIP">Vaq. VIP S/S</div>
                                        <div class="plantel-panel-value">@FormatearCantidad(plantelPanelSeleccionado.Vqssrp)</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            <br />
            <div class="row" style="width=100%;">
                <div class="col-sm">
                    <label class="col-sm">Tipo de Hembras</label>
                    <RadzenDropDown @bind-Value=@oTransan.Tipohem Data=@tiposHembra Change="@OnTipoHembraChanged" Style="width: 100%; max-width: 400px;" />
                    <ValidationMessage For="(()=> oTransan.Tipohem)" style="color:red;" />
                </div>
                <div class="col-sm">
                    <label class="col-sm">Tipo de Hacienda</label>
                    <RadzenDropDown @bind-Value=@temp1 Data=@tiposHacienda Change="@OnTipoHaciendaChanged" Style="width: 100%; max-width: 400px;" />
                    <ValidationMessage For="(()=> temp1)" style="color:red;" />
                </div>
                <div class="col-sm">
                    <label class="col-sm">Sexo de los Animales</label>
                    <RadzenDropDown @bind-Value=@temp2 Data=@sexoAnimales Style="width: 100%; max-width: 400px;" />
                    <ValidationMessage For="(()=> temp2)" style="color:red;" />
                </div>
            </div>
            <br />
            <div class="row" style="width=100%;">
                <div class="col-sm">
                    <label class="col-sm">Estado de las Hembras</label>
                    <RadzenDropDown @bind-Value=@temp3 Data=@estadoHembrasDisponibles Style="width: 100%; max-width: 400px;" />
                    <ValidationMessage For="(()=> temp3)" style="color:red;" />
                </div>
            </div>
            @if (TieneImpactoPosible())
            {
                var preview = GetPreviewImpacto();
                if (string.IsNullOrWhiteSpace(preview.Error))
                {
                    <div class="alert alert-info mt-3 py-2 px-3">
                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                            <div class="font-weight-bold mr-3">Transferencia de @preview.Impacto!.BucketLabel</div>
                            <div>
                                <span class="text-muted">Plantel Origen:</span>
                                <span class="font-weight-bold">@preview.Impacto.OrigenAntes</span>
                                <span class="text-muted mx-1">→</span>
                                <span class="font-weight-bold">@preview.Impacto.OrigenDespues</span>
                            </div>
                            <div>
                                <span class="text-muted">Plantel Destino:</span>
                                <span class="font-weight-bold">@preview.Impacto.DestinoAntes</span>
                                <span class="text-muted mx-1">→</span>
                                <span class="font-weight-bold">@preview.Impacto.DestinoDespues</span>
                            </div>
                        </div>
                    </div>
                }
            }
            <br />
            <div class="row" style="width=100%;">
                <div class="col-sm">
                    <label class="col-sm">Mail del comprador</label>
                    <InputText @bind-Value="@direccionCompra" class="form-control" placeholder=""></InputText>
                    <ValidationMessage For="(()=> direccionCompra)" style="color:red;" />
                    <p>*Una vez seleccionado el socio se llenara este campo</p>
                </div>
            </div>
            <br />

            <button type="submit" class="btn btn-primary mr-2">Aceptar</button>
            <button type="button" @onclick="cancel" class="btn btn-light">Cancelar</button>
        </EditForm>
    </div>
</div>
}
else
{
    <br />
    <center>
        <div class="mb-2">
            <br />
            <RadzenProgressBar style="position:relative;width:93.5%" Value="100" ShowValue="false" ProgressBarStyle="ProgressBarStyle.Primary" Mode="ProgressBarMode.Indeterminate" />
        </div>
    </center>
}
@code {
    TransanDTO oTransan = new();
    SocioDTO socioComprador = new();
    SocioDTO socioVendedor = new();
    List<SocioDTO> socios = new();
    List<PlantelDTO> plantelesVendedor = new();
    List<PlantelDTO> plantelesComprador = new();
    List<string> tiposHembra = new List<string> { "VQ", "VA" };
    List<string> tiposHacienda = new List<string> { "PHPR (Puro Registrado)", "HPR (Puro Registrado)", "PHVIP (VIP)", "HVIP (VIP)" };
    List<string> sexoAnimales = new List<string> { "Hembras", "Machos" };
    List<string> estadoHembrasDisponibles = new List<string>();
    string temp1 = "";
    string temp2 = "";
    string temp3 = "";
    PlantelDTO? plantelOrigen = null;
    PlantelDTO? plantelDestino = null;
    PlantelDTO? plantelPanelSeleccionado = null;
    bool plantelPanelAbierto = false;


    private ClaimsPrincipal? user;
    private bool esSocioUsuario;




    Dictionary<string, string> traductor = new Dictionary<string, string>{
        {"PHPR (Puro Registrado)","PHPR"},
        {"HPR (Puro Registrado)","HPR"},
        {"PHVIP (VIP)","PHVIP"},
        {"HVIP (VIP)","HVIP"},
        {"Machos","M"},
        {"Hembras","H"},
        {"Con Cria (CC)","CC"},
        {"Con Cria y Preñada (CCP)","CCP"},
        {"Sin Servicio (SS)","SS"},
        {"Preñada (PR)","PR"}
    };
    Dictionary<string, string> traductorCarga = new Dictionary<string, string>{
        {"PHPR","PHPR (Puro Registrado)"},
        {"HPR","HPR (Puro Registrado)"},
        {"PHVIP","PHVIP (VIP)"},
        {"HVIP","HVIP (VIP)"},
        {"M","Machos"},
        {"H","Hembras"},
        {"CC","Con Cria (CC)"},
        {"CCP","Con Cria y Preñada (CCP)"},
        {"SS","Sin Servicio (SS)"},
        {"PR","Preñada (PR)"}
    };

    [CascadingParameter] BlazoredModalInstance ModalInstance { get; set; }
    [Parameter] public int Id { get; set; }
    [Parameter] public int? IdSocio { get; set; }
    string direccionCompra = "";
    string? plantelesVendedorSocioCode;
    string? plantelesCompradorSocioCode;



    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        user = authState.User;
        esSocioUsuario = user?.IsInRole("Socio") == true || user?.IsInRole("SOCIO") == true;

        if (esSocioUsuario)
        {
            socios = await GetSociosLookupAsync();
        }
        else
        {
            var rta = await _sociosServicio.LimitadosFiltrados(0, 0);
            socios = rta.List ?? new();
        }
        if (IdSocio != null && IdSocio != 0)
        {
            socioVendedor = socios.FirstOrDefault(x => x.Id == IdSocio);
            await EnsurePlantelesVendedorLoadedAsync();
        }

        if (Id != 0)
        {
            try
            {
                string filtro = $"Id = {Id}";
                var r = await _transanServicio.LimitadosFiltrados(0, 1, filtro);
                oTransan = r.List.FirstOrDefault();
                socioComprador = socios.FirstOrDefault(x => x.Scod == oTransan.Scom) ?? new SocioDTO();
                socioVendedor = socios.FirstOrDefault(x => x.Scod == oTransan.Sven) ?? new SocioDTO();

                await EnsurePlantelesVendedorLoadedAsync();
                await EnsurePlantelesCompradorLoadedAsync();

                plantelOrigen = plantelesVendedor.FirstOrDefault(x => x.Id == oTransan.PlantOrigenId)
                    ?? plantelesVendedor.FirstOrDefault(x => x.Placod == oTransan.Plant)
                    ?? new PlantelDTO();
                plantelDestino = plantelesComprador.FirstOrDefault(x => x.Id == oTransan.PlantDestinoId)
                    ?? plantelesComprador.FirstOrDefault(x => x.Placod == oTransan.NvoPla)
                    ?? new PlantelDTO();
                temp1 = traductorCarga[oTransan.Tiphac];
                temp2 = traductorCarga[oTransan.Tipani];
                temp3 = traductorCarga[oTransan.Hemsta];
                RecalcularEstadosHembras();
            }
            catch (Exception ex)
            {
            }
        }

        RecalcularEstadosHembras();
    }
    async Task Guardar()
    {
        var errores = new List<string>();

        if (oTransan.Fecvta == null) errores.Add("La fecha de venta es obligatoria.");

        var hayVendedor = socioVendedor != null && socioVendedor.Id != 0 && !string.IsNullOrWhiteSpace(socioVendedor.Scod);
        if (!hayVendedor) errores.Add("Debés seleccionar un Socio Vendedor.");

        var hayComprador = socioComprador != null && socioComprador.Id != 0 && !string.IsNullOrWhiteSpace(socioComprador.Scod);

        var hayPlantelOrigen = plantelOrigen != null && !string.IsNullOrWhiteSpace(plantelOrigen.Placod);
        if (!hayPlantelOrigen) errores.Add("Debés seleccionar el Plantel Origen.");

        var hayPlantelDestino = plantelDestino != null && !string.IsNullOrWhiteSpace(plantelDestino.Placod);
        if (!hayPlantelDestino) errores.Add("Debés seleccionar el Plantel Destino.");
        if (hayPlantelOrigen && hayPlantelDestino && plantelOrigen.Placod == plantelDestino.Placod)
            errores.Add("El plantel de origen y el plantel de destino no pueden ser el mismo.");

        if (string.IsNullOrWhiteSpace(temp1)) errores.Add("Debés seleccionar el Tipo de Hacienda.");
        if (string.IsNullOrWhiteSpace(temp2)) errores.Add("Debés seleccionar el Sexo de los Animales.");
        if (string.IsNullOrWhiteSpace(temp3)) errores.Add("Debés seleccionar el Estado de las Hembras.");

        int cantHem = oTransan.CantHem ?? 0;
        int cantMach = oTransan.CantMach ?? 0;
        int cantChem = oTransan.CantChem ?? 0;
        int cantCmach = oTransan.CantCmach ?? 0;
        int totalHembras = cantHem + cantChem;
        int totalMachos = cantMach + cantCmach;

        if (cantHem < 0 || cantMach < 0 || cantChem < 0 || cantCmach < 0)
            errores.Add("Las cantidades no pueden ser negativas.");

        if ((cantHem + cantMach + cantChem + cantCmach) == 0)
            errores.Add("Debés ingresar al menos 1 animal en total.");

        if (totalHembras > 0)
        {
            if (string.IsNullOrWhiteSpace(temp3)) errores.Add("Debés seleccionar el Estado de las Hembras.");
            if (string.IsNullOrWhiteSpace(oTransan.Tipohem)) errores.Add("Debés seleccionar el Tipo de Hembras.");
        }

        if (hayComprador && string.IsNullOrWhiteSpace(direccionCompra) && string.IsNullOrWhiteSpace(socioComprador?.Mail))
            errores.Add("El socio comprador no tiene un mail cargado. Completá el campo 'Mail del comprador' para poder enviar la notificación.");

        if (errores.Count > 0)
        {
            await Swal.FireAsync(new SweetAlertOptions
                {
                    Title = "No se puede guardar la transferencia",
                    Html = $"<ul style='text-align:left;margin-left:12px'>{string.Join("", errores.Select(e => $"<li>{e}</li>"))}</ul>",
                    Icon = SweetAlertIcon.Warning
                });
            return;
        }

        oTransan.Tiphac = traductor[temp1];            // PHPR/HPR/PHVIP/HVIP
        oTransan.Tipani = traductor[temp2];            // H/M
        oTransan.Hemsta = totalHembras > 0 ? traductor[temp3] : null;
        oTransan.Tipohem = totalHembras > 0 ? oTransan.Tipohem : null;
        oTransan.Incorp = 1;

        // El stock de plantel sólo cambia con hembras adultas.
        // El helper compartido decide qué columna mover y evita que front y backend diverjan.
        if (!TransferenciaAnimalImpactoHelper.TryBuildImpacto(oTransan, plantelOrigen, plantelDestino, out var impactoPreview, out var impactoError))
        {
            await Swal.FireAsync(new SweetAlertOptions
            {
                Title = "No se puede guardar la transferencia",
                Html = impactoError ?? "No se pudo determinar el impacto de la transferencia.",
                Icon = SweetAlertIcon.Warning
            });
            return;
        }

        if (impactoPreview != null && cantHem > 0 && impactoPreview.OrigenAntes < cantHem)
        {
            await Swal.FireAsync(new SweetAlertOptions
            {
                Title = "Cantidad inválida",
                Html = $"El plantel origen no dispone de {cantHem} hembras en la categoría seleccionada. Disponible: {impactoPreview.OrigenAntes:0}.",
                Icon = SweetAlertIcon.Warning
            });
            return;
        }

        oTransan.Vnom = socioVendedor.Nombre;
        oTransan.Sven = socioVendedor.Scod?.ToString();

        oTransan.Cnom = hayComprador ? socioComprador.Nombre : null;
        oTransan.Scom = hayComprador ? socioComprador.Scod?.ToString() : null;

        oTransan.Plant = plantelOrigen.Placod;
        oTransan.NvoPla = plantelDestino.Placod;
        oTransan.PlantOrigenId = plantelOrigen.Id;
        oTransan.PlantDestinoId = plantelDestino.Id;

        var request = new TransanSaveRequestDTO
        {
            Transan = oTransan,
            VendedorId = socioVendedor.Id,
            CompradorId = hayComprador ? socioComprador.Id : null,
            MailComprador = hayComprador ? direccionCompra : null,
            PlantOrigenId = plantelOrigen.Id,
            PlantDestinoId = plantelDestino.Id
        };

        if (Id == 0)
        {
            var response = await _transanServicio.Crear(request);
            if (response == null || response.Exito != 1)
            {
                await MostrarErrorGuardado(response?.Mensaje);
                return;
            }

            await ModalInstance.CloseAsync(ModalResult.Ok("Creado"));
        }
        else
        {
            var response = await _transanServicio.Editar(request);
            if (response == null || response.Exito != 1)
            {
                await MostrarErrorGuardado(response?.Mensaje);
                return;
            }

            await ModalInstance.CloseAsync(ModalResult.Ok("Editado"));
        }
    }


    public class ChangeNotificationModel
    {
