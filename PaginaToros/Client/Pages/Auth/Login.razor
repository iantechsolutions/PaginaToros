@page "/Login"
﻿
@inject HttpClient http
@inject NavigationManager uriHelper
@inject PaginaToros.Client.Auth.ILoginServices loginService
@inject IModalService ModalService

<div class="login-screen">
    <div class="login-overlay"></div>

    <div class="login-panel">
        <img class="login-logo" src="images/LOGO PRINCIPAL.png" alt="Hereford Argentina" />

        <form class="login-form">
            <div class="login-field">
                <label for="username">Usuario</label>
                <input id="username" type="text" @bind-value="@userInfo.UserName" placeholder="Ingrese su usuario" />
            </div>

            <div class="login-field">
                <label for="password">Contraseña</label>
                <input id="password" type="password" @bind-value="@userInfo.Password" placeholder="Ingrese su contraseña" />
            </div>

            <button class="login-button" type="button" @onclick="Loger">Acceder</button>

            <p class="login-message">¿No está registrado? <a href="#">Cree su cuenta</a></p>
        </form>
    </div>
</div>


@code {
    [CascadingParameter] public IModalService Modal { get; set; }

    private UserLogin userInfo = new UserLogin();
    private async Task Loger()
    {
        var validationMessage = GetValidationMessage();
        if (validationMessage is not null)
        {
            Modal.Show<ModalInfo>("Error", SharedModalOptions.SetParameterModalInfo(validationMessage, "alert alert-danger"), SharedModalOptions.modalOptionsInfo);
            return;
        }

        var options = new ModalOptions()
            {
                Position = ModalPosition.Middle,
                HideCloseButton=true,
            };
        var modal = Modal.Show<ModalWait>("", options);
        try
        {
            var result = await http.PostAsJsonAsync($"{http.BaseAddress}api/Account/Login", userInfo);
            if (result.IsSuccessStatusCode)
            {
                var token = await result.Content.ReadAsStringAsync();
                await loginService.Login(token);
                uriHelper.NavigateTo("");
                return;
            }

            var serverMessage = await result.Content.ReadAsStringAsync();
            modal.Close();
            Modal.Show<ModalInfo>("Error", SharedModalOptions.SetParameterModalInfo(GetFriendlyLoginError(serverMessage), "alert alert-danger"), SharedModalOptions.modalOptionsInfo);
        }
        catch
        {
            modal.Close();
            Modal.Show<ModalInfo>("Error", SharedModalOptions.SetParameterModalInfo("No se pudo iniciar sesión en este momento. Intente nuevamente en unos minutos.", "alert alert-danger"), SharedModalOptions.modalOptionsInfo);
        }
    }

    private static string GetFriendlyLoginError(string? serverMessage)
    {
        if (string.IsNullOrWhiteSpace(serverMessage))
        {
            return "No se pudo iniciar sesión. Verifique sus datos e intente nuevamente.";
        }

        var normalizedMessage = serverMessage.Trim().Trim('"');

        if (normalizedMessage.Contains("credenciales", StringComparison.OrdinalIgnoreCase))
        {
            return "Las credenciales no son correctas. Revise el correo de detalles de inicio de sesión.";
        }

        if (normalizedMessage.Contains("suspendido", StringComparison.OrdinalIgnoreCase))
        {
            return "Su usuario está suspendido. Comuníquese con un administrador.";
        }

        return "No se pudo iniciar sesión en este momento. Intente nuevamente en unos minutos.";
    }

    private string? GetValidationMessage()
    {
        var isUserNameEmpty = string.IsNullOrWhiteSpace(userInfo.UserName);
        var isPasswordEmpty = string.IsNullOrWhiteSpace(userInfo.Password);

        if (isUserNameEmpty && isPasswordEmpty)
        {
            return "Ingrese sus credenciales.";
        }

        if (isUserNameEmpty)
        {
            return "Ingrese su mail.";
        }

        if (isPasswordEmpty)
        {
            return "Ingrese su contraseña.";
        }

        return null;
    }

}
