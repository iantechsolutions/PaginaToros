@page "/Usuarios"
@using PaginaToros.Client.Servicios.Contrato
@using PaginaToros.Client.Shared.Filters
@using PaginaToros.Shared.Models
@inject HttpClient http
@inject NavigationManager uriHelper
@inject ISocioServicio _socioServicio
@using Radzen
@using Radzen.Blazor
@using System.Text.Json
@using System.Linq

<style>
    .users-page {
        width: 100%;
        margin: 0 auto 2rem;
        color: #172033;
    }

    .users-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin: 1rem 0;
        width: 93.5%;
        margin-left: 3.33%;
    }

    .users-title {
        margin: 0;
        font-size: 1.55rem;
        font-weight: 700;
    }

    .users-description {
        margin: .25rem 0 0;
        color: #64748b;
    }

    .users-card {
        width: 93.5%;
        margin-left: 3.33%;
        border: 1px solid #dbe3cf;
        border-radius: 8px;
        background: #fffdf8;
        box-shadow: 0 8px 18px rgba(76, 59, 32, .06);
    }

    .users-filter-card {
        padding: .75rem;
        margin-bottom: .85rem;
    }

    .users-toolbar {
        display: flex;
        gap: .75rem;
        align-items: center;
        justify-content: space-between;
        flex-wrap: nowrap;
    }

    .users-toolbar-search {
        flex: 1 1 auto;
        min-width: 0;
    }

    .users-status-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-top: .55rem;
        flex-wrap: wrap;
    }

    .users-loading-message {
        color: #2563eb;
        font-size: .92rem;
        font-weight: 600;
    }

    .tablacontent {
        position: relative;
        overflow: hidden;
        border-radius: 8px;
    }

    .tablacontent .rz-datatable-tablewrapper,
    .tablacontent.rz-data-grid .rz-datatable-tablewrapper {
        border-radius: 8px 8px 0 0 !important;
    }

    .tablacontent .rz-cell-data,
    .tablacontent .rz-column-title-content {
        font-size: 11.2px !important;
    }

    .tablacontent .rz-cell-data {
        overflow: hidden !important;
        text-overflow: ellipsis;
        white-space: nowrap !important;
    }

    .tablacontent th.rz-unselectable-text.rz-text-align-left {
        background-color: #f1f5f9;
        color: #334155;
        position: sticky;
        top: 0;
        z-index: 2;
    }

    .tablacontent .rz-grid-table td,
    .tablacontent .rz-grid-table th {
        padding-left: .42rem !important;
        padding-right: .42rem !important;
    }

    .tablacontent .rz-grid-table thead th,
    .tablacontent th.rz-unselectable-text.rz-text-align-left {
        padding-top: .75rem !important;
        padding-bottom: .75rem !important;
    }

    .rz-paginator {
        border-top: solid #e2e8f0 1px;
    }

    .empty-state {
        padding: 3rem 1rem;
        text-align: center;
        color: #475569;
        border: 1px dashed #cbd5e1;
        border-radius: 8px;
        background: #f8fafc;
    }

    .table-action {
        width: 1.75rem;
        height: 1.75rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        background: #fff;
    }

    @@media (min-width: 1200px) {
        .users-page {
            width: calc(100vw - 20.75rem);
            max-width: none;
            margin-left: calc((100% - (100vw - 20.75rem)) / 2);
            margin-right: 0;
        }
    }

    @@media (max-width: 980px) {
        .users-header {
            flex-direction: column;
            align-items: stretch;
        }

        .users-toolbar {
            flex-wrap: wrap;
            flex-direction: column;
        }

        .users-toolbar-search {
            min-width: 0;
        }
    }
</style>

<div class="users-page">
    <AuthorizeView>
        <Authorized>
            <div class="users-header">
                <div>
                    <h3 class="users-title">Usuarios</h3>
                    <p class="users-description">Buscá por nombre, apellido, socio asociado o correo del socio.</p>
                </div>
            </div>

            <div class="users-card users-filter-card">
                <div class="users-toolbar">
                    <div class="users-toolbar-search">
                        <SearchInput Value="@searchText"
                                     ValueChanged="OnSearchChanged"
                                     IsLoading="@searchLoading"
                                     Placeholder="Buscar por nombre, apellido, mail o socio" />
                    </div>
                </div>
            </div>

            <div class="tablacontent" style="position:relative;width:80%;margin-left:10%;">
                <RadzenDataGrid TItem="User"
                                Data="@Usuarios"
                                Count="@count"
                                LoadData="@LoadUsers"
                                @ref="grid"
                                AllowFiltering="false"
                                AllowSorting="true"
                                AllowColumnResize="true"
                                AllowAlternatingRows="true"
                                AllowPaging="true"
                                PageSize="5"
                                ShowPagingSummary="true"
                                ColumnWidth="3.33%">
                    <Columns>
                        <RadzenDataGridColumn TItem="User" Property="Names" Title="Nombre/s" Width="15%" />
                        <RadzenDataGridColumn TItem="User" Property="LastNames" Title="Apellido/s" Width="15%" />
                        <RadzenDataGridColumn TItem="User" Property="Dni" Title="DNI" Width="12%" />
                        <RadzenDataGridColumn TItem="User" Property="Phone" Title="Número" Width="12%" />
                        <RadzenDataGridColumn TItem="User" Title="Socio asociado" Width="16%" Sortable="false">
                            <Template Context="data">
                                @GetSocioDisplay(data)
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="User" Property="Rol" Title="Rol" Width="12%" />
                        <RadzenDataGridColumn TItem="User" Property="Status" Title="Estado" Width="12%" />
                        <RadzenDataGridColumn TItem="User" Property="Email" Title="Email" Width="20%" />
                        <RadzenDataGridColumn TItem="User" Title="" Width="7%">
                            <Template Context="data">
                                <button class="btn" title="Eliminar" @onclick="@(()=>uriHelper.NavigateTo($"/EliminarUsuario/{data.Id}"))">
                                    <FeatherTrash2 Color="red" />
                                </button>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="User" Title="" Width="7%">
                            <Template Context="data">
                                <button class="btn" title="Info" @onclick="@(()=> ShowDetails(data))">
                                    <FeatherInfo Color="blue" />
                                </button>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>

                @if (!isLoading && count == 0)
                {
                    <div class="empty-state">
                        No hay usuarios para mostrar con los filtros actuales.
                    </div>
                }
            </div>
        </Authorized>
    </AuthorizeView>
</div>

@code {
    [CascadingParameter] public IModalService Modal { get; set; } = default!;

    private IList<User> Usuarios = new List<User>();
    private List<SocioDTO> Socios = new();

    private int count;
    private RadzenDataGrid<User>? grid;
    private bool initialGridLoadTriggered;
    private bool isLoading;
    private bool searchLoading;
    private string searchText = string.Empty;
    private int loadRequestVersion;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var rta = await _socioServicio.LimitadosFiltrados(0, 0);
            Socios = rta.List ?? new List<SocioDTO>();
        }
        catch
        {
            Socios = new List<SocioDTO>();
        }

    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || initialGridLoadTriggered || grid == null)
        {
            return;
        }

        initialGridLoadTriggered = true;
        await grid.Reload();
    }

    private async Task LoadUsers(LoadDataArgs args)
    {
        var requestId = ++loadRequestVersion;
        isLoading = true;
        StateHasChanged();

        try
        {
            var response = await SearchUsersPageAsync(args.Skip ?? 0, args.Top ?? 5);

            if (requestId != loadRequestVersion)
            {
                return;
            }

            if (response is not null)
            {
                Usuarios = JsonSerializer.Deserialize<IList<User>>(response.EntitiesPricipal ?? "[]") ?? new List<User>();
                count = response.AllRegisters;
            }
        }
        catch (Exception ex)
        {
            Usuarios = new List<User>();
            count = 0;
            Modal.Show<ModalInfo>("Error",
                SharedModalOptions.SetParameterModalInfo(ex.Message, "alert alert-danger"),
                SharedModalOptions.modalOptionsInfo);
        }
        finally
        {
            if (requestId == loadRequestVersion)
            {
                isLoading = false;
                searchLoading = false;
                StateHasChanged();
            }
        }
    }

    private async Task<ResponseForList?> SearchUsersPageAsync(int skip, int take)
    {
        var url = new System.Text.StringBuilder("api/Account/SearchUsersPaged");
        url.Append($"?skip={Math.Max(skip, 0)}");
        url.Append($"&take={Math.Max(take, 1)}");

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            url.Append($"&searchText={Uri.EscapeDataString(searchText)}");
        }

        var resp = await http.GetAsync(url.ToString());
        var payload = await resp.Content.ReadAsStringAsync();

        if (resp.IsSuccessStatusCode)
        {
            return JsonSerializer.Deserialize<ResponseForList>(payload);
        }

        if (resp.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            Usuarios = new List<User>();
            count = 0;
            return null;
        }

        if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            uriHelper.NavigateTo("/Logout");
            return null;
        }

        Modal.Show<ModalInfo>("Error",
            SharedModalOptions.SetParameterModalInfo(payload, "alert alert-danger"),
            SharedModalOptions.modalOptionsInfo);

        return null;
    }

    private async Task OnSearchChanged(string value)
    {
        searchLoading = true;
        searchText = value ?? string.Empty;
        await ReloadGridFromStartAsync();
    }

    private async Task ReloadGridFromStartAsync()
    {
        if (grid != null)
        {
            if (grid.CurrentPage > 0)
            {
                await grid.FirstPage(true);
            }
            else
            {
                await grid.Reload();
            }
        }
    }

    private async Task ShowDetails(User usuario)
    {
        var parameters = new ModalParameters();
        parameters.Add(nameof(DetailsUsuario.Usuario), usuario);
        var options = new ModalOptions
        {
            Size = ModalSize.ExtraLarge
        };

        var modalRef = Modal.Show<DetailsUsuario>("Detalles Del Usuario", parameters, options);
        await modalRef.Result;

        if (grid is not null)
        {
            await grid.Reload();
        }

        try
        {
            var rta = await _socioServicio.LimitadosFiltrados(0, 0);
            Socios = rta.List ?? new List<SocioDTO>();
        }
        catch
        {
        }
    }

    private string GetSocioDisplay(User usuario)
    {
        var socioIds = (usuario.SocioIds ?? new List<int>())
            .Where(x => x > 0)
            .Distinct()
            .ToList();

        if (socioIds.Count == 0 && usuario.SocioId.HasValue && usuario.SocioId.Value > 0)
        {
            socioIds.Add(usuario.SocioId.Value);
        }

        if (socioIds.Count == 0)
        {
            return string.Empty;
        }

        var activeSocioId = usuario.SocioId.HasValue && socioIds.Contains(usuario.SocioId.Value)
            ? usuario.SocioId.Value
            : socioIds[0];

        var socio = Socios.FirstOrDefault(x => x.Id == activeSocioId);
        if (socio == null)
        {
            return string.Empty;
        }

        var codigo = socio.CodigoVisible();
        var label = string.IsNullOrWhiteSpace(codigo) ? (socio.Nombre ?? string.Empty) : $"{codigo} - {socio.Nombre}";

        return socioIds.Count > 1
            ? $"{label} (+{socioIds.Count - 1})"
            : label;
    }

}
