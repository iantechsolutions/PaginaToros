@page "/reporteprint/{opcion:int}"
@* COMO NO SE PUEDE MANDAR STRING MANDAMOS INT, 1 ES TOROS, 0 ES CERTIFICADOS *@
@using PaginaToros.Client.Servicios.Contrato;
@inject ISocioServicio _socioServicio
@inject ITorosServicio _torosServicio
@inject ICertifsemanServicio _certifsemanServicio
@inject IJSRuntime js
@using Blazored.Typeahead;
<div class="report-page">
<br/>
<div class="no-print report-toolbar">
    <br/>
<div class="row">
    <div class="col-sm-3"/> 
    <div class="col-sm-6">
            <BlazoredTypeahead SearchMethod="BusquedaSocios"
                               placeholder="Seleccione el socio"
                               EnableDropDown="true"
                               Value="socioSeleccionado"
                               ValueChanged="@(EventCallback.Factory.Create<SocioDTO>(this, OnSocioChanged))"
                               ValueExpression="(() => socioSeleccionado)">
        <SelectedTemplate Context="eleccion">
            @eleccion.Nombre
        </SelectedTemplate>
        <ResultTemplate Context="eleccion">
            @eleccion.Nombre
        </ResultTemplate>
    </BlazoredTypeahead>
    </div>
    <div class="col-sm-2" style="width:10%;position:relative;left:2%">
        <button class="font-bold px-4 py-3 rounded-2xl bg-gray-200 hover:bg-gray-300 hover:border-transparent transition ease-in duration-100 transform hover:-translate-y-1 active:translate-y-0" style="position:relative;width:80%" @onclick="()=>Generate()">Buscar</button>
    </div>
    <div class="col-sm-1">
        <button style="outline:none; float: right;margin-right:3%;height:100%;" class="px-3 py-3 rounded-2xl bg-gray-200 hover:bg-gray-300 hover:border-transparent transition ease-in duration-100 transform hover:-translate-y-1 active:translate-y-0" @onclick="() => Print()"><FeatherPrinter Color="Black"></FeatherPrinter></button>
    </div>
</div>

</div>
@if(socioSeleccionado!=null && terminado && opcion == 1){
    <div class="report-shell">
        <section class="report-sheet">
            <div class="report-header">
                <div class="report-brand">
                    <span class="report-brand-kicker">Asociacion Argentina Criadores Hereford</span>
                    <span class="report-brand-title">Toros del Criador</span>
                </div>
            </div>

            <div class="report-meta-card">
                <div class="report-meta-pair">
                    <span class="report-meta-label">Socio</span>
                    <span class="report-meta-value">@socioSeleccionado.Nombre</span>
                </div>
                <div class="report-meta-divider"></div>
                <div class="report-meta-pair report-meta-pair-date">
                    <span class="report-meta-label">Fecha de impresion</span>
                    <span class="report-meta-value">@DateTime.Now.ToString("dd/MM/yyyy")</span>
                </div>
            </div>

            <div class="report-table-wrap">
            <table class="report-table" cellspacing="0">
                <thead>
                    <tr>
                        <th class="col-sm">HBA</th>
                        <th class="col-sm">Tatuaje</th>
                        <th class="col-xs">Var</th>
                        <th class="col-sm">Nacido</th>
                        <th class="col-xl">Nombre Toro</th>
                        <th class="col-md">Es Padre Desde</th>
                        <th class="col-sm">Estado</th>
                        <th class="col-sm">Actual</th>
                        <th class="col-lg">Tipo de Toro</th>
                    </tr>
                </thead>
                <tbody>
            @foreach(var toro in toros.Where(x=>x.CodEstado=="1"))
            {
                <tr>
                    <td>@toro.Hba</td>
                    <td>@toro.Tatpart</td>
                    <td>@toro.Variedad</td>
                    <td>
                        @if(toro.Nacido.HasValue){
                            @toro.Nacido.Value.ToString("dd/MM/yyyy")
                        }
                        else{
                            <span></span>
                        }
                    </td>
                    <td>@toro.NomDad</td>
                    <td></td>
                    <td>@traductor[toro.CodEstado]</td>
                    <td></td>
                    <td>@traductor[toro.TipToro]</td>
                </tr>

            }
                </tbody>
            </table>  
            </div>
        </section>
    </div>
}
else if (opcion == 0 && socioSeleccionado != null && terminado)
{
    <div class="report-shell">
        <section class="report-sheet">
            <div class="report-header">
                <div class="report-brand">
                    <span class="report-brand-kicker">Asociacion Argentina Criadores Hereford</span>
                    <span class="report-brand-title">Certificados del Criador</span>
                </div>
            </div>

            <div class="report-meta-card">
                <div class="report-meta-pair">
                    <span class="report-meta-label">Socio</span>
                    <span class="report-meta-value">@socioSeleccionado.Nombre</span>
                </div>
                <div class="report-meta-divider"></div>
                <div class="report-meta-pair report-meta-pair-date">
                    <span class="report-meta-label">Fecha de impresion</span>
                    <span class="report-meta-value">@DateTime.Now.ToString("dd/MM/yyyy")</span>
                </div>
            </div>

            <div class="report-table-wrap">
        <table class="report-table" cellspacing="0">
            <thead>
                <tr>
                    <th class="col-cert-type">Tipo cert.</th>
                    <th class="col-cert-date">Fecha de venta</th>
                    <th class="col-cert-socio">Socio</th>
                    <th class="col-cert-short">Tatuaje</th>
                    <th class="col-cert-short">HBA</th>
                    <th class="col-cert-name">Nombre</th>
                    <th class="col-cert-nick">Apodo</th>
                    <th class="col-cert-dose">Cant. dosis</th>
                    <th class="col-cert-dose">Cant. reman</th>
                    <th class="col-cert-var">Variedad</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cer in certificados.Where(x=>x.NrDosi>0))
                {
                <tr>
                        <td>@cer.TipoCert.ToUpper()</td>
                        <td>
                            @if (cer.Fecvta.HasValue)
                            {
                                @cer.Fecvta.Value.ToString("dd/MM/yyyy")
                            }
                            else
                            {
                                <span></span>
                            }
                        </td>
                        <td>@cer.Socio.Nombre</td>
                        <td>@cer.Tatpart</td>
                        <td>@cer.Hba</td>
                        <td>@cer.NomDad</td>
                        <td>@cer.Apodacion</td>
                        <td>@cer.NrDosiOr</td>
                        <td>@cer.NrDosi</td>
                        <td>@cer.Variedad</td>
                    </tr>

                }
            </tbody>
        </table>
            </div>
        </section>
    </div>

}
else if (seleccion && !terminado)
{
    <br/>
    <center>
        <div class="mb-2">
            <br />
            <RadzenProgressBar style="position:relative" Value="100" ShowValue="false" ProgressBarStyle="ProgressBarStyle.Primary" Mode="ProgressBarMode.Indeterminate" />
        </div>
    </center>
}
</div>

@code {
    [Parameter] public int opcion { get; set; }
    SocioDTO socioSeleccionado = null;
    List<SocioDTO> socios = new();
    bool terminado = false;
    bool seleccion = false;
    List<TorosuniDTO> toros = new();
    List<CertifsemanDTO> certificados = new();
    Dictionary<string, string> traductor = new Dictionary<string, string>{
        {"P","Puro Pedigree (SRA)"},
        {"S","S/"},
        {"A","Patagonico"},
        {"GP","Ganador de prueba"},
        {"1","Activo"},
        {"2","Inactivo"},
        {"3","Inexistente"},
        {"4","Muerto"},
        {"5","Vendido"}
    };
    protected override async Task OnInitializedAsync()
    {
        var rta = await _socioServicio.LimitadosFiltrados(0, 0);
        socios = rta.List;
    }

    private string TituloReporte => opcion == 1 ? "Toros del Criador" : "Certificados del Criador";

    private async Task<IEnumerable<SocioDTO>> BusquedaSocios(string searchText)
    {
        return await Task.FromResult(socios.Where(x => x.Nombre.ToLower().Contains(searchText.ToLower())).ToList());
    }

    private Task OnSocioChanged(SocioDTO? socio)
    {
        socioSeleccionado = socio;
        LimpiarReporte();
        return Task.CompletedTask;
    }

    private void LimpiarReporte()
    {
        terminado = false;
        seleccion = false;
        toros = new();
        certificados = new();
    }

    private async Task Generate()
    {
        try{
            if (socioSeleccionado == null)
            {
                LimpiarReporte();
                return;
            }

            seleccion = true;
            if (opcion == 1)
            {
                string filtro = $"(Criador == null ? \"\" : Criador).ToLower().Contains(\"{socioSeleccionado.Scod}\".ToLower())";
                var rtaa = await _torosServicio.LimitadosFiltradosNoInclude(0, 0,filtro);
                toros = rtaa.List.Where(x=>x.CodEstado!="4").ToList();
            }
            else if (opcion == 0)
            {
                string filtro = $"(Nrocri == null ? \"\" : Nrocri).ToLower().Contains(\"{socioSeleccionado.Scod}\".ToLower())";
                var rtaa = await _certifsemanServicio.LimitadosFiltrados(0, 0,filtro);
                certificados = rtaa.List;
            }
            terminado = true;
        }
        catch(Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }
    private async Task Print()
        => await js.InvokeVoidAsync("window.print");

}
