@page "/consultas"
@attribute [Authorize(Roles = "ADMINISTRADOR")]

<PageTitle>Consultas</PageTitle>
@inject ISocioServicio _socioServicio
@inject IDesepla1Servicio _desepla1Servicio

<AuthorizeView Roles="ADMINISTRADOR">
    <Authorized>
        <div class="container py-4">
            <div class="row justify-content-center">
                <div class="col-12 col-lg-8">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            <h3 class="mb-3">Consultas</h3>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <button type="button"
                                        class="btn btn-warning"
                                        @onclick="RepararSociosAsync"
                                        disabled="@isRepairing">
                                    @(isRepairing ? "Reparando socios..." : "Reparar datos de socios")
                                </button>
                                <button type="button"
                                        class="btn btn-primary"
                                        @onclick="CorregirPlantelesAmbiguosAsync"
                                        disabled="@isRepairingPlanteles">
                                    @(isRepairingPlanteles ? "Corrigiendo planteles..." : "Corregir planteles ambiguos")
                                </button>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(repairSummary))
                            {
                                <div class="@repairSummaryClass mb-3" role="alert">
                                    @repairSummary
                                    @if (repairObservations.Count > 0)
                                    {
                                        <hr />
                                        <div class="small mb-0">
                                            <strong>Observaciones:</strong>
                                            <ul class="mb-0 mt-2">
                                                @foreach (var obs in repairObservations)
                                                {
                                                    <li>@obs</li>
                                                }
                                            </ul>
                                        </div>
                                    }
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(plantelRepairSummary))
                            {
                                <div class="@plantelRepairSummaryClass mb-3" role="alert">
                                    @plantelRepairSummary
                                    @if (plantelRepairObservations.Count > 0)
                                    {
                                        <hr />
                                        <div class="small mb-0">
                                            <strong>Observaciones:</strong>
                                            <ul class="mb-0 mt-2">
                                                @foreach (var obs in plantelRepairObservations)
                                                {
                                                    <li>@obs</li>
                                                }
                                            </ul>
                                        </div>
                                    }
                                </div>
                            }

                            @if (plantelRepairPending.Count > 0)
                            {
                                <div class="table-responsive mb-4">
                                    <table class="table table-sm table-striped align-middle">
                                        <thead>
                                            <tr>
                                                <th>Id</th>
                                                <th>Nrodec</th>
                                                <th>Plantel</th>
                                                <th>Fecha</th>
                                                <th>Motivo</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in plantelRepairPending)
                                            {
                                                <tr>
                                                    <td>@item.Id</td>
                                                    <td>@item.Nrodec</td>
                                                    <td>@item.Nroplan</td>
                                                    <td>@FormatDate(item.FechaDeclaracion)</td>
                                                    <td class="text-break">@item.Motivo</td>
                                                    <td class="text-end">
                                                        <button type="button"
                                                                class="btn btn-outline-secondary btn-sm"
                                                                @onclick="@(() => OpenDeclaracion(item.Id))">
                                                            Abrir
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }

                            <dl class="row">
                                <dt class="col-sm-4">Version frontend</dt>
                                <dd class="col-sm-8">@FrontendVersion</dd>
                            </dl>

                            @if (!string.IsNullOrWhiteSpace(errorMessage))
                            {
                                <div class="alert alert-danger">@errorMessage</div>
                            }
                            else if (info is null)
                            {
                                <div class="alert alert-secondary mb-0">Cargando informacion del servidor...</div>
                            }
                            else
                            {
                                <dl class="row mb-0">
                                    <dt class="col-sm-4">Entorno</dt>
                                    <dd class="col-sm-8">@info.Environment</dd>

                                    <dt class="col-sm-4">Servidor</dt>
                                    <dd class="col-sm-8">@info.MachineName</dd>

                                    <dt class="col-sm-4">Hora actual UTC</dt>
                                    <dd class="col-sm-8">@FormatDate(info.ServerUtcNow)</dd>

                                    <dt class="col-sm-4">Inicio del proceso</dt>
                                    <dd class="col-sm-8">@FormatDate(info.ProcessStartTimeUtc)</dd>

                                    <dt class="col-sm-4">Ultima modificacion detectada</dt>
                                    <dd class="col-sm-8">@FormatDate(info.AssemblyLastWriteTimeUtc)</dd>

                                    <dt class="col-sm-4">Directorio base</dt>
                                    <dd class="col-sm-8 text-break">@info.AppBaseDirectory</dd>
                                </dl>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
</AuthorizeView>

@code {
    private const string FrontendVersion = "1.0.0";
    private bool isRepairing;
    private bool isRepairingPlanteles;
    private ConsultaInfo? info;
    private string? errorMessage;
    private string? repairSummary;
    private string repairSummaryClass = "alert alert-info";
    private readonly List<string> repairObservations = new();
    private string? plantelRepairSummary;
    private string plantelRepairSummaryClass = "alert alert-info";
    private readonly List<string> plantelRepairObservations = new();
    private readonly List<Desepla1PlantelAmbiguityPendingItem> plantelRepairPending = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            info = await Http.GetFromJsonAsync<ConsultaInfo>("api/consultas/info");
            if (info is null)
            {
                errorMessage = "No se pudo obtener la informacion del servidor.";
            }
        }
        catch (HttpRequestException ex)
        {
            errorMessage = $"No se pudo obtener la metadata del servidor. Version actual: {FrontendVersion}. Detalle: {ex.Message}";
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudo obtener la metadata del servidor. Version actual: {FrontendVersion}. Detalle: {ex.Message}";
        }
    }

    private async Task RepararSociosAsync()
    {
        if (isRepairing)
        {
            return;
        }

        var confirm = await Swal.FireAsync(new SweetAlertOptions
        {
            Title = "Reparar datos de socios",
            Text = "Esta acción revisará los socios sin SCOD y completará los códigos faltantes. ¿Querés continuar?",
            Icon = SweetAlertIcon.Warning,
            ShowCancelButton = true,
            ConfirmButtonText = "Sí, reparar",
            CancelButtonText = "Cancelar"
        });

        if (!confirm.IsConfirmed)
        {
            return;
        }

        isRepairing = true;
        repairSummary = null;
        repairObservations.Clear();

        try
        {
            var response = await _socioServicio.RepairMissingScod();
            if (response.Exito != 1 || response.List is null)
            {
                repairSummaryClass = "alert alert-danger";
                repairSummary = response.Mensaje ?? "No se pudo reparar la información de socios.";
                await Swal.FireAsync("Error", repairSummary, SweetAlertIcon.Error);
                return;
            }

            var result = response.List;
            repairObservations.AddRange(result.Observaciones ?? new List<string>());

            repairSummaryClass = "alert alert-success";
            repairSummary =
                $"Se revisaron {result.TotalSocios} socios. " +
                $"Se corrigieron {result.SociosReparados} sin SCOD: {result.SociosReparadosConCodpos2} usando CODPOS2 y {result.SociosReparadosConScodGenerado} generando un SCOD nuevo. " +
                $"Quedaron sin resolver {result.SociosSinResolver}.";

            await Swal.FireAsync("Listo", repairSummary, SweetAlertIcon.Success);
        }
        catch (Exception ex)
        {
            repairSummaryClass = "alert alert-danger";
            repairSummary = $"No se pudo completar la reparación. Detalle: {ex.Message}";
            await Swal.FireAsync("Error", repairSummary, SweetAlertIcon.Error);
        }
        finally
        {
            isRepairing = false;
        }
    }

    private async Task CorregirPlantelesAmbiguosAsync()
    {
        if (isRepairingPlanteles)
        {
            return;
        }

        var confirm = await Swal.FireAsync(new SweetAlertOptions
        {
            Title = "Corregir planteles ambiguos",
            Text = "Se revisarán todas las declaraciones y se corregirán automáticamente solo los casos resolubles. Los dudosos quedarán listados para revisar manualmente.",
            Icon = SweetAlertIcon.Warning,
            ShowCancelButton = true,
            ConfirmButtonText = "Sí, corregir",
            CancelButtonText = "Cancelar"
        });

        if (!confirm.IsConfirmed)
        {
            return;
        }

        isRepairingPlanteles = true;
        plantelRepairSummary = null;
        plantelRepairObservations.Clear();
        plantelRepairPending.Clear();

        try
        {
            var response = await _desepla1Servicio.RepairAmbiguousPlantels();
            if (response.Exito != 1 || response.List is null)
            {
                plantelRepairSummaryClass = "alert alert-danger";
                plantelRepairSummary = response.Mensaje ?? "No se pudo corregir la información de planteles.";
                await Swal.FireAsync("Error", plantelRepairSummary, SweetAlertIcon.Error);
                return;
            }

            var result = response.List;
            plantelRepairObservations.AddRange(result.Observaciones ?? new List<string>());
            plantelRepairPending.AddRange(result.Pendientes ?? new List<Desepla1PlantelAmbiguityPendingItem>());

            plantelRepairSummaryClass = plantelRepairPending.Count > 0 ? "alert alert-warning" : "alert alert-success";
            plantelRepairSummary =
                $"Se revisaron {result.TotalDeclaraciones} declaraciones. " +
                $"Con plantel cargado: {result.DeclaracionesConPlantel}. " +
                $"Se corrigieron {result.DeclaracionesCorregidas}. " +
                $"Quedaron pendientes {result.DeclaracionesPendientes}.";

            await Swal.FireAsync("Listo", plantelRepairSummary, SweetAlertIcon.Success);
        }
        catch (Exception ex)
        {
            plantelRepairSummaryClass = "alert alert-danger";
            plantelRepairSummary = $"No se pudo completar la corrección de planteles. Detalle: {ex.Message}";
            await Swal.FireAsync("Error", plantelRepairSummary, SweetAlertIcon.Error);
        }
        finally
        {
            isRepairingPlanteles = false;
        }
    }

    private static string FormatDate(DateTime? value)
    {
        return value.HasValue ? value.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") : "No disponible";
    }

    private void OpenDeclaracion(int id) => nav.NavigateTo($"/declaraciones/{id}");

    private sealed class ConsultaInfo
    {
        public string FrontendVersion { get; set; } = string.Empty;
        public string Environment { get; set; } = string.Empty;
        public string MachineName { get; set; } = string.Empty;
        public DateTime ServerUtcNow { get; set; }
        public DateTime ProcessStartTimeUtc { get; set; }
        public DateTime? AssemblyLastWriteTimeUtc { get; set; }
        public string AppBaseDirectory { get; set; } = string.Empty;
    }
}
