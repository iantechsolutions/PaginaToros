@page "/declaraciones"

@using PaginaToros.Shared.Models.Response
@using PaginaToros.Shared.Models
@using PaginaToros.Client.Servicios.Contrato;
@inject IDesepla1Servicio _desepla1Servicio
@inject ICertifsemanServicio _certifsemanServicio
@inject IDesepla3Servicio _desepla3Servicio


<style>
    .declaraciones-page {
        width: 93.5%;
        margin-left: 3.33%;
        color: #2b2418;
    }

    .declaraciones-title {
        margin: 0 0 1.15rem;
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: #2f3427;
    }

    .declaraciones-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.35rem;
        flex-wrap: wrap;
    }

    .declaraciones-actions {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        flex-wrap: wrap;
    }

    .declaraciones-primary-btn,
    .declaraciones-filter-btn {
        border: 0;
        transition: transform 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease;
    }

    .declaraciones-primary-btn {
        padding: 0.72rem 1.15rem;
        border-radius: 18px;
        background: linear-gradient(135deg, #cab08a 0%, #a78052 100%);
        color: #fffaf2;
        box-shadow: 0 16px 30px rgba(116, 83, 47, 0.18);
        font-weight: 800;
        font-size: 0.98rem;
    }

    .declaraciones-primary-btn:hover,
    .declaraciones-filter-btn:hover {
        transform: translateY(-1px);
    }

    .declaraciones-filter-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.95rem;
        height: 2.95rem;
        border-radius: 16px;
        background: linear-gradient(135deg, #f0ede1 0%, #ddd6c1 100%);
        box-shadow: 0 12px 26px rgba(82, 68, 46, 0.12);
    }

    .declaraciones-filter-btn.active {
        background: linear-gradient(135deg, #e9dfc9 0%, #d1bc96 100%);
    }

    .declaraciones-grid-shell {
        padding: 0;
        border: 0;
        background: transparent;
        box-shadow: none;
        border-radius: 24px 24px 0 0;
        overflow: hidden;
    }

    .rz-cell-data,
    .rz-column-title-content {
        font-size: 13px !important;
    }

    .rz-cell-data {
        overflow: visible !important;
        white-space: normal !important;
    }

    .declaraciones-grid {
        width: 100%;
    }

    .declaraciones-action-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.2rem;
        height: 2.2rem;
        border: 0;
        border-radius: 12px;
        background: rgba(110, 147, 78, 0.12);
        transition: background-color 0.18s ease, transform 0.18s ease;
    }

    .declaraciones-action-btn:hover {
        background: rgba(110, 147, 78, 0.2);
        transform: translateY(-1px);
    }

    @@media (max-width: 767.98px) {
        .declaraciones-page {
            width: 100%;
            margin-left: 0;
        }

        .declaraciones-title {
            font-size: 1.6rem;
        }

        .declaraciones-toolbar {
            align-items: stretch;
        }

        .declaraciones-actions {
            width: 100%;
            justify-content: space-between;
        }

    }
</style>
<AuthorizeView Roles="ADMINISTRADOR,USUARIOMAESTRO,Socio">
    <Authorized>
        <section class="declaraciones-page">
            <h3 class="declaraciones-title">Declaraciones de servicio</h3>

            <div class="declaraciones-toolbar">
                <div class="declaraciones-actions">
                    <button class="declaraciones-primary-btn"
                            @onclick="() => add(0, esSocio)">
                        Agregar Declaracion
                    </button>
                </div>

                @if (oRespuesta.List != null)
                {
                    <button class="declaraciones-filter-btn @(allowFiltering ? "active" : string.Empty)"
                            type="button"
                            title="Mostrar filtros"
                            @onclick="() => CambiarModoFiltro()">
                        <FeatherFilter Color="#3e3528"></FeatherFilter>
                    </button>
                }
            </div>

            @if (oRespuesta.List != null)
            {
                <div class="declaraciones-grid-shell">
                    <RadzenDataGrid class="tablacontent declaraciones-grid"
                                    AllowFiltering="allowFiltering"
                                    IsLoading="@isLoading"
                                    LoadData="LoadData"
                                    AllowColumnResize="true"
                                    AllowAllowAlternatingRows="true"
                                    FilterMode="FilterMode.Simple"
                                    AllowSorting="false"
                                    PageSize="15"
                                    Density="Density.Compact"
                                    AllowPaging="true"
                                    ShowPagingSummary="true"
                                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                    @ref="grid"
                                    Count="@cantidad"
                                    Data="@oRespuesta.List"
                                    TItem="Desepla1DTO"
                                    ColumnWidth="3.33%"
                                    LogicalFilterOperator="LogicalFilterOperator.Or"
                                    PagerHorizontalAlign="HorizontalAlign.Center">

                        <Columns>
                            <RadzenDataGridColumn TItem="Desepla1DTO" Property="Nrodec" Title="Nro de declaracion" Width="6.6%" />
                            <RadzenDataGridColumn TItem="Desepla1DTO" Property="NrFolio" Title="Nro de folio" Width="3.33%" />
                            <RadzenDataGridColumn TItem="Desepla1DTO" Property="Nroplan" Title="Nro de plantel" Width="3.33%" />

                            <RadzenDataGridColumn TItem="Desepla1DTO" Property="Socio.Nombre" Title="Socio" Width="7.34%" Visible="@(!esSocio)" />

                            <RadzenDataGridColumn TItem="Desepla1DTO" Property="Desde" Title="Desde" Width="4.6%">
                                <Template Context="data">
                                    @if (data.Desde.HasValue)
                                    {
                                        <a>@data.Desde.Value.ToString("dd/MM/yyyy")</a>
                                    }
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="Desepla1DTO" Property="Hasta" Title="Hasta" Width="4.6%">
                                <Template Context="data">
                                    @if (data.Hasta.HasValue)
                                    {
                                        <a>@data.Hasta.Value.ToString("dd/MM/yyyy")</a>
                                    }
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="Desepla1DTO" Property="Fchrecepcion" Title="Fecha de recepcion" Width="4.6%">
                                <Template Context="data">
                                    @if (data.Fchrecepcion.HasValue)
                                    {
                                        <a>@data.Fchrecepcion.Value.ToString("dd/MM/yyyy")</a>
                                    }
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="Desepla1DTO" Property="Tipse" Title="Tipo de servicio" Width="5%" />

                            <RadzenDataGridColumn TItem="Desepla1DTO" Title="" Filterable="false" Width="3.33%">
                                <Template Context="data">
                                    <button class="declaraciones-action-btn"
                                            title="Editar Declaracion"
                                            @onclick="() => add(data.Id, esSocio)">
                                        <FeatherEdit Size="16" Color="#5a8750" />
                                    </button>
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </div>
            }
            else
            {
                <center>
                    <div class="mb-2 pt-4">
                        <RadzenProgressBar style="width:100%" Value="100" ShowValue="false"
                                           ProgressBarStyle="ProgressBarStyle.Primary"
                                           Mode="ProgressBarMode.Indeterminate" />
                    </div>
                </center>
            }
        </section>
    </Authorized>
</AuthorizeView>

@code {
    [CascadingParameter] public IModalService Modal { get; set; } = default!;
    public RadzenDataGrid<Desepla1DTO>? grid;
    List<SocioDTO> socios = new();
    int cantidad;
    int currentPage;
    bool isLoading = false;
    public bool allowFiltering = false;
    public Respuesta<List<Desepla1DTO>> oRespuesta = new Respuesta<List<Desepla1DTO>>();

    Boolean esSocio = true;
    protected override async Task OnInitializedAsync()
    {
        await Get();
    }
    async Task Get()
    {
        esSocio = await UserHasRole("Socio");
        await LoadPageAsync(0, 15, null);
        NormalizeList();
    }

    private async Task<bool> UserHasRole(string role)
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        return authenticationState.User.IsInRole(role);
    }

    public void CambiarModoFiltro()
    {
        allowFiltering = !allowFiltering;
    }

 
    async Task add(int Id,bool esSocio)
    {
        nav.NavigateTo($"/declaraciones/{Id}");

    }
    async Task LoadData(LoadDataArgs args)
    {
        isLoading = true;
        await LoadPageAsync(args.Skip ?? 0, args.Top ?? 15, args.Filter);
        NormalizeList();
        isLoading = false;
    }

    private async Task LoadPageAsync(int skip, int take, string? filterExpression)
    {
        if (string.IsNullOrWhiteSpace(filterExpression))
        {
            var c = await _desepla1Servicio.CantidadTotal();
            cantidad = c.List;
            oRespuesta = await _desepla1Servicio.Lista(skip, take);
            return;
        }

        oRespuesta = await _desepla1Servicio.LimitadosFiltrados(skip, take, filterExpression);
        var filteredCount = await _desepla1Servicio.LimitadosFiltrados(0, 0, filterExpression);
        cantidad = filteredCount.List?.GroupBy(x => x.Id).Select(g => g.First()).Count() ?? 0;
    }

    private void NormalizeList()
    {
        oRespuesta.List = oRespuesta.List?
            .GroupBy(x => x.Id)
            .Select(g => g.First())
            .ToList();
    }





  


}
