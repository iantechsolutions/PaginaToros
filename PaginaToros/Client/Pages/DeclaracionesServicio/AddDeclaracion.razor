    double GetMultiplicador(string tipo) => tipo switch
    {
        "Inseminacion c/celo" => 1.5,
        "Inseminacion c/celo y rep" => 1.0,
        "IATF c/rep" => 1.0,
        "ANUAL" => 1.0,
        "Santa Fe" => 1.0,
        "Inseminacion c/p y rep" => 0.8,
        _ => 0.0 // Natural no consume dosis
    };

    int DosisNecesarias(double? cantVientres, double multiplicador)
    {
        var v = cantVientres ?? 0.0;
        if (multiplicador <= 0) return 0;

        return (int)Math.Round(v * multiplicador, MidpointRounding.AwayFromZero);
    }
    Dictionary<string, string> errors = new();

    // Construye un mapa HBA -> dosis totales usadas en la declaración
    Dictionary<string, int> BuildUsoPorCert(IEnumerable<Desepla3DTO> items, double multiplicador)
    {
        return items
            .Where(x => x.Tipo == "insem")  
            .GroupBy(x => x.Hardb)
            .ToDictionary(
                g => g.Key,
                g => g.Sum(d => DosisNecesarias(d.Cantv, multiplicador))
            );
    }

    Dictionary<string, int> BuildUsoPorCertFromSelected(IEnumerable<Desepla3Data> items, double multiplicador)
    {
        return items
            .Where(x => x.original != null && x.original.Tipo == "insem" && !string.IsNullOrWhiteSpace(x.original.Hardb))
            .GroupBy(x => x.original.Hardb)
            .ToDictionary(
                g => g.Key,
                g => g.Sum(d => DosisNecesarias(d.original.Cantv, multiplicador))
            );
    }

    private int GetDosisRemanDisplay(string? hba)
    {
        if (string.IsNullOrWhiteSpace(hba)) return 0;

        var cert = certificados.FirstOrDefault(x => x.Hba == hba);
        var baseStock = cert?.NrDosi ?? 0;

        // Si estamos editando, devolvemos al stock lo usado originalmente por la declaración
        if (_isEdit && deseplasViejos.Count > 0)
        {
            var multPrev = GetMultiplicador(string.IsNullOrWhiteSpace(previousTipoTemp) ? tipoTemp : previousTipoTemp);
            var usoInicial = BuildUsoPorCert(deseplasViejos, multPrev);
            if (usoInicial.TryGetValue(hba, out var u))
            {
                baseStock += u;
            }
        }

        // Restamos lo que se está usando ahora en pantalla
        var multActual = GetMultiplicador(tipoTemp);
        var usoActual = BuildUsoPorCertFromSelected(certificadosSeleccionados, multActual);
        if (usoActual.TryGetValue(hba, out var a))
        {
            baseStock -= a;
        }

        return baseStock < 0 ? 0 : baseStock;
    }

    private string CampoLegible(string key) => key switch
    {
        "socio" => "Socio",
        "plantel" => "Plantel",
        "plantelCodigo" => "Código de plantel",
        "tipo" => "Tipo de servicio",
        "tipoCodigo" => "Tipo de servicio",
        "NrFolio" => "Nº de folio",
        "Fchrecepcion" => "Fecha de declaración",
        "cantv" => "Vientres PR",
        "cantb" => "Vientres VIP",
        "periodoNatural" => "Período (Natural)",
        "torosNatural" => "Toros (Natural)",
        "torosCorral" => "Toros (Natural a Corral)",
        "certifs" => "Certificados de semen",
        _ => key
    };


    private string ToCode(string label)
    {
        var normalized = NormalizeTipoLabel(label);
        if (traductor.TryGetValue(normalized, out var code)) return code;
        // Fallback: si ya es código o es un label desconocido
        return normalized;
    }

    private string ToLabel(string code)
    {
        if (string.IsNullOrWhiteSpace(code)) return code;

        // Normalización de códigos legacy para que la UI siempre trabaje con labels actuales.
        if (string.Equals(code, "ANUAL", StringComparison.OrdinalIgnoreCase))
            return "Inseminacion c/celo y rep";
        if (string.Equals(code, "IATFR", StringComparison.OrdinalIgnoreCase))
            return "IATF c/rep";

        // Invertimos el diccionario en caliente (o creá otro diccionario inverso fijo)
        var pair = traductor.FirstOrDefault(kv => kv.Value == code);
        return string.IsNullOrWhiteSpace(pair.Key) ? code : NormalizeTipoLabel(pair.Key);
    }

    private string NormalizeTipoLabel(string? label)
    {
        var v = (label ?? string.Empty).Trim();
        if (string.Equals(v, "ANUAL", StringComparison.OrdinalIgnoreCase))
            return "Inseminacion c/celo y rep";
        if (string.Equals(v, "Santa Fe", StringComparison.OrdinalIgnoreCase))
            return "IATF c/rep";
        return v;
    }

    private bool IsNaturalTipo(string? tipo) => string.Equals(NormalizeTipoLabel(tipo), "Natural", StringComparison.Ordinal);
    private bool IsNaturalCorralTipo(string? tipo) => string.Equals(NormalizeTipoLabel(tipo), "Natural a Corral", StringComparison.Ordinal);
    private bool IsTipoInseminacion(string? tipo)
    {
        var t = NormalizeTipoLabel(tipo);
        return t == "Inseminacion c/celo"
               || t == "Inseminacion c/celo y rep"
               || t == "Inseminacion c/p y rep"
               || t == "IATF c/rep";
    }
    private bool IsTipoConToros(string? tipo)
    {
        var t = NormalizeTipoLabel(tipo);
        return t == "Natural a Corral" || t == "Inseminacion c/celo y rep" || t == "Inseminacion c/p y rep" || t == "IATF c/rep";
    }



    private string BuildErrorsHtml()
    {
        var items = errors
            .Select(kv => $"<li><b>{CampoLegible(kv.Key)}:</b> {System.Net.WebUtility.HtmlEncode(kv.Value)}</li>");
        return $"<ul style='text-align:left;margin-left:1rem'>{string.Join("", items)}</ul>";
    }

    private string BuildSaveHintsHtml()
    {
        var hints = new List<string>();

        if (Plantelseleccionado != null && !string.IsNullOrWhiteSpace(Plantelseleccionado.Placod) && Plantelseleccionado.Placod.Length > 6)
            hints.Add($"El código de plantel \"{System.Net.WebUtility.HtmlEncode(Plantelseleccionado.Placod)}\" supera 6 caracteres.");

        var tipseCode = string.IsNullOrWhiteSpace(tipoTemp) ? string.Empty : ToCode(tipoTemp);
        if (!string.IsNullOrWhiteSpace(tipseCode) && tipseCode.Length > 5)
            hints.Add($"El tipo de servicio seleccionado se envía como \"{System.Net.WebUtility.HtmlEncode(tipseCode)}\" y supera 5 caracteres.");

        if (hints.Count == 0) return string.Empty;

        var li = string.Join("", hints.Select(h => $"<li>{h}</li>"));
        return $"<div style='margin-top:.5rem'><b>Posibles causas:</b><ul style='text-align:left;margin-left:1rem'>{li}</ul></div>";
    }

    private async Task HandleSubmit(EditContext _)
    {
        Log($"HandleSubmit | socio={Q(socioSeleccionado?.Scod)} | plantel={Q(Plantelseleccionado?.Placod)} | tipo={Q(tipoTemp)} | torosSel={torosSeleccionados.Count} | certifsSel={certificadosSeleccionados.Count}");
        if (!ValidateManual())
        {
            Log($"ValidateManual FAIL | errores={string.Join(" | ", errors.Select(e => $"{e.Key}:{e.Value}"))}");
            // Alerta con resumen de errores
            await Swal.FireAsync(new SweetAlertOptions
                {
                    Title = "Faltan datos para guardar",
                    Html = BuildErrorsHtml(),
                    Icon = SweetAlertIcon.Warning,
                    ConfirmButtonText = "Revisar"
                });

            StateHasChanged(); // por si además mostrás mensajes rojos debajo
            return;
        }

        Log("ValidateManual OK. Ejecutando Guardar...");
        await Guardar();
    }

    private void ClearErrors() => errors.Clear();


    private bool ValidateManual()
    {
        ClearErrors();

        // 1) Requeridos básicos
        if (socioSeleccionado is null)
            errors["socio"] = "Debe seleccionar un socio.";

        if (Plantelseleccionado is null)
            errors["plantel"] = "Debe seleccionar un plantel.";
        else if (!string.IsNullOrWhiteSpace(Plantelseleccionado.Placod) && Plantelseleccionado.Placod.Length > 6)
            errors["plantelCodigo"] = "El código de plantel supera 6 caracteres y no puede guardarse.";

        if (string.IsNullOrWhiteSpace(tipoTemp))
            errors["tipo"] = "Seleccione el tipo de servicio.";
        else
        {
            var tipseCode = ToCode(tipoTemp);
            if (!string.IsNullOrWhiteSpace(tipseCode) && tipseCode.Length > 5)
                errors["tipoCodigo"] = "Tipo de servicio inválido para guardar. Intente re-seleccionarlo.";
        }

        if (oDeclaracion.NrFolio is null || (oDeclaracion.NrFolio ?? 0) <= 0)
            errors["NrFolio"] = "Ingrese un número de folio válido.";

        if (oDeclaracion.Fchrecepcion is null)
            errors["Fchrecepcion"] = "Ingrese la fecha de declaración.";

        // 2) Límites PR/VIP contra el plantel
        var prTotal = (Plantelseleccionado?.Varede ?? 0)
                    + (Plantelseleccionado?.Vqssrd ?? 0)
                    + (Plantelseleccionado?.Vqcsrd ?? 0);

        var vipTotal = (Plantelseleccionado?.Varepr ?? 0)
                     + (Plantelseleccionado?.Vqssrp ?? 0)
                     + (Plantelseleccionado?.Vqcsrp ?? 0);

        if ((oDeclaracion.Cantv ?? 0) < 0 || (oDeclaracion.Cantv ?? 0) > prTotal)
            errors["cantv"] = $"La cantidad PR no puede superar {prTotal}.";

        if ((oDeclaracion.Cantb ?? 0) < 0 || (oDeclaracion.Cantb ?? 0) > vipTotal)
            errors["cantb"] = $"La cantidad VIP no puede superar {vipTotal}.";

        // 3) Reglas por tipo
        bool esNatural = IsNaturalTipo(tipoTemp);
        bool esNaturalCorral = IsNaturalCorralTipo(tipoTemp);
        bool esAlgunaInsemin = IsTipoInseminacion(tipoTemp);

        // Natural: requiere periodo y al menos 1 toro
        if (esNatural)
        {
            if (oDeclaracion.Desde == null || oDeclaracion.Hasta == null || oDeclaracion.Desde > oDeclaracion.Hasta)
                errors["periodoNatural"] = "Complete un periodo válido (Desde/Hasta).";

            if (torosSeleccionados.Count == 0)
                errors["torosNatural"] = "Debe seleccionar al menos un toro.";
        }

        // Natural a Corral: toros con fechas por fila
        if (esNaturalCorral)
        {
            bool algunaFilaInvalida = torosSeleccionados.Any(t => t.Desde == default || t.Hasta == default || t.Desde > t.Hasta);
            if (torosSeleccionados.Count == 0 || algunaFilaInvalida)
                errors["torosCorral"] = "Seleccione toros y complete fechas válidas en cada fila.";
        }

        // Inseminación: certificados con Cantv > 0 y fechas válidas
        if (esAlgunaInsemin)
        {
            bool faltan = certificadosSeleccionados.Count == 0;
            bool cantErr = certificadosSeleccionados.Any(c => (c.original.Cantv ?? 0) <= 0);
            bool fechasErr = certificadosSeleccionados.Any(c => c.Desde == default || c.Hasta == default || c.Desde > c.Hasta);

            if (faltan || cantErr || fechasErr)
                errors["certifs"] = "Agregue certificados, con vientres mayores a 0 y fechas válidas por fila.";
        }

        return errors.Count == 0;
    }
    async Task Guardar()
    {
        Log($"Guardar START | Id={Id} | nrodec={Q(oDeclaracion?.Nrodec)}");
        seleccionFinal.Clear();
        LogSelectedSnapshot("Guardar -> torosSeleccionados antes de persistir", torosSeleccionados);
        LogSelectedSnapshot("Guardar -> certificadosSeleccionados antes de persistir", certificadosSeleccionados);

        oDeclaracion.Nrocri = socioSeleccionado.Scod;
        oDeclaracion.Nroplan = Plantelseleccionado.Placod;
        oDeclaracion.Tipse = ToCode(tipoTemp);
        oDeclaracion.Desde ??= DateTime.Now;
        oDeclaracion.Hasta ??= DateTime.Now;
        Log($"Cabecera lista para persistir | Nrocri={Q(oDeclaracion.Nrocri)} | Nroplan={Q(oDeclaracion.Nroplan)} | Tipse={Q(oDeclaracion.Tipse)}");


        // --- Multiplicadores
        var multActual = GetMultiplicador(tipoTemp);
        var multPrevio = GetMultiplicador(string.IsNullOrWhiteSpace(previousTipoTemp) ? tipoTemp : previousTipoTemp);
        Log($"Multiplicadores | actual={multActual} (tipo={Q(tipoTemp)}) | previo={multPrevio} (tipoPrev={Q(previousTipoTemp)})");



        if (IsNaturalTipo(tipoTemp))
        {
            var d = oDeclaracion.Desde ?? DateTime.Now;
            var h = oDeclaracion.Hasta ?? DateTime.Now;

            foreach (var t in torosSeleccionados)
            {
                t.Desde = d;
                t.Hasta = h;
            }
        }

        // --- Armo seleccionFinal como hacías
        foreach (var adaptacion in torosSeleccionados)
        {
            adaptacion.original.Desde = adaptacion.Desde.ToString("yyyy-MM-dd");
            adaptacion.original.Hasta = adaptacion.Hasta.ToString("yyyy-MM-dd");
            seleccionFinal.Add(adaptacion.original);

            if (tipoTemp != "Natural")
            {
                if (adaptacion.Desde < oDeclaracion.Desde!.Value) oDeclaracion.Desde = adaptacion.Desde;
                if (adaptacion.Hasta > oDeclaracion.Hasta!.Value) oDeclaracion.Hasta = adaptacion.Hasta;
            }
        }

        foreach (var adaptacion in certificadosSeleccionados)
        {
            adaptacion.original.Desde = adaptacion.Desde.ToString("yyyy-MM-dd");
            adaptacion.original.Hasta = adaptacion.Hasta.ToString("yyyy-MM-dd");
            seleccionFinal.Add(adaptacion.original);

            // Ajusto rango general con min/max
            if (adaptacion.Desde < oDeclaracion.Desde!.Value) oDeclaracion.Desde = adaptacion.Desde;
            if (adaptacion.Hasta > oDeclaracion.Hasta!.Value) oDeclaracion.Hasta = adaptacion.Hasta;

        }
        Log($"seleccionFinal armada | total={seleccionFinal.Count} | toros={torosSeleccionados.Count} | certifs={certificadosSeleccionados.Count}");
        LogDetalleSnapshot("Guardar -> seleccionFinal", seleccionFinal);


        // --- USO INICIAL (lo que tenía la declaración al cargar)
        //     NOTA: usamos deseplasViejos (traídos de BD). Si estás creando, es lista vacía.
        var usoInicialPorCert = BuildUsoPorCert(deseplasViejos, multPrevio);

        // --- USO ACTUAL (lo que consumen hoy los seleccionados en pantalla)
        var usoActualPorCert = BuildUsoPorCert(seleccionFinal, multActual);

        // --- Union de HBAs para calcular delta
        var hbAs = new HashSet<string>(usoInicialPorCert.Keys);
        hbAs.UnionWith(usoActualPorCert.Keys);
        Log($"Uso certificados | inicialHBAs={usoInicialPorCert.Count} | actualHBAs={usoActualPorCert.Count} | unionHBAs={hbAs.Count}");

        // --- Calcular delta y preparar edición de certificados
        var certificadosAlterados = new List<CertifsemanDTO>();

        foreach (var hba in hbAs)
        {
            var inicial = usoInicialPorCert.TryGetValue(hba, out var i) ? i : 0;
            var actual = usoActualPorCert.TryGetValue(hba, out var a) ? a : 0;
            var delta = actual - inicial; // + = restar del certificado; - = devolver al certificado

            if (delta == 0) continue;

            var cert = certificados.FirstOrDefault(x => x.Hba == hba);
            if (cert == null)
            {
                Log($"No se encontró certificado en memoria para HBA={Q(hba)}");
                await Swal.FireAsync("Atención", $"No se encontró certificado para HBA {hba}", SweetAlertIcon.Warning);
                continue;
            }

            // Simulamos para validar
            var nuevoNrDosi = cert.NrDosi - delta; // delta positivo resta; delta negativo suma
            if (nuevoNrDosi < 0)
            {
                Log($"Stock insuficiente | HBA={Q(hba)} | delta={delta} | actualNrDosi={cert.NrDosi}");
                await Swal.FireAsync("Atención",
                    $"El certificado HBA {hba} no tiene suficientes dosis. " +
                    $"Intento consumir {delta} y quedan {cert.NrDosi}.",
                    SweetAlertIcon.Warning);
                return; // aborta el guardado
            }

            // Creamos un "snapshot" para enviar al Editar
            certificadosAlterados.Add(new CertifsemanDTO
                {
                    Id = cert.Id,
                    NrDosi = nuevoNrDosi,

                    // <<< IMPORTANTE >>>
                    // Copiá aquí cualquier otro campo NO NULLABLE que tu API espere en Editar
                    // (si tu Editar hace "update full", envía los mismos valores actuales del cert)
                    Hba = cert.Hba,
                    Tatpart = cert.Tatpart,
                    Nrocri = cert.Nrocri,
                    NomDad = cert.NomDad
                    // ... lo que corresponda en tu DTO
                });
        }

        // --- Persistencia de certificados primero (para asegurar stock coherente)
        foreach (var cert in certificadosAlterados)
        {
            Log($"UpdateNrDosi | certId={cert.Id} | HBA={Q(cert.Hba)} | nuevoNrDosi={cert.NrDosi}");
            var r = await _certifsemanServicio.UpdateNrDosi(cert.Id, cert.NrDosi ?? 0);
            if (r?.Exito != 1)
            {
                Log($"UpdateNrDosi ERROR | certId={cert.Id} | mensaje={Q(r?.Mensaje)}");
                await Swal.FireAsync("Error", r?.Mensaje ?? "No se pudo actualizar NrDosi", SweetAlertIcon.Error);
                return; // abortar guardar si querés consistencia estricta
            }
        }

        // --- Persistir declaración y detalles (tu flujo original)
        if (!string.IsNullOrEmpty(oDeclaracion.Nrodec) && oDeclaracion.Nrodec.Length > 15)
        {
            oDeclaracion.Nrodec = oDeclaracion.Nrodec.Substring(0, 15);
        }
        else if (string.IsNullOrEmpty(oDeclaracion.Nrodec))
        {
            oDeclaracion.Nrodec = "0";
        }

        if (Id == 0)
        {
            Log("Flujo guardar: CREAR cabecera");
            // Crear: primero persistir la cabecera para reducir riesgo de desincronía en Nrodec
            Respuesta<Desepla1DTO>? createdResp = null;
            try
            {
                createdResp = await _desepla1Servicio.Crear(oDeclaracion);
            }
            catch (Exception ex)
            {
                Log($"Excepción creando cabecera: {ex.Message}");
                await Swal.FireAsync(new SweetAlertOptions
                    {
                        Title = "Error al crear declaración",
                        Html = $"No se pudo crear la cabecera.<br/><b>Detalle:</b> {System.Net.WebUtility.HtmlEncode(ex.Message)}<br/>{BuildSaveHintsHtml()}",
                        Icon = SweetAlertIcon.Error
                    });
                return;
            }

            if (createdResp == null || createdResp.Exito != 1 || createdResp.List == null)
            {
                var detalle = createdResp?.Mensaje;
                Log($"Error creando cabecera | respuestaNull={createdResp is null} | exito={createdResp?.Exito} | mensaje={Q(detalle)}");
                await Swal.FireAsync(new SweetAlertOptions
                    {
                        Title = "Error al crear declaración",
                        Html = $"No se pudo crear la cabecera.<br/><b>Detalle:</b> {System.Net.WebUtility.HtmlEncode(!string.IsNullOrWhiteSpace(detalle) ? detalle : "Sin detalle devuelto por el servidor.")}<br/>{BuildSaveHintsHtml()}",
                        Icon = SweetAlertIcon.Error
                    });
                return;
            }

            // Asegurar que usamos el Nrodec devuelto por el servidor si lo modificó
            oDeclaracion = createdResp.List;
            Log($"Cabecera creada OK | Id={oDeclaracion.Id} | Nrodec={Q(oDeclaracion.Nrodec)}");

            // Persistir detalles con el Nrodec confirmado
            foreach (var dese in seleccionFinal)
            {
                dese.Nrodec = oDeclaracion.Nrodec;
                Log($"Crear detalle | Nrodec={Q(dese.Nrodec)} | Tipo={Q(dese.Tipo)} | HBA={Q(dese.Hardb)} | Tat={Q(dese.Tatpart)} | Cantv={dese.Cantv} | Desde={Q(dese.Desde)} | Hasta={Q(dese.Hasta)}");
                try
                {
                    var detResp = await _desepla3Servicio.Crear(dese);
                    if (detResp == null || detResp.Exito != 1)
                    {
                        Log($"Error creando detalle | HBA={Q(dese.Hardb)} | tipo={Q(dese.Tipo)} | mensaje={Q(detResp?.Mensaje)}");
                        await Swal.FireAsync("Error al crear detalle",
                            $"Falló la creación de un detalle (HBA: {dese.Hardb}, Tipo: {dese.Tipo}).\nDetalle: {detResp?.Mensaje ?? "Sin detalle del servidor."}",
                            SweetAlertIcon.Error);
                        return;
                    }
                }
                catch (Exception ex)
                {
                    Log($"Excepción creando detalle | HBA={Q(dese.Hardb)} | tipo={Q(dese.Tipo)} | ex={ex.Message}");
                    await Swal.FireAsync("Error al crear detalle",
                        $"Falló la creación de un detalle (HBA: {dese.Hardb}, Tipo: {dese.Tipo}).\nDetalle: {ex.Message}",
                        SweetAlertIcon.Error);
                    return;
                }
            }
            Log($"Detalles creados: {seleccionFinal.Count}");

            Navigation.NavigateTo("/declaraciones");
            return;
        }
        else
        {
            Log("Flujo guardar: EDITAR");
            // Editar: borro viejos y recreo (como ya tenías)
            var nrodecLower = oDeclaracion.Nrodec.ToLower();
            var filtro = $"(Nrodec == null ? \"\" : Nrodec).ToLower() == \"{nrodecLower}\"";
            var existentes = await _desepla3Servicio.LimitadosFiltrados(0, 0, filtro);
            Log($"Detalles existentes a reemplazar: {existentes?.List?.Count ?? 0}");
            LogDetalleSnapshot("Editar -> detalles existentes antes de borrar", existentes?.List);

            if (existentes?.List != null)
            {
                foreach (var d in existentes.List)
                {
                    try
                    {
                        var okDelete = await _desepla3Servicio.Eliminar(d.Id);
                        if (!okDelete)
                        {
                            Log($"Error eliminando detalle previo | IdDetalle={d.Id}");
                            await Swal.FireAsync("Error al actualizar declaración",
                                $"No se pudo eliminar un detalle previo (Id {d.Id}).",
                                SweetAlertIcon.Error);
                            return;
                        }
                    }
                    catch (Exception ex)
                    {
                        Log($"Excepción eliminando detalle previo | IdDetalle={d.Id} | ex={ex.Message}");
                        await Swal.FireAsync("Error al actualizar declaración",
                            $"Falló la eliminación de un detalle previo (Id {d.Id}).\nDetalle: {ex.Message}",
                            SweetAlertIcon.Error);
                        return;
                    }
                }
            }

            foreach (var dese in seleccionFinal)
            {
                dese.Nrodec = oDeclaracion.Nrodec;
                Log($"Recrear detalle | Nrodec={Q(dese.Nrodec)} | Tipo={Q(dese.Tipo)} | HBA={Q(dese.Hardb)} | Tat={Q(dese.Tatpart)} | Cantv={dese.Cantv} | Desde={Q(dese.Desde)} | Hasta={Q(dese.Hasta)}");
                try
                {
                    var detResp = await _desepla3Servicio.Crear(dese);
                    if (detResp == null || detResp.Exito != 1)
                    {
                        Log($"Error recreando detalle | HBA={Q(dese.Hardb)} | tipo={Q(dese.Tipo)} | mensaje={Q(detResp?.Mensaje)}");
                        await Swal.FireAsync("Error al actualizar declaración",
                            $"No se pudo guardar un detalle (HBA: {dese.Hardb}, Tipo: {dese.Tipo}).\nDetalle: {detResp?.Mensaje ?? "Sin detalle del servidor."}",
                            SweetAlertIcon.Error);
                        return;
                    }
                }
                catch (Exception ex)
                {
                    Log($"Excepción recreando detalle | HBA={Q(dese.Hardb)} | tipo={Q(dese.Tipo)} | ex={ex.Message}");
                    await Swal.FireAsync("Error al actualizar declaración",
                        $"Falló la creación de un detalle (HBA: {dese.Hardb}, Tipo: {dese.Tipo}).\nDetalle: {ex.Message}",
                        SweetAlertIcon.Error);
                    return;
                }
            }

            bool okEdit;
            try
            {
                okEdit = await _desepla1Servicio.Editar(oDeclaracion);
            }
            catch (Exception ex)
            {
                Log($"Excepción editando cabecera | Id={oDeclaracion.Id} | ex={ex.Message}");
                await Swal.FireAsync("Error al actualizar declaración",
                    $"Falló la actualización de la cabecera (Id {oDeclaracion.Id}).\nDetalle: {ex.Message}",
                    SweetAlertIcon.Error);
                return;
            }

            if (!okEdit)
            {
                Log($"Error editando cabecera | Id={oDeclaracion.Id}");
                await Swal.FireAsync("Error al actualizar declaración",
                    $"No se pudo actualizar la cabecera de la declaración (Id {oDeclaracion.Id}).",
                    SweetAlertIcon.Error);
                return;
            }
            Log($"Declaración editada OK | Id={oDeclaracion.Id} | Nrodec={Q(oDeclaracion.Nrodec)} | detallesNuevos={seleccionFinal.Count}");
            Navigation.NavigateTo("/declaraciones");
            return;
        }
    }




