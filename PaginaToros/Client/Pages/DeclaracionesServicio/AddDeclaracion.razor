    protected async Task UpdateValores(SocioDTO socio)
        => await LoadSocioDataAsync(socio, preserveCabecera: _isEdit, refreshUi: true);

    private async Task LoadSocioDataAsync(SocioDTO socio, bool preserveCabecera, bool refreshUi)
    {
        socioSeleccionado = socio;
        isLoadingDependencias = true;
        loadingMessage = "Cargando planteles, toros y certificados...";
        if (refreshUi)
        {
            await InvokeAsync(StateHasChanged);
        }

        var socioScodRaw = socio?.Scod ?? string.Empty;
        var socioScodTrim = T(socio?.Scod);
        Log($"UpdateValores START | socio.Id={socio?.Id} | socio.ScodRaw={Q(socioScodRaw)} | socio.ScodTrim={Q(socioScodTrim)}");

        await ResetForSocioChange(preserveCabecera: preserveCabecera, refreshUi: false, reloadGrids: false);

        var filtro = $"Nrocri == \"{EscapeForFilter(socioScodRaw)}\"";
        Log($"UpdateValores -> Planteles filtro: {filtro}");
        var plantelesTask = _plantelServicio.LimitadosFiltradosNoInclude(0, 0, filtro);

        filtro = $"Criador == \"{EscapeForFilter(socioScodRaw)}\"";
        Log($"UpdateValores -> Toros filtro: {filtro}");
        var torosTask = _torosServicio.LimitadosFiltradosNoInclude(0, 0, filtro);

        filtro = $"Nrocri == \"{EscapeForFilter(socioScodRaw)}\"";
        Log($"UpdateValores -> Certificados filtro: {filtro}");
        var certificadosTask = _certifsemanServicio.LimitadosFiltradosNoInclude(0, 0, filtro);

        await Task.WhenAll(plantelesTask, torosTask, certificadosTask);

        var rt = await plantelesTask;
        Planteles = rt.List ?? new List<PlantelDTO>();
        Log($"Planteles cargados: {Planteles?.Count ?? 0}");
        if ((Planteles?.Count ?? 0) == 0 && !string.IsNullOrWhiteSpace(socioScodTrim))
        {
            var filtroDiag = $"(Nrocri == null ? \"\" : Nrocri).ToLower().Contains(\"{EscapeForFilter(socioScodTrim.ToLower())}\")";
            var rtDiag = await _plantelServicio.LimitadosFiltradosNoInclude(0, 20, filtroDiag);
            Planteles = (rtDiag?.List ?? new List<PlantelDTO>())
                .Where(x => T(x.Nrocri).Equals(socioScodTrim, StringComparison.OrdinalIgnoreCase))
                .ToList();
            Log($"Diag Planteles (contains scod trim) -> {rtDiag?.List?.Count ?? 0} resultados crudos | filtradosExactos={Planteles.Count} | filtro={filtroDiag}");
        }

        var rta = await torosTask;
        toros = rta.List ?? new List<TorosuniDTO>();
        Log($"Toros cargados: {toros?.Count ?? 0}");
        if ((toros?.Count ?? 0) == 0 && !string.IsNullOrWhiteSpace(socioScodTrim))
        {
            var filtroDiag = $"(Criador == null ? \"\" : Criador).ToLower().Contains(\"{EscapeForFilter(socioScodTrim.ToLower())}\")";
            var rtDiag = await _torosServicio.LimitadosFiltradosNoInclude(0, 20, filtroDiag);
            toros = (rtDiag?.List ?? new List<TorosuniDTO>())
                .Where(x => T(x.Criador).Equals(socioScodTrim, StringComparison.OrdinalIgnoreCase))
                .ToList();
            Log($"Diag Toros (contains scod trim) -> {rtDiag?.List?.Count ?? 0} resultados crudos | filtradosExactos={toros.Count} | filtro={filtroDiag}");
        }
        if ((toros?.Count ?? 0) > 0)
        {
            var criadores = toros.Select(t => t.Criador).Where(c => !string.IsNullOrWhiteSpace(c)).Distinct().Take(5);
            Log($"Toros criadores (muestra): {string.Join(" | ", criadores.Select(Q))}");
        }

        var rtaa = await certificadosTask;
        certificados = rtaa.List ?? new List<CertifsemanDTO>();
        Log($"Certificados cargados: {certificados?.Count ?? 0}");
        if ((certificados?.Count ?? 0) == 0 && !string.IsNullOrWhiteSpace(socioScodTrim))
        {
            var filtroDiag = $"(Nrocri == null ? \"\" : Nrocri).ToLower().Contains(\"{EscapeForFilter(socioScodTrim.ToLower())}\")";
            var rtDiag = await _certifsemanServicio.LimitadosFiltradosNoInclude(0, 20, filtroDiag);
            certificados = (rtDiag?.List ?? new List<CertifsemanDTO>())
                .Where(x => T(x.Nrocri).Equals(socioScodTrim, StringComparison.OrdinalIgnoreCase))
                .ToList();
            Log($"Diag Certificados (contains scod trim) -> {rtDiag?.List?.Count ?? 0} resultados crudos | filtradosExactos={certificados.Count} | filtro={filtroDiag}");
        }
        if ((certificados?.Count ?? 0) > 0)
        {
            var nrocris = certificados.Select(c => c.Nrocri).Where(n => !string.IsNullOrWhiteSpace(n)).Distinct().Take(5);
            Log($"Certificados Nrocri (muestra): {string.Join(" | ", nrocris.Select(Q))}");
        }

        isLoadingDependencias = false;
        if (refreshUi)
        {
            await InvokeAsync(StateHasChanged);
        }
        Log($"UpdateValores END | Planteles={Planteles?.Count ?? 0} | Toros={toros?.Count ?? 0} | Certifs={certificados?.Count ?? 0}");
    }




    private async Task ResetForSocioChange(bool preserveCabecera = false, bool refreshUi = true, bool reloadGrids = true)
    {
        Log($"ResetForSocioChange START | preserveCabecera={preserveCabecera}");
        torosSeleccionados.Clear();
        certificadosSeleccionados.Clear();
        seleccionFinal.Clear();
        deseplasViejos.Clear();

        Plantelseleccionado = null;

        if (!preserveCabecera)
        {
            tipoTemp = string.Empty;
            oDeclaracion.Cantv = 0;
            oDeclaracion.Cantb = 0;
            oDeclaracion.Desde = DateTime.Now;
            oDeclaracion.Hasta = DateTime.Now;
        }

        if (reloadGrids)
        {
            try { if (gridToro1 != null) await gridToro1.Reload(); } catch { }
            try { if (gridToro2 != null) await gridToro2.Reload(); } catch { }
            try { if (gridCertif != null) await gridCertif.Reload(); } catch { }
        }

        if (refreshUi)
        {
            await InvokeAsync(StateHasChanged);
        }
        Log("ResetForSocioChange END");
    }








