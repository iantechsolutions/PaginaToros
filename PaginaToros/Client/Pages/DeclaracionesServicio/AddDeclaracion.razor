    protected async Task UpdateValores(SocioDTO socio)
    {
        socioSeleccionado = socio;
        var socioScodRaw = socio?.Scod ?? string.Empty;
        var socioScodTrim = T(socio?.Scod);
        Log($"UpdateValores START | socio.Id={socio?.Id} | socio.ScodRaw={Q(socioScodRaw)} | socio.ScodTrim={Q(socioScodTrim)}");

        // si estoy editando, no quiero que me borre tipo/cantidades/fechas
        await ResetForSocioChange(preserveCabecera: _isEdit);

        var filtro = $"Nrocri == \"{EscapeForFilter(socioScodRaw)}\"";
        Log($"UpdateValores -> Planteles filtro: {filtro}");
        var rt = await _plantelServicio.LimitadosFiltradosNoInclude(0, 0, filtro);
        Planteles = rt.List;
        Log($"Planteles cargados: {Planteles?.Count ?? 0}");
        if ((Planteles?.Count ?? 0) == 0 && !string.IsNullOrWhiteSpace(socioScodTrim))
        {
            var filtroDiag = $"(Nrocri == null ? \"\" : Nrocri).ToLower().Contains(\"{EscapeForFilter(socioScodTrim.ToLower())}\")";
            var rtDiag = await _plantelServicio.LimitadosFiltradosNoInclude(0, 20, filtroDiag);
            Log($"Diag Planteles (contains scod trim) -> {rtDiag?.List?.Count ?? 0} resultados | filtro={filtroDiag}");
        }

        filtro = $"Criador == \"{EscapeForFilter(socioScodRaw)}\"";
        Log($"UpdateValores -> Toros filtro: {filtro}");
        var rta = await _torosServicio.LimitadosFiltradosNoInclude(0, 0, filtro);
        toros = rta.List;
        Log($"Toros cargados: {toros?.Count ?? 0}");
        if ((toros?.Count ?? 0) == 0 && !string.IsNullOrWhiteSpace(socioScodTrim))
        {
            var filtroDiag = $"(Criador == null ? \"\" : Criador).ToLower().Contains(\"{EscapeForFilter(socioScodTrim.ToLower())}\")";
            var rtDiag = await _torosServicio.LimitadosFiltradosNoInclude(0, 20, filtroDiag);
            Log($"Diag Toros (contains scod trim) -> {rtDiag?.List?.Count ?? 0} resultados | filtro={filtroDiag}");
        }
        if ((toros?.Count ?? 0) > 0)
        {
            var criadores = toros.Select(t => t.Criador).Where(c => !string.IsNullOrWhiteSpace(c)).Distinct().Take(5);
            Log($"Toros criadores (muestra): {string.Join(" | ", criadores.Select(Q))}");
        }

        filtro = $"Nrocri == \"{EscapeForFilter(socioScodRaw)}\"";
        Log($"UpdateValores -> Certificados filtro: {filtro}");
        var rtaa = await _certifsemanServicio.LimitadosFiltradosNoInclude(0, 0, filtro);
        certificados = rtaa.List;
        Log($"Certificados cargados: {certificados?.Count ?? 0}");
        if ((certificados?.Count ?? 0) == 0 && !string.IsNullOrWhiteSpace(socioScodTrim))
        {
            var filtroDiag = $"(Nrocri == null ? \"\" : Nrocri).ToLower().Contains(\"{EscapeForFilter(socioScodTrim.ToLower())}\")";
            var rtDiag = await _certifsemanServicio.LimitadosFiltradosNoInclude(0, 20, filtroDiag);
            Log($"Diag Certificados (contains scod trim) -> {rtDiag?.List?.Count ?? 0} resultados | filtro={filtroDiag}");
        }
        if ((certificados?.Count ?? 0) > 0)
        {
            var nrocris = certificados.Select(c => c.Nrocri).Where(n => !string.IsNullOrWhiteSpace(n)).Distinct().Take(5);
            Log($"Certificados Nrocri (muestra): {string.Join(" | ", nrocris.Select(Q))}");
        }

        StateHasChanged();
        Log($"UpdateValores END | Planteles={Planteles?.Count ?? 0} | Toros={toros?.Count ?? 0} | Certifs={certificados?.Count ?? 0}");
    }




