    private async Task<IEnumerable<SocioDTO>> BusquedaSocios(string searchText)
    {
        return await Task.FromResult(socios.Where(x => x.Criador == "S" && x.Nombre.ToLower().Contains(searchText.ToLower())).ToList());
    }
    private async Task<IEnumerable<PlantelDTO>> BusquedaPlanteles(string searchText)
    {
        var socioScod = socioSeleccionado?.Scod;
        var result = Planteles
            .Where(x => T(x.Nrocri).Equals(T(socioScod), StringComparison.OrdinalIgnoreCase)
                && (x.Placod ?? string.Empty).ToLower().Contains((searchText ?? string.Empty).ToLower()))
            .ToList();
        Log($"BusquedaPlanteles | search={Q(searchText)} | socioScod={Q(socioScod)} | resultados={result.Count}");
        return await Task.FromResult(result);
    }

    private async Task<IEnumerable<TorosuniDTO>> BusquedaToros(string searchText)
    {
        var term = (searchText ?? string.Empty).Trim().ToLower();
        var socioScod = T(socioSeleccionado?.Scod);

        var baseQuery = toros
            .Where(x => T(x.Criador).Equals(socioScod, StringComparison.OrdinalIgnoreCase))
            .Where(x => x.CodEstado == "1")
            .Where(x => !IsToroSelected(x));

        if (!string.IsNullOrWhiteSpace(term))
        {
            baseQuery = baseQuery.Where(x =>
                (x.NomDad ?? string.Empty).ToLower().Contains(term)
                || (x.Hba ?? string.Empty).ToLower().Contains(term)
                || (x.Tatpart ?? string.Empty).ToLower().Contains(term));
        }

        return await Task.FromResult(baseQuery.Take(30).ToList());
    }

    private async Task<IEnumerable<CertifsemanDTO>> BusquedaCertificados(string searchText)
    {
        var term = (searchText ?? string.Empty).Trim().ToLower();
        var socioScod = T(socioSeleccionado?.Scod);

        var baseQuery = certificados
            .Where(x => T(x.Nrocri).Equals(socioScod, StringComparison.OrdinalIgnoreCase))
            .Where(x => (x.NrDosi ?? 0) > 0)
            .Where(x => !IsCertifSelected(x));

        if (!string.IsNullOrWhiteSpace(term))
        {
            baseQuery = baseQuery.Where(x =>
                (x.NomDad ?? string.Empty).ToLower().Contains(term)
                || (x.Hba ?? string.Empty).ToLower().Contains(term)
                || (x.Tatpart ?? string.Empty).ToLower().Contains(term));
        }

        return await Task.FromResult(baseQuery.Take(30).ToList());
    }

