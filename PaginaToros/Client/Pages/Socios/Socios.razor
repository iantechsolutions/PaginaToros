@page "/socios"
@inject ISocioServicio _socioServicio

<style>
    .socios-page {
        width: 100%;
        margin: 0 auto 2rem;
        color: #172033;
    }

    .socios-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin: 1rem 0;
        width: 93.5%;
        margin-left: 3.33%;
    }

    .socios-title {
        margin: 0;
        font-size: 1.55rem;
        font-weight: 700;
    }

    .socios-description {
        margin: .25rem 0 0;
        color: #64748b;
    }

    .socios-card {
        width: 93.5%;
        margin-left: 3.33%;
        border: 1px solid #dbe3cf;
        border-radius: 8px;
        background: #fffdf8;
        box-shadow: 0 8px 18px rgba(76, 59, 32, .06);
    }

    .socios-filter-card {
        padding: .75rem;
        margin-bottom: .85rem;
    }

    .socios-toolbar {
        display: flex;
        gap: .75rem;
        align-items: center;
        justify-content: space-between;
        flex-wrap: nowrap;
    }

    .socios-toolbar-search {
        flex: 1 1 auto;
        min-width: 0;
    }

    .tablacontent {
        position: relative;
        overflow: hidden;
        border-radius: 8px;
    }

    .tablacontent .rz-datatable-tablewrapper,
    .tablacontent.rz-data-grid .rz-datatable-tablewrapper {
        border-radius: 8px 8px 0 0 !important;
    }

    .tablacontent .rz-cell-data,
    .tablacontent .rz-column-title-content {
        font-size: 11.2px !important;
    }

    .tablacontent .rz-cell-data {
        overflow: hidden !important;
        text-overflow: ellipsis;
        white-space: nowrap !important;
    }

    .tablacontent th.rz-unselectable-text.rz-text-align-left {
        background-color: #f1f5f9;
        color: #334155;
        position: sticky;
        top: 0;
        z-index: 2;
    }

    .tablacontent .rz-grid-table td,
    .tablacontent .rz-grid-table th {
        padding-left: .42rem !important;
        padding-right: .42rem !important;
    }

    .tablacontent .rz-grid-table thead th,
    .tablacontent th.rz-unselectable-text.rz-text-align-left {
        padding-top: .75rem !important;
        padding-bottom: .75rem !important;
    }

    .rz-paginator {
        border-top: solid #e2e8f0 1px;
    }

    .empty-state {
        padding: 3rem 1rem;
        text-align: center;
        color: #475569;
        border: 1px dashed #cbd5e1;
        border-radius: 8px;
        background: #f8fafc;
    }

    .table-action {
        width: 1.75rem;
        height: 1.75rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        background: #fff;
    }

    @@media (min-width: 1200px) {
        .socios-page {
            width: calc(100vw - 20.75rem);
            max-width: none;
            margin-left: calc((100% - (100vw - 20.75rem)) / 2);
            margin-right: 0;
        }
    }

    @@media (max-width: 980px) {
        .socios-header {
            flex-direction: column;
            align-items: stretch;
        }

        .socios-toolbar {
            flex-wrap: wrap;
            flex-direction: column;
        }

        .socios-toolbar-search {
            min-width: 0;
        }
    }
</style>

<div class="socios-page">
    <AuthorizeView Roles="ADMINISTRADOR,USUARIOMAESTRO,Socio">
        <Authorized>
            <div class="socios-header">
                <div>
                    <h3 class="socios-title">Socios</h3>
                    <p class="socios-description">Buscá por nombre, apellido, razón social o por los usuarios asociados a cada socio.</p>
                </div>

                @if (CanUseAdminControls)
                {
                    <button class="font-bold px-4 py-3 rounded-2xl bg-gray-200 hover:bg-gray-300 hover:border-transparent transition ease-in duration-100 transform hover:-translate-y-1 active:translate-y-0"
                            @onclick="() => AddAsync(0, string.Empty)">
                        Agregar Socio
                    </button>
                }
            </div>

            <div class="socios-card socios-filter-card">
                <div class="socios-toolbar">
                    <div class="socios-toolbar-search">
                        <SearchInput Value="@searchText"
                                     ValueChanged="OnSearchChanged"
                                     IsLoading="@searchLoading"
                                     Placeholder="Buscar por nombre, apellido, razón social, mail o código" />
                    </div>
                </div>
            </div>

            <div class="socios-card tablacontent">
                <RadzenDataGrid class="tablacontent"
                                @ref="grid"
                                TItem="SocioDTO"
                                Data="@items"
                                Count="@cantidad"
                                LoadData="LoadData"
                                IsLoading="@isLoading"
                                AllowFiltering="false"
                                AllowColumnResize="true"
                                AllowSorting="false"
                                AllowPaging="true"
                                ShowPagingSummary="true"
                                PageSize="15"
                                Density="Density.Compact"
                                ColumnWidth="3.33%"
                                PagerHorizontalAlign="HorizontalAlign.Center">
                    <EmptyTemplate>
                        <div class="empty-state">
                            No hay socios para la búsqueda seleccionada.
                        </div>
                    </EmptyTemplate>
                    <Columns>
                        <RadzenDataGridColumn TItem="SocioDTO" Property="Codpos2" Title="Nro Socio" Width="3.6%">
                            <Template Context="data">
                                @data.CodigoVisible()
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="SocioDTO" Property="Placod" Title="Plantel" Width="3%" />
                        <RadzenDataGridColumn TItem="SocioDTO" Property="Criador" Title="Activo?" Width="3.33%">
                            <Template Context="data">
                                @if (data.Criador == "S")
                                {
                                    <a style="color:green">Si</a>
                                }
                                else
                                {
                                    <a style="color:red">No</a>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="SocioDTO" Property="Nombre" Title="Nombre" Width="9.3%" />
                        <RadzenDataGridColumn TItem="SocioDTO" Property="Direcc1" Title="Domicilio" Width="5.6%" />
                        <RadzenDataGridColumn TItem="SocioDTO" Property="Locali1" Title="Localidad" Width="6.6%" />
                        <RadzenDataGridColumn TItem="SocioDTO" Property="Codpos1" Title="Cod. Postal" Width="4.3%" />
                        <RadzenDataGridColumn TItem="SocioDTO" Property="Provincia.Nombre" Title="Provincia" Width="5%" />
                        <RadzenDataGridColumn TItem="SocioDTO" Property="Telefo1" Title="Telefono" Width="5%" />
                        <RadzenDataGridColumn TItem="SocioDTO" Property="Mail" Title="Mail" Width="6.6%" />
                        <RadzenDataGridColumn TItem="SocioDTO" Property="FechaExistencia" Title="Fecha de Creacion" Width="6.6%">
                            <Template Context="data">
                                @if (data.Fecing.HasValue)
                                {
                                    @data.Fecing.Value.ToString("dd/MM/yyyy")
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        @if (CanUseAdminControls)
                        {
                            <RadzenDataGridColumn TItem="SocioDTO" Title="" Filterable="false" Sortable="false" Width="3%">
                                <Template Context="data">
                                    <button class="table-action" title="Editar Socio" @onclick="() => AddAsync(data.Id, data.Scod)">
                                        <FeatherEdit Size="16" Color="green" />
                                    </button>
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="SocioDTO" Title="" Filterable="false" Sortable="false" Width="3%">
                                <Template Context="data">
                                    <button class="table-action" title="Eliminar" @onclick="() => AlertDelete(data.Id, data.Scod)">
                                        <FeatherTrash2 Size="16" Color="red" />
                                    </button>
                                </Template>
                            </RadzenDataGridColumn>
                        }
                        <RadzenDataGridColumn TItem="SocioDTO" Title="" Filterable="false" Sortable="false" Width="3%">
                            <Template Context="data">
                                <button class="table-action" title="Ver info" @onclick="() => GoToInfoAsync(data.Id, data.Scod)">
                                    <FeatherInfo Size="16" Color="blue" />
                                </button>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </div>
        </Authorized>
    </AuthorizeView>
</div>

@code {
    [CascadingParameter] public IModalService Modal { get; set; } = default!;

    private RadzenDataGrid<SocioDTO>? grid;
    private List<SocioDTO> items = new();
    private bool canUseAdminControls;
    private bool isLoading;
    private bool initialGridLoadTriggered;
    private bool searchLoading;
    private int cantidad;
    private int currentPage;
    private string searchText = string.Empty;
    private int loadRequestVersion;

    private bool CanUseAdminControls => canUseAdminControls;

    protected override async Task OnInitializedAsync()
    {
        canUseAdminControls = await UserHasAnyRoleAsync("ADMINISTRADOR", "USUARIOMAESTRO");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || initialGridLoadTriggered || grid == null)
        {
            return;
        }

        initialGridLoadTriggered = true;
        await grid.Reload();
    }

    private async Task LoadData(LoadDataArgs args)
    {
        var requestId = ++loadRequestVersion;
        isLoading = true;
        StateHasChanged();

        try
        {
            currentPage = grid?.CurrentPage ?? 0;
            var response = await _socioServicio.SearchPaged(args.Skip ?? 0, args.Top ?? 15, searchText);

            if (requestId != loadRequestVersion)
            {
                return;
            }

            items = response.List?.Items ?? new List<SocioDTO>();
            cantidad = response.List?.TotalCount ?? 0;
        }
        catch (Exception ex)
        {
            items = new List<SocioDTO>();
            cantidad = 0;
            await Swal.FireAsync(new SweetAlertOptions
            {
                Title = "Error",
                Text = ex.Message,
                Icon = SweetAlertIcon.Error,
                ConfirmButtonText = "Aceptar"
            });
        }
        finally
        {
            if (requestId == loadRequestVersion)
            {
                isLoading = false;
                searchLoading = false;
                StateHasChanged();
            }
        }
    }

    private async Task<bool> UserHasAnyRoleAsync(params string[] roles)
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        return roles.Any(authenticationState.User.IsInRole);
    }

    private async Task OnSearchChanged(string value)
    {
        searchLoading = true;
        searchText = value ?? string.Empty;
        await ReloadGridFromStartAsync();
    }

    private async Task ReloadGridFromStartAsync()
    {
        if (grid != null)
        {
            if (grid.CurrentPage > 0)
            {
                await grid.FirstPage(true);
            }
            else
            {
                await grid.Reload();
            }
        }
    }

    private async Task AddAsync(int id, string cod)
    {
        if (id != 0)
        {
            currentPage = grid?.CurrentPage ?? 0;
        }

        var parameters = new ModalParameters();
        parameters.Add(nameof(AddSocio.Id), id);
        parameters.Add(nameof(AddSocio.cod), cod);

        var options = new ModalOptions
        {
            Size = ModalSize.ExtraLarge,
            DisableBackgroundCancel = true
        };

        var formModal = Modal.Show<AddSocio>(id == 0 ? "Agregar Socio" : "Editar Socio", parameters, options);
        var result = await formModal.Result;

        if (result.Cancelled)
        {
            if (grid != null)
            {
                await grid.GoToPage(currentPage);
            }

            return;
        }

        if (grid != null)
        {
            await grid.Reload();
            await grid.GoToPage(currentPage);
        }
    }

    private async Task AlertDelete(int id, string cod)
    {
        SweetAlertResult result = await Swal.FireAsync(new SweetAlertOptions
        {
            Title = "¿Está seguro?",
            Text = "Se eliminará al socio y todo lo relacionado al mismo",
            Icon = SweetAlertIcon.Warning,
            ShowCancelButton = true,
            ConfirmButtonText = "Eliminar",
            CancelButtonText = "Cancelar"
        });

        if (!string.IsNullOrEmpty(result.Value))
        {
            await DeleteAsync(id, cod);
        }
    }

    private async Task DeleteAsync(int id, string cod)
    {
        currentPage = grid?.CurrentPage ?? 0;
        var response = await _socioServicio.Eliminar(id);
        if (!response || grid == null)
        {
            return;
        }

        await grid.Reload();

        if (items.Count == 0 && currentPage > 0)
        {
            await grid.GoToPage(currentPage - 1);
        }
        else
        {
            await grid.GoToPage(currentPage);
        }
    }

    private async Task GoToInfoAsync(int id, string cod)
    {
        currentPage = grid?.CurrentPage ?? 0;

        var parameters = new ModalParameters();
        parameters.Add(nameof(InfoSocio.Id), id);
        parameters.Add(nameof(InfoSocio.Cod), cod);

        var options = new ModalOptions
        {
            HideHeader = true,
            HideCloseButton = true,
            Size = ModalSize.ExtraLarge
        };

        var formModal = Modal.Show<InfoSocio>(string.Empty, parameters, options);
        var result = await formModal.Result;

        if (grid == null)
        {
            return;
        }

        if (result.Cancelled)
        {
            await grid.GoToPage(currentPage);
            return;
        }

        await grid.Reload();
        await grid.GoToPage(currentPage);
    }
}
