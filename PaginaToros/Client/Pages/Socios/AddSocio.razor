@using Blazored.Typeahead
@using System.Net.Http.Json
@using PaginaToros.Client.Servicios.Contrato
@using PaginaToros.Shared.Models.Response

@inject HttpClient http
@inject ISocioServicio _socioServicio

<style>
    .bm-title {
        font-size: 25px;
        font-weight: bold;
    }
</style>

<div class="card">
    <div class="card-body">
        @if (!string.IsNullOrWhiteSpace(formMessage))
        {
            <div class="@formMessageCss" role="alert">
                @formMessage
            </div>
        }

        @if (validationErrors.Count > 0)
        {
            <div class="alert alert-danger" role="alert">
                <strong>Revisá estos datos:</strong>
                <ul class="mb-0 mt-2">
                    @foreach (var error in validationErrors)
                    {
                        <li>@error</li>
                    }
                </ul>
            </div>
        }

        <EditForm Model="@oSocio" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="row">
                <AuthorizeView Roles="ADMINISTRADOR,USUARIOMAESTRO">
                    <Authorized Context="adminContext">
                        <div class="col-sm">
                            <label>Nombre Completo *</label>
                            <InputText class="form-control" @bind-Value="oSocio.Nombre" placeholder="Nombre" />
                        </div>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="Socio">
                    <Authorized Context="socioContext">
                        <div class="col-sm">
                            <label>Código de Socio</label>
                            <input class="form-control" value="@oSocio.CodigoVisible()" placeholder="Codigo" disabled />
                        </div>
                        <div class="col-sm">
                            <label>Nombre Completo *</label>
                            <InputText class="form-control" @bind-Value="oSocio.Nombre" placeholder="Nombre" />
                        </div>
                    </Authorized>
                </AuthorizeView>

                <div class="col-sm">
                    <label>Domicilio *</label>
                    <InputText @bind-Value="oSocio.Direcc1" class="form-control" placeholder="Domicilio" />
                </div>

                <div class="col-sm">
                    <label>Localidad *</label>
                    <InputText @bind-Value="oSocio.Locali1" class="form-control" placeholder="Localidad" />
                </div>
            </div>

            <br />

            <div class="row">
                <div class="col-sm">
                    <label>Código Postal *</label>
                    <InputText class="form-control" @bind-Value="oSocio.Codpos1" placeholder="Cod. Postal" />
                </div>

                <div class="col-sm">
                    <label>Provincia *</label>
                    <BlazoredTypeahead SearchMethod="@(text => SearchMethod(text, provincias))"
                                       placeholder="Busca por nombre"
                                       EnableDropDown="true"
                                       @bind-Value="tempProvincia">
                        <SelectedTemplate Context="eleccion">
                            @eleccion
                        </SelectedTemplate>
                        <ResultTemplate Context="eleccion">
                            @eleccion
                        </ResultTemplate>
                    </BlazoredTypeahead>
                </div>

                <div class="col-sm">
                    <label>Telefono *</label>
                    <InputText @bind-Value="oSocio.Telefo1" class="form-control" placeholder="Telefono" />
                </div>
            </div>

            <br />

            <div class="row">
                <div class="col-sm">
                    <label>2do Telefono</label>
                    <InputText class="form-control" @bind-Value="oSocio.Telefo2" placeholder="2do telefono" />
                </div>

                <div class="col-sm">
                    <label>Mail *</label>
                    <InputText class="form-control" @bind-Value="oSocio.Mail" placeholder="Mail" />
                </div>

                <div class="col-sm">
                    <label>Codigo de socio *</label>
                    <InputText class="form-control" @bind-Value="oSocio.Codpos2" placeholder="Codigo de socio" maxlength="4" />
                </div>

                <AuthorizeView Roles="ADMINISTRADOR,USUARIOMAESTRO">
                    <Authorized Context="mailContext">
                        <div class="col-sm d-flex align-items-end">
                            @if (Id != 0)
                            {
                                <button type="button"
                                        class="font-bold px-4 py-3 rounded-2xl bg-gray-200 hover:bg-gray-300 hover:border-transparent transition ease-in duration-100 transform hover:-translate-y-1 active:translate-y-0"
                                        @onclick="ChangeEmail"
                                        disabled="@isBusy">
                                    Enviar mail de inscripción
                                </button>
                            }
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>

            <br />

            <div class="row">
                <div class="col-sm">
                    <label>Fecha de Ingreso *</label><br />
                    <RadzenDatePicker TValue="DateTime"
                                      @bind-Value="FechaTemp"
                                      ShowTime="false"
                                      ShowSeconds="false"
                                      DateFormat="dd/MM/yyyy"
                                      Class="w-75" />
                </div>

                <div class="col-sm">
                    <label>Plantel *</label>
                    <InputText class="form-control" @bind-Value="oSocio.Placod" placeholder="Plantel" maxlength="4" />
                </div>

                <div class="col-sm">
                    <label>Activo?</label><br />
                    <input type="checkbox" @bind="activo">
                </div>
            </div>

            <br />
            <br />

            <button type="submit" class="btn btn-primary mr-2" disabled="@isBusy">Aceptar</button>
            <button type="button" @onclick="Cancel" class="btn btn-light" disabled="@isBusy">Cancelar</button>
        </EditForm>
    </div>
</div>

@code {
    private readonly List<string> provincias = new()
    {
        "Buenos Aires", "Capital Federal", "Catamarca", "Chaco", "Chubut", "Cordoba", "Corrientes", "Entre Rios", "Formosa",
        "Jujuy", "La pampa", "La rioja", "Mendoza", "Misiones", "Neuquen", "Rio negro", "Salta", "San Juan", "San Luis", "Santa Cruz", "Santa Fe",
        "Santiago Del Estero", "Tierra del fuego", "Tucuman"
    };

    private readonly Dictionary<string, string> traductorProvincia = new()
    {
        { "Chaco", "01" }, { "Corrientes", "02" }, { "Entre Rios", "03" }, { "Santa Fe", "04" }, { "Cordoba", "05" },
        { "La pampa", "06" }, { "San Luis", "07" }, { "Santa Cruz", "08" }, { "Tierra del fuego", "09" }, { "Chubut", "10" },
        { "Neuquen", "11" }, { "Rio negro", "12" }, { "Buenos Aires", "13" }, { "Capital Federal", "14" }, { "Catamarca", "15" },
        { "Formosa", "16" }, { "Jujuy", "17" }, { "La rioja", "18" }, { "Mendoza", "19" }, { "Misiones", "20" },
        { "Salta", "21" }, { "San Juan", "22" }, { "Santiago Del Estero", "23" }, { "Tucuman", "24" }, { "", "" }
    };

    private readonly Dictionary<string, string> traductorProvinciaInverso = new()
    {
        { "01", "Chaco" }, { "02", "Corrientes" }, { "03", "Entre Rios" }, { "04", "Santa Fe" }, { "05", "Cordoba" },
        { "06", "La pampa" }, { "07", "San Luis" }, { "08", "Santa Cruz" }, { "09", "Tierra del fuego" }, { "10", "Chubut" },
        { "11", "Neuquen" }, { "12", "Rio negro" }, { "13", "Buenos Aires" }, { "14", "Capital Federal" }, { "15", "Catamarca" },
        { "16", "Formosa" }, { "17", "Jujuy" }, { "18", "La rioja" }, { "19", "Mendoza" }, { "20", "Misiones" },
        { "21", "Salta" }, { "22", "San Juan" }, { "23", "Santiago Del Estero" }, { "24", "Tucuman" }, { "", "" }
    };

    private SocioDTO oSocio = new();
    private List<SocioDTO> socios = new();
    private readonly List<string> validationErrors = new();
    private bool activo = true;
    private bool isBusy;
    private string? formMessage;
    private string formMessageCss = "alert alert-danger";

    [CascadingParameter] private BlazoredModalInstance ModalInstance { get; set; } = default!;
    [CascadingParameter] public IModalService Modal { get; set; } = default!;

    [Parameter] public int Id { get; set; }
    [Parameter] public string cod { get; set; } = string.Empty;

    private DateTime FechaTemp = DateTime.Now.Date;
    private string tempProvincia = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var rta = await _socioServicio.LimitadosFiltrados(0, 0);
        socios = rta.List?.Where(x => x.Id != Id).ToList() ?? new List<SocioDTO>();

        if (Id != 0)
        {
            var c = await _socioServicio.LimitadosFiltrados(0, 1, $"Id = {Id}");
            oSocio = c.List?.FirstOrDefault() ?? new SocioDTO();
            activo = oSocio.Criador == "S";
            FechaTemp = oSocio.Fecing ?? DateTime.Now.Date;

            if (!string.IsNullOrEmpty(oSocio.Codpro1))
            {
                tempProvincia = traductorProvinciaInverso.TryGetValue(oSocio.Codpro1, out var provincia) ? provincia : string.Empty;
            }
        }
        else
        {
            var max = socios.Select(s => int.TryParse(s.Scod, out var v) ? v : 0).DefaultIfEmpty(0).Max();
            oSocio.Scod = (max + 1).ToString("D4");
        }
    }

    private async Task Guardar()
    {
        if (isBusy)
        {
            return;
        }

        ClearMessages();

        if (!await ValidateFormAsync())
        {
            return;
        }

        isBusy = true;

        try
        {
            var response = await SaveSocioAsync();
            if (response.Exito != 1)
            {
                SetFormError(response.Mensaje ?? "No se pudo guardar el socio.");
                return;
            }

            await ModalInstance.CloseAsync(ModalResult.Ok("Socio guardado."));
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ChangeEmail()
    {
        if (isBusy)
        {
            return;
        }

        ClearMessages();

        if (!await ValidateFormAsync())
        {
            return;
        }

        var confirm = await Swal.FireAsync(new SweetAlertOptions
        {
            Title = "Confirmación",
            Text = "Se van a guardar los datos del socio y enviar el mail de inscripción. ¿Desea continuar?",
            Icon = SweetAlertIcon.Warning,
            ShowCancelButton = true,
            ConfirmButtonText = "Sí, enviar",
            CancelButtonText = "Cancelar"
        });

        if (!confirm.IsConfirmed)
        {
            return;
        }

        isBusy = true;
        var wait = Modal.Show<ModalWait>("", SharedModalOptions.modalOptionsWait);

        try
        {
            PrepareSocioForSave();

            var response = await _socioServicio.GuardarYEnviarInscripcion(new SocioRegistrationRequest
            {
                Socio = oSocio
            });

            if (response.Exito != 1)
            {
                ShowBackendErrors(response);
                return;
            }

            formMessageCss = "alert alert-success";
            formMessage = response.List?.MensajeUsuario ?? "Se envió el mail de inscripción correctamente.";
            await Swal.FireAsync(new SweetAlertOptions
            {
                Title = "Éxito",
                Text = formMessage,
                Icon = SweetAlertIcon.Success,
                ConfirmButtonText = "Aceptar"
            });

            await ModalInstance.CloseAsync(ModalResult.Ok("Mail de inscripción enviado."));
        }
        finally
        {
            wait.Close();
            isBusy = false;
        }
    }

    private async Task<Respuesta<SocioDTO>> SaveSocioAsync()
    {
        PrepareSocioForSave();

        if (Id == 0)
        {
            var createResponse = await _socioServicio.Crear(oSocio);
            return createResponse ?? new Respuesta<SocioDTO> { Exito = 0, Mensaje = "No se pudo guardar el socio." };
        }

        var httpResponse = await http.PutAsJsonAsync("api/Socio/Editar", oSocio);
        var dto = await httpResponse.Content.ReadFromJsonAsync<Respuesta<SocioDTO>>();
        return dto ?? new Respuesta<SocioDTO> { Exito = 0, Mensaje = "No se pudo guardar el socio." };
    }

    private void PrepareSocioForSave()
    {
        oSocio.Nombre = oSocio.Nombre?.Trim();
        oSocio.Direcc1 = oSocio.Direcc1?.Trim();
        oSocio.Locali1 = oSocio.Locali1?.Trim();
        oSocio.Codpos1 = oSocio.Codpos1?.Trim();
        oSocio.Telefo1 = oSocio.Telefo1?.Trim();
        oSocio.Telefo2 = oSocio.Telefo2?.Trim();
        oSocio.Mail = oSocio.Mail?.Trim();
        oSocio.Codpos2 = oSocio.Codpos2?.Trim();
        oSocio.Placod = oSocio.Placod?.Trim();
        oSocio.Codpro1 = traductorProvincia.TryGetValue(tempProvincia, out var provincia) ? provincia : string.Empty;
        oSocio.Fecing = FechaTemp;
        oSocio.Criador = activo ? "S" : "N";
    }

    private async Task<bool> ValidateFormAsync()
    {
        PrepareSocioForSave();
        validationErrors.Clear();

        AddIfMissing(oSocio.Nombre, "Completá el nombre completo.");
        AddIfMissing(oSocio.Direcc1, "Completá el domicilio.");
        AddIfMissing(oSocio.Locali1, "Completá la localidad.");
        AddIfMissing(oSocio.Codpos1, "Completá el código postal.");
        AddIfMissing(tempProvincia, "Seleccioná una provincia.");
        AddIfMissing(oSocio.Telefo1, "Completá el teléfono.");
        AddIfMissing(oSocio.Mail, "Completá el mail.");
        AddIfMissing(oSocio.Codpos2, "Completá el código de socio.");
        AddIfMissing(oSocio.Placod, "Completá el plantel.");

        if (FechaTemp == default)
        {
            validationErrors.Add("Completá la fecha de ingreso.");
        }

        if (!string.IsNullOrWhiteSpace(oSocio.Mail))
        {
            try
            {
                var addr = new System.Net.Mail.MailAddress(oSocio.Mail);
                if (!string.Equals(addr.Address, oSocio.Mail, StringComparison.OrdinalIgnoreCase))
                {
                    validationErrors.Add("El formato del mail no es válido.");
                }
            }
            catch
            {
                validationErrors.Add("El formato del mail no es válido.");
            }
        }

        if (!traductorProvincia.TryGetValue(tempProvincia, out var provincia) || string.IsNullOrWhiteSpace(provincia))
        {
            validationErrors.Add("Seleccioná una provincia válida.");
        }

        if (!string.IsNullOrWhiteSpace(oSocio.Codpos2) && oSocio.Codpos2.Length > 4)
        {
            validationErrors.Add("El código de socio no puede tener más de 4 caracteres.");
        }

        return validationErrors.Count == 0;
    }

    private void ShowBackendErrors(Respuesta<SocioRegistrationResult> response)
    {
        validationErrors.Clear();

        if (response.List?.Errores != null && response.List.Errores.Count > 0)
        {
            validationErrors.AddRange(response.List.Errores.Where(x => !string.IsNullOrWhiteSpace(x)));
        }

        if (!string.IsNullOrWhiteSpace(response.List?.MensajeUsuario))
        {
            SetFormError(response.List.MensajeUsuario);
            return;
        }

        SetFormError(response.Mensaje ?? "No se pudo enviar el mail de inscripción.");
    }

    private void AddIfMissing(string? value, string message)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            validationErrors.Add(message);
        }
    }

    private void ClearMessages()
    {
        validationErrors.Clear();
        formMessage = null;
        formMessageCss = "alert alert-danger";
    }

    private void SetFormError(string message)
    {
        formMessageCss = "alert alert-danger";
        formMessage = message;
    }

    private Task<IEnumerable<string>> SearchMethod(string searchText, List<string> lista)
    {
        IEnumerable<string> result = lista.Where(x => x.Contains(searchText, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(result);
    }

    private async Task Cancel()
    {
        await ModalInstance.CancelAsync();
    }
}
