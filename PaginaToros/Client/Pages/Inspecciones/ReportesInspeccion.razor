@page "/reportes"
@using PaginaToros.Shared.Models.Response
@using PaginaToros.Shared.Models
@using PaginaToros.Client.Servicios.Contrato;
@inject IResin1Servicio _resin1Servicio

<style>
    .reportes-page {
        width: 100%;
        margin: 0 auto 2rem;
        color: #172033;
    }

    .reportes-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin: 1rem 0;
        width: 93.5%;
        margin-left: 3.33%;
    }

    .reportes-title {
        margin: 0;
        font-size: 1.55rem;
        font-weight: 700;
    }

    .reportes-description {
        margin: .25rem 0 0;
        color: #64748b;
    }

    .reportes-card {
        width: 93.5%;
        margin-left: 3.33%;
        border: 1px solid #dbe3cf;
        border-radius: 8px;
        background: #fffdf8;
        box-shadow: 0 8px 18px rgba(76, 59, 32, .06);
    }

    .reportes-filter-card {
        padding: .75rem;
        margin-bottom: .85rem;
    }

    .empty-state {
        padding: 3rem 1rem;
        text-align: center;
        color: #475569;
        border: 1px dashed #cbd5e1;
        border-radius: 8px;
        background: #f8fafc;
    }

    .rz-cell-data,
    .rz-column-title-content {
        font-size: 13px !important;
    }

    .rz-cell-data {
        overflow: visible !important;
        white-space: normal !important;
    }

    .tablacontent th.rz-unselectable-text.rz-text-align-left {
        background-color: #82D682;
    }

    .rz-paginator {
        border-top: solid #E0E0E0 1px;
    }
</style>

<div class="reportes-page">
    <AuthorizeView Roles="ADMINISTRADOR,USUARIOMAESTRO,Socio">
        <Authorized Context="reportesUser">
            <div class="reportes-header">
                <div>
                    <h3 class="reportes-title">Reportes de Inspeccion</h3>
                    <p class="reportes-description">Buscá por número, plantel, socio, establecimiento o fecha de creación.</p>
                </div>

                <AuthorizeView Roles="ADMINISTRADOR,USUARIOMAESTRO">
                    <Authorized Context="reportesAdminButton">
                        <button class="font-bold px-4 py-3 rounded-2xl bg-gray-200 hover:bg-gray-300 hover:border-transparent transition ease-in duration-100 transform hover:-translate-y-1 active:translate-y-0"
                                @onclick="() => add(0, 0)">
                            Agregar Nuevo Reporte
                        </button>
                    </Authorized>
                </AuthorizeView>
            </div>

            <div class="reportes-card reportes-filter-card">
                <SearchInput Value="@searchText"
                             ValueChanged="OnSearchChanged"
                             IsLoading="@searchLoading"
                             Placeholder="Buscar por número, plantel, socio, establecimiento o fecha" />
            </div>

            <AuthorizeView Roles="ADMINISTRADOR,USUARIOMAESTRO">
                <Authorized Context="reportesAdminGrid">
                    <div class="reportes-card tablacontent">
                        <RadzenDataGrid @ref="grid"
                                        IsLoading="@isLoading"
                                        AllowColumnResize="true"
                                        AllowSorting="false"
                                        AllowPaging="true"
                                        ShowPagingSummary="true"
                                        PageSize="15"
                                        Density="Density.Compact"
                                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                        LogicalFilterOperator="LogicalFilterOperator.Or"
                                        LoadData="LoadData"
                                        Data="@items"
                                        Count="@cantidad"
                                        TItem="Resin1DTO"
                                        ColumnWidth="3.33%">
                            <EmptyTemplate>
                                <div class="empty-state">No hay reportes para la búsqueda seleccionada.</div>
                            </EmptyTemplate>
                            <Columns>
                                <RadzenDataGridColumn TItem="Resin1DTO" Property="Nrores" Title="Nro Resultado" Width="21.7%">
                                    <Template Context="data">
                                        @(string.IsNullOrWhiteSpace(data.Nrores) ? "Sin solicitud" : data.Nrores)
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="Resin1DTO" Property="Nropla" Title="Plantel" Width="21.7%" />
                                <RadzenDataGridColumn TItem="Resin1DTO" Property="Socio.Nombre" Title="Socio" Width="21.7%" />
                                <RadzenDataGridColumn TItem="Resin1DTO" Property="FchUsu" Title="Fecha de Creación" Width="21.7%">
                                    <Template Context="data">
                                        @if (data.FchUsu.HasValue)
                                        {
                                            @data.FchUsu.Value.ToString("dd/MM/yyyy")
                                        }
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="Resin1DTO" Property="Freali" Title="Fecha De Inspeccion" Width="21.7%">
                                    <Template Context="data">
                                        @if (data.Freali.HasValue)
                                        {
                                            @data.Freali.Value.ToString("dd/MM/yyyy")
                                        }
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="Resin1DTO" Property="" Title="" Filterable="false" Width="3.33%">
                                    <Template Context="data">
                                        <button class="btn" title="Editar" @onclick="() => add(data.Id, 0)"><FeatherEdit Size="16" Color="green" /></button>
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="Resin1DTO" Property="" Title="" Filterable="false" Width="3.33%">
                                    <Template Context="data">
                                        <button class="btn" title="Eliminar" @onclick="() => alertaDelete(data.Id)"><FeatherTrash Size="16" Color="red" /></button>
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    </div>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView Roles="Socio">
                <Authorized Context="reportesSocioGrid">
                    <div class="reportes-card tablacontent">
                        <RadzenDataGrid @ref="grid"
                                        IsLoading="@isLoading"
                                        AllowColumnResize="true"
                                        AllowSorting="false"
                                        AllowPaging="true"
                                        ShowPagingSummary="true"
                                        PageSize="15"
                                        Density="Density.Compact"
                                        FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                        LogicalFilterOperator="LogicalFilterOperator.Or"
                                        LoadData="LoadData"
                                        Data="@items"
                                        Count="@cantidad"
                                        TItem="Resin1DTO"
                                        ColumnWidth="3.33%">
                            <EmptyTemplate>
                                <div class="empty-state">No hay reportes para la búsqueda seleccionada.</div>
                            </EmptyTemplate>
                            <Columns>
                                <RadzenDataGridColumn TItem="Resin1DTO" Property="Nrores" Title="Nro Resultado" Width="21.7%" />
                                <RadzenDataGridColumn TItem="Resin1DTO" Property="Nropla" Title="Plantel" Width="21.7%" />
                                <RadzenDataGridColumn TItem="Resin1DTO" Property="Establecimiento.Nombre" Title="Establecimiento" Width="21.7%" />
                                <RadzenDataGridColumn TItem="Resin1DTO" Property="FchUsu" Title="Fecha de Creación" Width="21.7%">
                                    <Template Context="data">
                                        @if (data.FchUsu.HasValue)
                                        {
                                            @data.FchUsu.Value.ToString("dd/MM/yyyy")
                                        }
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="Resin1DTO" Property="Freali" Title="Fecha De Inspeccion" Width="21.7%">
                                    <Template Context="data">
                                        @if (data.Freali.HasValue)
                                        {
                                            @data.Freali.Value.ToString("dd/MM/yyyy")
                                        }
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="Resin1DTO" Property="" Title="" Filterable="false" Width="3.33%">
                                    <Template Context="data">
                                        <button class="btn" title="Editar" @onclick="() => add(data.Id, 1)"><FeatherEdit Size="16" Color="green" /></button>
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    </div>
                </Authorized>
            </AuthorizeView>
        </Authorized>
    </AuthorizeView>
</div>


@code {
    [CascadingParameter] public IModalService Modal { get; set; } = default!;
    public RadzenDataGrid<Resin1DTO>? grid;

    private List<Resin1DTO> items = new();
    private bool isLoading;
    private bool searchLoading;
    private int cantidad;
    private string searchText = string.Empty;
    private int loadRequestVersion;
    private bool initialGridLoadTriggered;

    protected override Task OnInitializedAsync()
        => Task.CompletedTask;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || initialGridLoadTriggered || grid == null)
        {
            return;
        }

        initialGridLoadTriggered = true;
        await grid.Reload();
    }

    private async Task LoadData(LoadDataArgs args)
    {
        var requestId = ++loadRequestVersion;
        isLoading = true;

        try
        {
            var response = await _resin1Servicio.SearchPaged(args.Skip ?? 0, args.Top ?? 15, searchText);
            if (requestId != loadRequestVersion)
            {
                return;
            }

            items = response.List?.Items ?? new List<Resin1DTO>();
            cantidad = response.List?.TotalCount ?? 0;
        }
        catch (Exception ex)
        {
            items = new List<Resin1DTO>();
            cantidad = 0;
            await Swal.FireAsync("Error", ex.Message, SweetAlertIcon.Error);
        }
        finally
        {
            if (requestId == loadRequestVersion)
            {
                isLoading = false;
                searchLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task OnSearchChanged(string value)
    {
        searchLoading = true;
        searchText = value ?? string.Empty;
        await ReloadGridFromStartAsync();
    }

    private async Task ReloadGridFromStartAsync()
    {
        if (grid != null)
        {
            if (grid.CurrentPage > 0)
            {
                await grid.FirstPage(true);
            }
            else
            {
                await grid.Reload();
            }
        }
    }

    async Task delete(int id)
    {
        var response = await _resin1Servicio.Eliminar(id);
        if (response)
        {
            await ReloadGridFromStartAsync();
        }
    }

    public async Task alertaDelete(int id)
    {
        SweetAlertResult result = await Swal.FireAsync(new SweetAlertOptions
        {
            Title = "¿Está seguro?",
            Text = "Se eliminará el reporte",
            Icon = SweetAlertIcon.Warning,
            ShowCancelButton = true,
            ConfirmButtonText = "Eliminar",
            CancelButtonText = "Cancelar"
        });

        if (!string.IsNullOrEmpty(result.Value))
        {
            await delete(id);
        }
    }

    async Task add(int Id, int esSocio)
    {
        nav.NavigateTo($"/inforeporte/{Id}/{esSocio}");
    }
}
