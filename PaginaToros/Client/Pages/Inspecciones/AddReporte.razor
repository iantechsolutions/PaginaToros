        private string GetMotivoRechazoLabel(int? motivoRechazo)
        {
            var key = (motivoRechazo ?? 0).ToString();
            return traductor.TryGetValue(key, out var descripcion) ? descripcion : "Sin motivo";
        }

        // Search helpers used by Blazored.Typeahead
        private async Task<IEnumerable<SocioDTO>> BusquedaSocios(string searchText)
        {
            var term = (searchText ?? string.Empty).Trim();
            var result = socios
                .Where(x => x.Criador == "S" && !string.IsNullOrEmpty(x.Nombre) && x.Nombre.Contains(term, StringComparison.OrdinalIgnoreCase))
                .ToList();
            return await Task.FromResult(result);
        }

        private async Task<IEnumerable<InspectDTO>> BusquedaInspects(string searchText)
        {
            var term = (searchText ?? string.Empty).Trim();
            var result = Inspects
                .Where(x => !string.IsNullOrEmpty(x.Nombre) && x.Nombre.Contains(term, StringComparison.OrdinalIgnoreCase))
                .ToList();
            return await Task.FromResult(result);
        }

        private async Task<IEnumerable<PlantelDTO>> BusquedaPlanteles(string searchText)
        {
            var term = (searchText ?? string.Empty).Trim();
            var scod = socioSeleccionado?.Scod;
            var result = OrderPlantelesByYear(Planteles)
                .Where(x => !string.IsNullOrEmpty(x.Placod) && x.Placod.Contains(term, StringComparison.OrdinalIgnoreCase) && x.Nrocri == scod)
                .ToList();
            return await Task.FromResult(result);
        }

        private static string FormatoPlantel(PlantelDTO? plantel)
        {
            if (plantel is null)
            {
                return string.Empty;
            }

            var placod = plantel.Placod?.Trim() ?? string.Empty;
            var anio = plantel.Anioex?.Trim() ?? string.Empty;

            if (string.IsNullOrWhiteSpace(anio))
            {
                return placod;
            }

            if (string.IsNullOrWhiteSpace(placod))
            {
                return anio;
            }

            return $"{placod} - {anio}";
        }

