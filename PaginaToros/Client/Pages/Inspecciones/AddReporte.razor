async Task<PlantelDTO> updatePlantel(bool _subirDeAnioNoSeUsa)
 {
    if (socioSeleccionado is null)
        throw new InvalidOperationException("No hay socio seleccionado.");

    var socio = socioSeleccionado!;
    var inspectionYear = GetInspectionYear();
    var anioDestino = inspectionYear.ToString();

    // Refrescar listado de planteles
    var plan = await _plantelServicio.LimitadosFiltradosNoInclude(0, 0);
    Planteles = plan.List;

    PlantelDTO? planDestino = null;

    // Si no pedimos forzar la creación, intentar localizar un plantel existente
    if (!_subirDeAnioNoSeUsa)
    {
        // 1) PRIORIDAD: plantel asociado al resultado
        if (!string.IsNullOrWhiteSpace(oResin1?.Nropla))
        {
            planDestino = Planteles.FirstOrDefault(x => x.Placod == oResin1.Nropla);
        }

        // 2) Si no se encontró, usar Año + Socio
        if (planDestino == null)
        {
            planDestino = Planteles.FirstOrDefault(x => x.Anioex == anioDestino && x.Nrocri == socio.Scod);
        }
    }

    var ultimoDigito = anioDestino.Last();
    var fechaCreacionPlantel = (oResin1?.Freali ?? fechaTemp).ToString("yyyy/MM/dd");
    var fechaAltaPlantel = DateTime.Now.ToString("yyyy/MM/dd");

    if (planDestino != null && !_subirDeAnioNoSeUsa)
    {
        // Actualizar plantel existente (solo si no se forza creación)
        planDestino.Varede = estadoFinal.Ea1;
        planDestino.Vqcsrd = estadoFinal.Ea2;
        planDestino.Vqssrd = estadoFinal.Ea3;
        planDestino.Varepr = estadoFinal.Ea4;
        planDestino.Vqcsrp = estadoFinal.Ea5;
        planDestino.Vqssrp = estadoFinal.Ea6;
        if (string.IsNullOrWhiteSpace(planDestino.Fecing))
        {
            planDestino.Fecing = fechaCreacionPlantel;
        }
        await _plantelServicio.Editar(planDestino);
    }
    else
    {
        // Forzar creación de uno nuevo o no se encontró
        var planViejo = Plantelseleccionado ?? Planteles.FirstOrDefault(x => x.Nrocri == socio.Scod) ?? throw new InvalidOperationException("No hay plantel base.");
        var tailAnterior = DerivarTailCodigo(planViejo.Placod);
        if (string.IsNullOrWhiteSpace(tailAnterior))
            tailAnterior = DerivarTailCodigo(socio.Placod);
        if (string.IsNullOrWhiteSpace(tailAnterior))
            tailAnterior = planViejo.Placod?.Trim() ?? socio.Placod?.Trim() ?? "";

        var nuevoPlacod = $"{ultimoDigito}{tailAnterior}";

        // Si existe un plantel con el mismo código nuevo, intentar evitar colisiones incrementando un suffix
        var candidate = nuevoPlacod;
        int suffix = 1;
        while (Planteles.Any(p => p.Placod == candidate))
        {
            candidate = nuevoPlacod + suffix.ToString();
            suffix++;
        }

        planDestino = new PlantelDTO
        {
            Anioex = anioDestino,
            Placod = candidate,
            Varede = estadoFinal.Ea1,
            Vqcsrd = estadoFinal.Ea2,
            Vqssrd = estadoFinal.Ea3,
            Varepr = estadoFinal.Ea4,
            Vqcsrp = estadoFinal.Ea5,
            Vqssrp = estadoFinal.Ea6,
            Nrocri = planViejo.Nrocri,
            Estado = planViejo.Estado,
            Fecing = fechaAltaPlantel,
            Nroins = planViejo.Nroins
        };

        var creado = await _plantelServicio.Crear(planDestino);
        planDestino = creado?.List ?? planDestino;
    }

    Plantelseleccionado = planDestino;
    return planDestino;

    static string DerivarTailCodigo(string? codigo)
    {
        var c = (codigo ?? "").Trim();
        if (string.IsNullOrEmpty(c)) return "";
        if (c.Length > 4 && char.IsDigit(c[0])) c = c.Substring(1);
        if (c.Length > 4) c = c.Substring(c.Length - 4);
        return c;
    }
}




