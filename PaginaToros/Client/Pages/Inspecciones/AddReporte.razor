    async Task updatePromedios(string nrores)
    {
        loadingProms = true; await InvokeAsync(StateHasChanged);
        try
        {
            string filtro = $"(Nrores == null ? \"\" : Nrores).ToLower().Contains(\"{nrores}\".ToLower())";
            var rtt = await _resin4Servicio.LimitadosFiltrados(0, 2, filtro);
            if (rtt.List.Count > 0)
            {
                promediohembra = rtt.List.FirstOrDefault(x => x.Sexo == "H") ?? new();
                promediomacho = rtt.List.FirstOrDefault(x => x.Sexo == "M") ?? new();
            }
            else { promediohembra = new(); promediomacho = new(); }
        }
        finally
        {
            loadingProms = false; await InvokeAsync(StateHasChanged);
        }
    }

    async Task updateRechazos(string nrores)
    {
        loadingRech = true; await InvokeAsync(StateHasChanged);
        try
        {
