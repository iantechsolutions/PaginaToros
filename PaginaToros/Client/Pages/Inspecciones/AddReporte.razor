            return;
        }

        if (inspectorSeleccionado is null)
        {
            await Swal.FireAsync("Error", "Debe seleccionar un inspector.", SweetAlertIcon.Error);
            return;
        }

        // 2) Tomar plantel base (para 'Existencia anterior'), pero SIN pisar selección del usuario
        PlantelDTO? plantel = Plantelseleccionado;

        if (plantel is null)
        {
            // Primero buscar por el mismo año de la fecha de inspección
            var anio = fechaTemp.Year.ToString();
            plantel = Planteles
                .Where(x => x.Nrocri == socioSeleccionado.Scod && x.Anioex == anio)
                .FirstOrDefault()
                ?? Planteles
                    .Where(x => x.Nrocri == socioSeleccionado.Scod)
                    .FirstOrDefault();
        }

        if (plantel is null)
        {
            await Swal.FireAsync("Error", "El socio no tiene plantel registrado.", SweetAlertIcon.Error);
            return;
        }

        Plantelseleccionado = plantel;

        // 2.1) Mostrar tabs y loaders ya mismo
        loadingMovs = loadingHemyma = loadingProms = loadingRech = true;
        confirmado = true;
        isSavingReporte = true;
        await InvokeAsync(StateHasChanged);

