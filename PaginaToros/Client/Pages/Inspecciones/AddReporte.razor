    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    async Task CargarDatos()
    {
        try
        {
            isInitialLoading = true;
            loadingMessage = Id != 0 ? "Cargando reporte y datos asociados..." : "Preparando formulario de inspección...";
            await InvokeAsync(StateHasChanged);
            await Task.Yield();

            var inspectTask = _inspectServicio.LimitadosFiltrados(0, 0);
            var plantelTask = _plantelServicio.LimitadosFiltradosNoInclude(0, 0);

            var sociosTask = Id == 0
                ? _socioServicio.LimitadosFiltrados(0, 0)
                : Task.FromResult(new Respuesta<List<SocioDTO>> { List = new List<SocioDTO>() });
            var solicitudesTask = Id == 0
                ? _solici1Servicio.LimitadosFiltradosNoInclude(0, 0)
                : Task.FromResult(new Respuesta<List<Solici1DTO>> { List = new List<Solici1DTO>() });
            var resultadosTask = Id == 0
                ? _resin1Servicio.LimitadosFiltradosNoInclude(0, 0)
                : Task.FromResult(new Respuesta<List<Resin1DTO>> { List = new List<Resin1DTO>() });
            var establecimientosTask = _estableServicio.LimitadosFiltradosNoInclude(0, 0);

            esSocio = opcion == 1;

            if (Id != 0)
            {
                isLoadingDependencias = true;
                loadingMessage = "Cargando dependencias del reporte...";
                await InvokeAsync(StateHasChanged);
                await Task.Yield();

                string filtro = $"Id = {Id}";
                var res = await _resin1Servicio.LimitadosFiltradosNoInclude(0, 1, filtro);
                oResin1 = res.List.FirstOrDefault() ?? new Resin1DTO();

                var socioFiltro = $"(Scod == null ? \"\" : Scod).ToLower().Contains(\"{EscapeForFilter(oResin1.Scod)}\".ToLower())";
                var rt = await _socioServicio.LimitadosFiltrados(0, 1, socioFiltro);
                socioSeleccionado = rt.List.FirstOrDefault(x => x.Scod == oResin1.Scod) ?? new SocioDTO();

                if (!string.IsNullOrWhiteSpace(oResin1.Nrores))
                {
                    solicitudSeleccionada = new List<Solici1DTO?>
                    {
                        new Solici1DTO
                        {
                            Nrosol = oResin1.Nrores,
                            Codest = oResin1.Estcod,
                            Fecsol = oResin1.Freali
                        }
                    };
                }

                inspectorSeleccionado = null;
                Plantelseleccionado = null;
                establecimientoSeleccionado = null;
            }
            else
            {
                var sociosResponse = await sociosTask;
                socios = OrderSociosByCreation(sociosResponse.List);

                var solicitudesResponse = await solicitudesTask;
                solicitudes = OrderSolicitudesByCreation(solicitudesResponse.List);

                var resultadosResponse = await resultadosTask;
                resultados = OrderResultadosByCreation(resultadosResponse.List);
            }

            var inspectResponse = await inspectTask;
            Inspects = OrderInspectsByCreation(inspectResponse.List);

            var plantelResponse = await plantelTask;
            Planteles = OrderPlantelesByYear(plantelResponse.List);

            var establecimientosResponse = await establecimientosTask;
            establecimientos = establecimientosResponse.List ?? new List<EstableDTO>();
            establecimientosPorCodigo = establecimientos
                .Where(x => !string.IsNullOrWhiteSpace(x.Ecod))
                .GroupBy(x => x.Ecod!, StringComparer.OrdinalIgnoreCase)
                .ToDictionary(x => x.Key, x => x.First(), StringComparer.OrdinalIgnoreCase);

            if (Id != 0)
            {
                var establecimiento = GetEstablecimientoForCurrentReport();
                establecimientoSeleccionado = establecimiento;

                if (socioSeleccionado != null)
                {
                    LoadSocioDerivedState(false);
                    var nrores = oResin1?.Nrores;
                    if (!string.IsNullOrWhiteSpace(nrores))
                    {
                        await LoadReportSectionsAsync(nrores, firstLoad: true);
                    }
                }

                Plantelseleccionado = Planteles.FirstOrDefault(x => x.Placod == oResin1.Nropla);
                if (Plantelseleccionado == null && oResin1?.Freali.HasValue == true)
                {
                    var anio = oResin1.Freali.Value.Year.ToString();
                    Plantelseleccionado = Planteles.FirstOrDefault(x => x.Anioex == anio && x.Nrocri == socioSeleccionado?.Scod);
                }
            }
            else
            {
                RefreshDerivedLists();
            }

            confirmado = Id != 0;
        }
        catch (Exception ex)
        {
            oRespuesta.Mensaje = ex.Message;
        }
        finally
        {
            isLoadingDependencias = false;
            isInitialLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string EscapeForFilter(string? value) => (value ?? string.Empty).Replace("\"", "\\\"");

    private void LoadSocioDerivedState(bool resetSelections)
    {
        if (resetSelections)
        {
            solicitudSeleccionada = null;
            Plantelseleccionado = null;
            establecimientoSeleccionado = null;
        }

        RefreshDerivedLists();
    }

    private void RefreshDerivedLists()
    {
        var codigosSocio = socioSeleccionado?.Scod == null
            ? new HashSet<string>(StringComparer.OrdinalIgnoreCase)
            : establecimientos
                .Where(x => string.Equals(x.Codsoc, socioSeleccionado.Scod, StringComparison.OrdinalIgnoreCase))
                .Select(x => x.Ecod)
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var resultadosNrores = resultados
            .Where(x => !string.IsNullOrWhiteSpace(x.Nrores))
            .Select(x => x.Nrores!)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        solicitudesVisibles = solicitudes
            .Where(x => !string.IsNullOrWhiteSpace(x.Codest))
            .Where(x => codigosSocio.Contains(x.Codest!))
            .Where(x => string.IsNullOrWhiteSpace(x.Nrosol) || !resultadosNrores.Contains(x.Nrosol))
            .ToList();
    }

    private async Task LoadReportSectionsAsync(string nrores, bool firstLoad = false)
    {
        if (string.IsNullOrWhiteSpace(nrores))
        {
            return;
        }

        loadingMovs = loadingHemyma = loadingProms = loadingRech = true;
        if (!firstLoad)
        {
            await InvokeAsync(StateHasChanged);
        }

        try
        {
            await updateEstadoHistorico(nrores);
            await Task.WhenAll(
                updatePromedios(nrores),
                updateRechazos(nrores),
                updateHembrasMachos(nrores)
            );
            await updateMovimientos(nrores, "no");
        }
        finally
        {
            loadingMovs = loadingHemyma = loadingProms = loadingRech = false;
        }
    }

    private async Task OnSocioChanged(SocioDTO? socio)
    {
        isLoadingDependencias = true;
        loadingMessage = socio != null ? "Cargando datos del socio seleccionado..." : "Limpiando selección...";
        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        socioSeleccionado = socio;

        if (socio == null)
        {
            solicitudSeleccionada = null;
            Plantelseleccionado = null;
            establecimientoSeleccionado = null;
            inspectorSeleccionado = null;
            confirmado = false;
            oResin1 = new Resin1DTO();
            RefreshDerivedLists();
        }
        else
        {
            if (Id == 0)
            {
                solicitudSeleccionada = null;
                oResin1 = new Resin1DTO
                {
                    Freali = fechaTemp,
                    Scod = socio.Scod
                };
                establecimientoSeleccionado = establecimientos.FirstOrDefault(x => string.Equals(x.Codsoc, socio.Scod, StringComparison.OrdinalIgnoreCase));
                Plantelseleccionado = Planteles.FirstOrDefault(x => string.Equals(x.Nrocri, socio.Scod, StringComparison.OrdinalIgnoreCase));
                inspectorSeleccionado = null;
                confirmado = true;
            }

            RefreshDerivedLists();
        }

        isLoadingDependencias = false;
        await InvokeAsync(StateHasChanged);
    }

    private Solici1DTO? SelectedSolicitud => solicitudSeleccionada?.FirstOrDefault();

    private string? SelectedLocalidad
    {
        get
        {
            var codest = SelectedSolicitud?.Codest;
            if (string.IsNullOrWhiteSpace(codest))
            {
                return establecimientoSeleccionado?.Locali;
            }

            if (establecimientoSeleccionado != null && string.Equals(establecimientoSeleccionado.Ecod, codest, StringComparison.OrdinalIgnoreCase))
            {
                return establecimientoSeleccionado.Locali;
            }

            return establecimientosPorCodigo.TryGetValue(codest, out var establecimiento)
                ? establecimiento.Locali
                : string.Empty;
        }
    }

    private EstableDTO? GetEstablecimientoForCurrentReport()
    {
        var codest = oResin1?.Estcod ?? SelectedSolicitud?.Codest;
        if (string.IsNullOrWhiteSpace(codest))
        {
            return null;
        }

        if (establecimientoSeleccionado != null && string.Equals(establecimientoSeleccionado.Ecod, codest, StringComparison.OrdinalIgnoreCase))
        {
            return establecimientoSeleccionado;
        }

        return establecimientosPorCodigo.TryGetValue(codest, out var establecimiento)
            ? establecimiento
            : establecimientos.FirstOrDefault(x => string.Equals(x.Ecod, codest, StringComparison.OrdinalIgnoreCase));
    }

    DateTime? GetSocioCreationDate(SocioDTO? socio)
