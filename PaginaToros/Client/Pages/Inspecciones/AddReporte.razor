async Task ResultWithoutSolicitud()
{
    Console.WriteLine("ResultWithoutSolicitud");

    try
    {
        // 1) Validaciones básicas
        if (socioSeleccionado is null)
        {
            await Swal.FireAsync("Error", "Debe seleccionar un socio.", SweetAlertIcon.Error);
            return;
        }

        var codEst = establecimientos.FirstOrDefault(x => x.Codsoc == socioSeleccionado.Scod)?.Ecod;
        if (string.IsNullOrWhiteSpace(codEst))
        {
