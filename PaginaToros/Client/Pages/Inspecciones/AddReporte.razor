    List<PlantelDTO> OrderPlantelesByYear(IEnumerable<PlantelDTO>? items)
        => (items ?? Enumerable.Empty<PlantelDTO>())
            .OrderByDescending(x => TryGetPlantelYear(x).HasValue)
            .ThenByDescending(x => TryGetPlantelYear(x))
            .ThenByDescending(x => x.Id)
            .ToList();

    private static int? TryGetPlantelYear(PlantelDTO? plantel)
    {
        if (plantel == null || string.IsNullOrWhiteSpace(plantel.Anioex))
        {
            return null;
        }

        return int.TryParse(plantel.Anioex, out var year) ? year : null;
    }

    List<SocioDTO> OrderSociosByCreation(IEnumerable<SocioDTO>? items)
        => (items ?? Enumerable.Empty<SocioDTO>())
            .OrderByDescending(x => GetSocioCreationDate(x).HasValue)
            .ThenByDescending(x => GetSocioCreationDate(x))
            .ThenByDescending(x => x.Id)
            .ToList();

    List<Solici1DTO> OrderSolicitudesByCreation(IEnumerable<Solici1DTO>? items)
        => (items ?? Enumerable.Empty<Solici1DTO>())
            .OrderByDescending(x => GetSolicitudCreationDate(x).HasValue)
            .ThenByDescending(x => GetSolicitudCreationDate(x))
            .ThenByDescending(x => x.Id)
            .ToList();

    List<InspectDTO> OrderInspectsByCreation(IEnumerable<InspectDTO>? items)
        => (items ?? Enumerable.Empty<InspectDTO>())
            .OrderByDescending(x => GetInspectCreationDate(x).HasValue)
            .ThenByDescending(x => GetInspectCreationDate(x))
            .ThenByDescending(x => x.Id)
