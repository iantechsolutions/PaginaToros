            var destino = await updatePlantel(_subirDeAnioNoSeUsa: true); // crea/actualiza 2025D1D1
            Plantelseleccionado = destino;                         // reflejar en UI

            // Forzar asociación del RESULTADO al NUEVO plantel
            oResin1.Nropla = destino.Placod;
            await _resin1Servicio.Editar(oResin1);

            // Esperar a que el backend refleje el cambio
            await EsperarActualizacionNropla(Id, destino.Placod);

            // Refrescar entidad y UI
            var actualizado = await _resin1Servicio.LimitadosFiltradosNoInclude(0, 1, $"Id = {Id}");
            oResin1 = actualizado.List.FirstOrDefault() ?? oResin1;
            Plantelseleccionado = Planteles.FirstOrDefault(x => x.Placod == oResin1.Nropla) ?? Plantelseleccionado;

            createNewPlantel = false; // evitar saltos a 2026, 2027...
            isUpdatingPlantel = false;
            await InvokeAsync(StateHasChanged);
        }

        // 6) Refrescar grilla de resultados
        var rtRes = await _resin1Servicio.LimitadosFiltradosNoInclude(0, 0);
        resultados = rtRes.List;
        RefreshDerivedLists();

        // 7) Render final
        await InvokeAsync(StateHasChanged);
    }
    catch (Exception ex)
    {
        Console.WriteLine(ex.Message);
        await Swal.FireAsync("Error", $"Ocurrió un error al crear el resultado sin solicitud: {ex.Message}", SweetAlertIcon.Error);
        loadingMovs = loadingHemyma = loadingProms = loadingRech = false;
        isSavingReporte = false;
        await InvokeAsync(StateHasChanged);
    }
    finally
    {
        isSavingReporte = false;
    }
}




