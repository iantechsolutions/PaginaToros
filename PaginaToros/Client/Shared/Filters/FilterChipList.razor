@if (Items?.Any() == true)
{
    <div class="filter-chip-list">
        @foreach (var item in Items)
        {
            <button type="button" class="filter-chip" @onclick="() => Remove(item.Key)">
                <span>@GetText(item)</span>
                <span class="filter-chip-close">x</span>
            </button>
        }
    </div>
}

@code {
    [Parameter] public IReadOnlyList<FilterChipItem> Items { get; set; } = Array.Empty<FilterChipItem>();
    [Parameter] public EventCallback<string> OnRemove { get; set; }

    private Task Remove(string key)
        => OnRemove.InvokeAsync(key);

    private static string GetText(FilterChipItem item)
        => string.IsNullOrWhiteSpace(item.Label)
            ? item.Value
            : string.IsNullOrWhiteSpace(item.Value)
                ? item.Label
                : $"{item.Label}: {item.Value}";
}
